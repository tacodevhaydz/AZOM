<Window x:Class="MozaPlugin.ColorPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:MozaControls"
        xmlns:res="clr-namespace:MozaPlugin.Resources"
        Title="{x:Static res:Strings.Title_PickLedColor}" Width="380" Height="440"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource BgDeepBrush}"
        TextElement.Foreground="{DynamicResource TextBrush}"
        TextElement.FontFamily="{DynamicResource FontUi}"
        TextElement.FontSize="13">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MozaPlugin;component/Themes/MozaTheme.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/MozaPlugin;component/Themes/MozaIcons.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style TargetType="Button" BasedOn="{StaticResource MozaButton}"/>
            <Style TargetType="Slider" BasedOn="{StaticResource MozaSlider}"/>
            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>
    <StackPanel Margin="22,18">
        <!-- Curated palette -->
        <TextBlock Text="{x:Static res:Strings.Label_Palette}" FontSize="10" FontWeight="SemiBold"
                   Foreground="{StaticResource TextFaintBrush}" Margin="0,0,0,8"/>
        <ctrl:PaletteStrip x:Name="Palette" Margin="0,0,0,14"/>

        <!-- Preview + Last Used -->
        <Grid Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Border x:Name="ColorPreview" Grid.Column="0" Height="46" CornerRadius="5"
                    BorderBrush="{StaticResource BorderBrightBrush}" BorderThickness="1"
                    Background="Black"/>
            <StackPanel x:Name="LastColorPanel" Grid.Column="1" Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="12,0,0,0" Visibility="Collapsed">
                <TextBlock Text="{x:Static res:Strings.Label_Last}" FontSize="10" FontWeight="SemiBold"
                           Foreground="{StaticResource TextFaintBrush}"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <Border x:Name="LastColorSwatch" Height="32" Width="32" CornerRadius="4"
                        BorderBrush="{StaticResource BorderBrightBrush}" BorderThickness="1"
                        Cursor="Hand" Background="Black" Tag="0,0,0"
                        MouseLeftButtonUp="Preset_Click"/>
            </StackPanel>
        </Grid>

        <!-- HSV / RGB fine-tune -->
        <TextBlock Text="{x:Static res:Strings.Label_FineTuneRgb}" FontSize="10" FontWeight="SemiBold"
                   Foreground="{StaticResource TextFaintBrush}" Margin="0,0,0,8"/>
        <Grid Margin="0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="40"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="R" VerticalAlignment="Center" FontWeight="Bold"
                       Foreground="{StaticResource RedBrush}"/>
            <Slider Grid.Column="1" x:Name="RSlider" Minimum="0" Maximum="255" TickFrequency="1"
                    IsSnapToTickEnabled="True" ValueChanged="Slider_ValueChanged"/>
            <TextBlock Grid.Column="2" x:Name="RValue" TextAlignment="Right" VerticalAlignment="Center"
                       FontFamily="{StaticResource FontMono}" Foreground="{StaticResource CyanBrush}"
                       Text="0"/>
        </Grid>
        <Grid Margin="0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="40"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="G" VerticalAlignment="Center" FontWeight="Bold"
                       Foreground="{StaticResource GreenBrush}"/>
            <Slider Grid.Column="1" x:Name="GSlider" Minimum="0" Maximum="255" TickFrequency="1"
                    IsSnapToTickEnabled="True" ValueChanged="Slider_ValueChanged"/>
            <TextBlock Grid.Column="2" x:Name="GValue" TextAlignment="Right" VerticalAlignment="Center"
                       FontFamily="{StaticResource FontMono}" Foreground="{StaticResource CyanBrush}"
                       Text="0"/>
        </Grid>
        <Grid Margin="0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="40"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="B" VerticalAlignment="Center" FontWeight="Bold"
                       Foreground="#FF6495ED"/>
            <Slider Grid.Column="1" x:Name="BSlider" Minimum="0" Maximum="255" TickFrequency="1"
                    IsSnapToTickEnabled="True" ValueChanged="Slider_ValueChanged"/>
            <TextBlock Grid.Column="2" x:Name="BValue" TextAlignment="Right" VerticalAlignment="Center"
                       FontFamily="{StaticResource FontMono}" Foreground="{StaticResource CyanBrush}"
                       Text="0"/>
        </Grid>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="{x:Static res:Strings.Button_Cancel}" Width="80" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="{x:Static res:Strings.Button_Ok}" Width="80" IsDefault="True"
                    Style="{StaticResource MozaButtonPrimary}" Click="Ok_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
