<UserControl x:Class="MozaPlugin.UI.PluginBanners"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:res="clr-namespace:MozaPlugin.Resources"
             xmlns:ui="clr-namespace:MozaPlugin.UI">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MozaPlugin;component/Themes/MozaTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <!-- Unified cross-page banner stack: status hints + update notification +
         SDK nudge. Self-refreshing (see PluginBanners.xaml.cs); each element
         collapses independently, so the whole control is zero-height when
         nothing is active. Hosted at the top of the plugin pane and every
         SimHub device page. The host supplies the outer horizontal margin. -->
    <StackPanel>

        <!-- 1. Status-hint banners (port-locked, restart-required,
             profile-not-added, telemetry parked/degraded). -->
        <ItemsControl x:Name="HintList" KeyboardNavigation.TabNavigation="None">
            <ItemsControl.Style>
                <Style TargetType="ItemsControl">
                    <Style.Triggers>
                        <Trigger Property="HasItems" Value="False">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ItemsControl.Style>
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type ui:StatusHint}">
                    <Border Style="{StaticResource BannerBorder}" Margin="0,8,0,0">
                        <StackPanel>
                            <TextBlock Text="{Binding Title}" FontWeight="Bold"
                                       Foreground="#FFD7A0"/>
                            <TextBlock Text="{Binding Body}" Foreground="#FFD7A0"
                                       TextWrapping="Wrap" Margin="0,2,0,0"/>
                            <!-- Restart button: only the device-definition-deployed
                                 banner shows it (ShowRestartButton). Wired to
                                 MozaPlugin.RestartSimHub() via HintRestart_Click. -->
                            <Button Content="{x:Static res:Strings.Button_RestartSimHub}"
                                    Click="HintRestart_Click"
                                    HorizontalAlignment="Left" Margin="0,8,0,0">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource MozaButton}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ShowRestartButton}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- 2. Update notification banner: newer release available (or an
             install pending a restart). Dismissable for the session; the full
             controls (channel, skip, check-now, notes) live in About > Updates
             on the plugin pane. Driven by PluginBanners.xaml.cs. -->
        <Border x:Name="HeaderUpdateBanner"
                Visibility="Collapsed"
                Margin="0,8,0,0"
                BorderBrush="{StaticResource CyanBrush}"
                BorderThickness="1"
                Background="{StaticResource BgDeepBrush}"
                CornerRadius="4"
                Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock x:Name="HeaderUpdateBannerText"
                               FontFamily="{StaticResource FontUi}"
                               FontSize="12.5" FontWeight="SemiBold"
                               Foreground="{StaticResource CyanBrush}"
                               TextWrapping="Wrap"/>
                    <TextBlock x:Name="HeaderUpdateBannerProgressText"
                               Style="{StaticResource MutedHintText}"
                               TextWrapping="Wrap"
                               Visibility="Collapsed"
                               Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="12,0,0,0">
                    <Button x:Name="HeaderUpdateInstallButton"
                            Content="{x:Static res:Strings.Button_InstallUpdate}"
                            Click="HeaderUpdateInstall_Click"
                            Margin="0,0,8,0"/>
                    <Button x:Name="HeaderUpdateRestartButton"
                            Content="{x:Static res:Strings.Button_RestartSimHub}"
                            Click="HeaderUpdateRestart_Click"
                            Visibility="Collapsed"
                            Margin="0,0,8,0"/>
                    <Button x:Name="HeaderUpdateNotesButton"
                            Content="{x:Static res:Strings.Button_OpenReleaseNotes}"
                            Click="HeaderUpdateNotes_Click"
                            Margin="0,0,8,0"/>
                    <Button x:Name="HeaderUpdateDismissButton"
                            Content="{x:Static res:Strings.Button_DismissUpdate}"
                            Click="HeaderUpdateDismiss_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 3. One-time nudge for users without SDK support enabled. Dismissal
             is persisted (SdkPromptDismissed). Driven by PluginBanners.xaml.cs.
             The Configure button navigates to the plugin pane's SDK tab and is
             hidden on device pages (no such tab to reach). -->
        <Border x:Name="SdkPromptBanner"
                Visibility="Collapsed" Margin="0,8,0,0"
                BorderBrush="{StaticResource CyanBrush}" BorderThickness="1"
                Background="{StaticResource BgDeepBrush}" CornerRadius="4" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{x:Static res:Strings.Banner_SdkSuggestionText}"
                           FontFamily="{StaticResource FontUi}" FontSize="12.5" FontWeight="SemiBold"
                           Foreground="{StaticResource CyanBrush}"
                           TextWrapping="Wrap" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="12,0,0,0">
                    <Button x:Name="SdkPromptConfigureButton"
                            Content="{x:Static res:Strings.Button_ConfigureSdk}"
                            Click="SdkPromptConfigure_Click" Margin="0,0,8,0"/>
                    <Button x:Name="SdkPromptDismissButton"
                            Content="{x:Static res:Strings.Button_Dismiss}"
                            Click="SdkPromptDismiss_Click"/>
                </StackPanel>
            </Grid>
        </Border>

    </StackPanel>
</UserControl>
