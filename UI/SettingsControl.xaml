                                                                            Margin="6,0,0,0" Click="MBoosterCancelFormula_Click" Tag="{Binding}"/>
                                                                    <Button Grid.Column="2" Content="{x:Static res:Strings.Button_Ok}"
                                                                            MinWidth="60" Margin="6,0,0,0"
                                                                            Click="MBoosterCommitFormula_Click" Tag="{Binding}"/>
                                                                </Grid>
                                                                <ListBox ItemsSource="{Binding FilteredProperties}"
                                                                         SelectedItem="{Binding PendingProperty, Mode=TwoWay}"
                                                                         MaxHeight="240"
                                                                         Background="{DynamicResource BgDeepBrush}"
                                                                         Foreground="{DynamicResource TextBrush}"
                                                                         BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                                                         VirtualizingStackPanel.IsVirtualizing="True"
                                                                         VirtualizingStackPanel.VirtualizationMode="Recycling"
                                                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                                                                    <ListBox.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <TextBlock Text="{Binding}" FontFamily="{DynamicResource FontMono}"
                                                                                       FontSize="12" Foreground="{DynamicResource TextBrush}" Padding="6,3"/>
                                                                        </DataTemplate>
                                                                    </ListBox.ItemTemplate>
                                                                </ListBox>
                                                            </StackPanel>
                                                        </Border>
                                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                            <ctrl:OffOnToggle Content="{x:Static res:Strings.Label_UseThreshold}" IsChecked="{Binding ThresholdEnabled}" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <Grid Margin="0,4" IsEnabled="{Binding ThresholdEnabled}">
