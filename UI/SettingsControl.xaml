                                            Content="{x:Static res:Strings.Button_LoadEts2Defaults}"
                                            Click="StalksLoadDefaultsButton_Click"
                                            HorizontalAlignment="Left" Padding="14,6" Margin="0,0,0,10"/>
                                    <ItemsControl x:Name="StalksButtonList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="72"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                        <Ellipse Width="9" Height="9" Margin="0,0,6,0" VerticalAlignment="Center">
                                                            <Ellipse.Style>
                                                                <Style TargetType="Ellipse">
                                                                    <Setter Property="Fill" Value="#3A3A3A"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsPressed}" Value="True">
                                                                            <Setter Property="Fill" Value="LimeGreen"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Ellipse.Style>
                                                        </Ellipse>
                                                        <TextBlock Text="{Binding Label}" VerticalAlignment="Center"
                                                                   Style="{StaticResource SliderLabel}"/>
                                                    </StackPanel>
                                                    <ComboBox Grid.Column="1" Margin="4,1"
                                                              ItemsSource="{Binding Options}"
                                                              SelectedItem="{Binding Selected, Mode=TwoWay}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ctrl:SectionCard>

                            <ctrl:SectionCard Title="{x:Static res:Strings.Section_StalksWiperSync}"
                                              Subtitle="{x:Static res:Strings.Subtitle_StalksWiperSync}"
                                              Icon="{StaticResource IconShift}">
                                <StackPanel>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{x:Static res:Strings.SliderLabel_WiperStageCount}" Style="{StaticResource SliderLabel}"/>
                                        <Slider Grid.Column="1" x:Name="StalksWiperStageSlider" Style="{StaticResource SettingSlider}" Minimum="2" Maximum="8" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="StalksWiperStageSlider_ValueChanged"/>
                                        <TextBox Grid.Column="2" x:Name="StalksWiperStageValue" Style="{StaticResource SliderValueEditBox}"
                                                 Tag="{Binding ElementName=StalksWiperStageSlider}"
                                                 KeyDown="SliderValueBox_KeyDown" LostFocus="SliderValueBox_LostFocus" Text="4"/>
                                    </Grid>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{x:Static res:Strings.Label_WiperForwardWraps}" Style="{StaticResource SliderLabel}"/>
                                        <ctrl:OffOnToggle Grid.Column="1" x:Name="StalksWiperWrapToggle"
                                                          Checked="StalksWiperWrapToggle_Changed" Unchecked="StalksWiperWrapToggle_Changed"/>
                                    </Grid>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{x:Static res:Strings.SliderLabel_LightStageCount}" Style="{StaticResource SliderLabel}"/>
                                        <Slider Grid.Column="1" x:Name="StalksLightStageSlider" Style="{StaticResource SettingSlider}" Minimum="2" Maximum="6" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="StalksLightStageSlider_ValueChanged"/>
                                        <TextBox Grid.Column="2" x:Name="StalksLightStageValue" Style="{StaticResource SliderValueEditBox}"
                                                 Tag="{Binding ElementName=StalksLightStageSlider}"
                                                 KeyDown="SliderValueBox_KeyDown" LostFocus="SliderValueBox_LostFocus" Text="3"/>
                                    </Grid>
                                    <DockPanel Margin="0,10,0,0">
                                        <Button x:Name="StalksResyncButton" DockPanel.Dock="Left"
                                                Content="{x:Static res:Strings.Button_ResyncStages}"
                                                Click="StalksResyncButton_Click" Padding="14,6"/>
                                        <TextBlock Text="{x:Static res:Strings.Hint_ResyncWipers}"
                                                   Style="{StaticResource MutedHintText}" TextWrapping="Wrap"
                                                   VerticalAlignment="Center" Margin="12,0,0,0"/>
                                    </DockPanel>
                                </StackPanel>
                            </ctrl:SectionCard>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="{x:Static res:Strings.TabHeader_Options}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="22,18,22,8">
                    <StackPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <ctrl:SectionCard Grid.Column="0" Margin="0,0,7,14"
                                              Title="{x:Static res:Strings.Section_Profiles}" Icon="{StaticResource IconBolt}">
                                <StackPanel Orientation="Horizontal" Margin="0,8">
                                    <TextBlock Text="{x:Static res:Strings.SliderLabel_ApplyProfileOnLaunch}" Style="{StaticResource SliderLabel}"/>
                                    <ctrl:OffOnToggle x:Name="AutoApplyProfileCheck" VerticalAlignment="Center"
                                              Checked="AutoApplyProfileCheck_Changed" Unchecked="AutoApplyProfileCheck_Changed"/>
                                </StackPanel>
                            </ctrl:SectionCard>

                            <ctrl:SectionCard Grid.Column="1" Margin="7,0,0,14"
                                              Title="{x:Static res:Strings.Section_Language}" Icon="{StaticResource IconBolt}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,8">
                                        <TextBlock Text="{x:Static res:Strings.SliderLabel_Language}" Style="{StaticResource SliderLabel}"/>
                                        <ComboBox x:Name="LanguageCombo" Width="200" VerticalAlignment="Center"
                                                  SelectionChanged="LanguageCombo_Changed"/>
                                    </StackPanel>
                                    <TextBlock Text="{x:Static res:Strings.Hint_LanguageChangeRestart}"
                                               Style="{StaticResource MutedHintText}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </ctrl:SectionCard>
                        </Grid>

                        <ctrl:SectionCard Title="{x:Static res:Strings.Section_SerialTrafficCapture}"
                                          Subtitle="{x:Static res:Strings.Subtitle_SerialTrafficCapture}"
                                          Icon="{StaticResource IconDiag}">
                            <StackPanel>
                                <TextBlock TextWrapping="Wrap" Style="{StaticResource MutedHintText}" Margin="0,0,0,10"
                                           Text="{x:Static res:Strings.Hint_CaptureDataInMemory}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Button x:Name="SerialCaptureToggleButton" Content="{x:Static res:Strings.Button_StartCapture}"
                                            Click="SerialCaptureToggle_Click" MinWidth="120"/>
                                    <TextBlock x:Name="SerialCaptureStatusText" Text="{x:Static res:Strings.Status_Idle}"
                                               Style="{StaticResource MutedHintText}" Margin="14,0,0,0"/>
                                </StackPanel>
                                <ctrl:OffOnToggle x:Name="AlwaysCaptureOnStartupCheck"
                                          Content="{x:Static res:Strings.Label_AlwaysCaptureOnStartup}"
                                          Click="AlwaysCaptureOnStartup_Click"
                                          Margin="0,0,0,10"
                                          ToolTip="{x:Static res:Strings.Tooltip_AlwaysCaptureOnStartup}"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="SerialCaptureExportButton" Content="{x:Static res:Strings.Button_ExportBundle}"
                                            Click="SerialCaptureExport_Click" IsEnabled="False"/>
                                    <Button x:Name="SerialCaptureCopyButton" Content="{x:Static res:Strings.Button_CopyCapture}"
                                            Click="SerialCaptureCopy_Click"
                                            Margin="8,0,0,0" IsEnabled="False"/>
                                </StackPanel>
                            </StackPanel>
                        </ctrl:SectionCard>

                        <ctrl:SectionCard Title="{x:Static res:Strings.Section_WheelLedOutput}"
                                          Subtitle="{x:Static res:Strings.Subtitle_WheelLedOutput}"
                                          Icon="{StaticResource IconLed}">
                            <StackPanel>
                                <TextBlock TextWrapping="Wrap" Style="{StaticResource MutedHintText}" Margin="0,0,0,8"
                                           Text="{x:Static res:Strings.Hint_LedOptionsRecommendedOff}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,8">
                                    <TextBlock Text="{x:Static res:Strings.SliderLabel_LimitWheelUpdates}" Style="{StaticResource SliderLabel}"/>
                                    <ctrl:OffOnToggle x:Name="LimitWheelUpdatesCheck" VerticalAlignment="Center"
                                              Checked="LimitWheelUpdatesCheck_Changed" Unchecked="LimitWheelUpdatesCheck_Changed"/>
                                </StackPanel>
                                <TextBlock Text="{x:Static res:Strings.Hint_OnlySendLedWhenChanged}"
                                           Style="{StaticResource MutedHintText}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                <StackPanel Orientation="Horizontal" Margin="0,8">
                                    <TextBlock Text="{x:Static res:Strings.SliderLabel_AlwaysResendBitmask}" Style="{StaticResource SliderLabel}"/>
                                    <ctrl:OffOnToggle x:Name="AlwaysResendBitmaskCheck" VerticalAlignment="Center"
                                              Checked="AlwaysResendBitmaskCheck_Changed" Unchecked="AlwaysResendBitmaskCheck_Changed"/>
                                </StackPanel>
                                <TextBlock Text="{x:Static res:Strings.Hint_AlwaysResendBitmask}"
                                           Style="{StaticResource MutedHintText}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                <Grid Margin="0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{x:Static res:Strings.SliderLabel_KeepaliveTimeout}" Style="{StaticResource SliderLabel}"/>
                                    <Slider Grid.Column="1" x:Name="KeepaliveTimeoutSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="300" TickFrequency="5" SmallChange="1" LargeChange="15" IsSnapToTickEnabled="True" ValueChanged="KeepaliveTimeoutSlider_ValueChanged"/>
                                    <TextBox Grid.Column="2" x:Name="KeepaliveTimeoutValue" Style="{StaticResource SliderValueEditBox}"
                                             Tag="{Binding ElementName=KeepaliveTimeoutSlider}"
                                             KeyDown="SliderValueBox_KeyDown" LostFocus="SliderValueBox_LostFocus"
                                             Text="45 s"/>
                                </Grid>
                                <TextBlock Text="{x:Static res:Strings.Hint_KeepaliveTimeout}"
                                           Style="{StaticResource MutedHintText}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </ctrl:SectionCard>

                        <ctrl:SectionCard Title="{x:Static res:Strings.Section_UsbDetection}" Icon="{StaticResource IconRefresh}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,8">
                                    <TextBlock Text="{x:Static res:Strings.SliderLabel_DisableSerialProbe}" Style="{StaticResource SliderLabel}"/>
                                    <ctrl:OffOnToggle x:Name="DisableSerialProbeFallbackCheck" VerticalAlignment="Center"
                                              Checked="DisableSerialProbeFallbackCheck_Changed" Unchecked="DisableSerialProbeFallbackCheck_Changed"/>
                                </StackPanel>
                                <TextBlock Text="{x:Static res:Strings.Hint_DisableSerialProbe}"
                                           Style="{StaticResource MutedHintText}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                <StackPanel Orientation="Horizontal" Margin="0,8">
                                    <TextBlock Text="{x:Static res:Strings.SliderLabel_DisableAb9Detection}" Style="{StaticResource SliderLabel}"/>
                                    <ctrl:OffOnToggle x:Name="DisableAb9DetectionCheck" VerticalAlignment="Center"
                                              Checked="DisableAb9DetectionCheck_Changed" Unchecked="DisableAb9DetectionCheck_Changed"/>
                                </StackPanel>
                                <TextBlock Text="{x:Static res:Strings.Hint_DisableAb9Detection}"
                                           Style="{StaticResource MutedHintText}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </ctrl:SectionCard>

                        <ctrl:SectionCard Title="{x:Static res:Strings.Section_DashboardTelemetry}" Icon="{StaticResource IconDiag}">
                            <StackPanel>
                                <!-- Hidden: dashboard upload/download UI collapsed while the feature is
                                     in development. Runtime values are forced off in MozaPlugin; the
                                     upload/download scaffolding is intentionally preserved. -->
                                <StackPanel Visibility="Collapsed">
                                    <ctrl:OffOnToggle x:Name="UploadDashboardCheck" Content="{x:Static res:Strings.Label_UploadDashboardOnConnect}"
                                              Margin="0,8,0,4" Checked="UploadDashboard_Changed" Unchecked="UploadDashboard_Changed"/>
                                    <ctrl:OffOnToggle x:Name="DownloadDashboardCheck" Content="{x:Static res:Strings.Label_DownloadDashboardsFromWheel}"
                                              Margin="0,8,0,4" Checked="DownloadDashboard_Changed" Unchecked="DownloadDashboard_Changed"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="{x:Static res:Strings.Label_WheelFirmwareEra}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <ComboBox x:Name="FirmwareEraCombo" Width="500"
                                              SelectionChanged="FirmwareEra_Changed">
                                        <ComboBoxItem Content="{x:Static res:Strings.Option_FirmwareEraAuto}"/>
                                        <ComboBoxItem Content="{x:Static res:Strings.Option_FirmwareEra2024}"/>
                                        <ComboBoxItem Content="{x:Static res:Strings.Option_FirmwareEra2026}"/>
                                    </ComboBox>
                                </StackPanel>
                                <TextBlock TextWrapping="Wrap" Style="{StaticResource MutedHintText}" Margin="0,4,0,0"
                                           Text="{x:Static res:Strings.Hint_FirmwareEra}"/>
                            </StackPanel>
                        </ctrl:SectionCard>

                        <ctrl:SectionCard Title="{x:Static res:Strings.Section_Reset}" Icon="{StaticResource IconAlert}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,8">
                                    <Button x:Name="ClearAllSettingsButton" Content="{x:Static res:Strings.Button_ClearAllSettings}"
                                            Style="{StaticResource MozaButtonDanger}"
                                            Click="ClearAllSettingsButton_Click"/>
                                </StackPanel>
                                <TextBlock Text="{x:Static res:Strings.Hint_ClearAllSettingsWarning}"
                                           Style="{StaticResource MutedHintText}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </ctrl:SectionCard>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Upload + Wheel Files tabs were moved to the wheel device page
                 (Devices/MozaWheelSettingsControl.xaml — FilesTab). The
                 functionality is wheel-scoped, so it lives next to the rest
                 of the per-wheel settings rather than at the plugin level. -->
            <TabItem Header="{x:Static res:Strings.TabHeader_Upload}" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="22,18,22,8">
                    <StackPanel>

                        <!-- Work-in-progress banner -->
                        <Border Style="{StaticResource BannerBorder}">
                            <StackPanel>
                                <TextBlock FontSize="14" FontWeight="Bold" Foreground="{StaticResource AmberBrush}"
                                           Text="{x:Static res:Strings.Banner_NotWorkingYet}"/>
                                <TextBlock TextWrapping="Wrap" Foreground="#FFE082" FontSize="11" Margin="0,4,0,0"
                                           Text="{x:Static res:Strings.Hint_DashboardUploadNotWorking}"/>
                            </StackPanel>
                        </Border>

                        <ctrl:SectionCard Title="{x:Static res:Strings.Section_DashboardUpload}"
                                          Subtitle="{x:Static res:Strings.Subtitle_DashboardUpload}"
                                          Icon="{StaticResource IconDiag}">
                            <StackPanel>
                                <TextBlock TextWrapping="Wrap" Style="{StaticResource MutedHintText}" Margin="0,0,0,12"
                                           Text="{x:Static res:Strings.Hint_UploadStatusFormat}"/>
                                <TextBlock Text="{x:Static res:Strings.Label_Source}" Style="{StaticResource MutedHintText}" Margin="0,0,0,6"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <RadioButton x:Name="UploadSourceFileRadio" Content="{x:Static res:Strings.Option_LocalMzdashFile}"
                                                 GroupName="UploadSource" IsChecked="True"
                                                 Margin="0,0,16,0" VerticalAlignment="Center"
                                                 Foreground="{StaticResource TextBrush}"
                                                 Click="UploadSourceRadio_Click"/>
                                    <RadioButton x:Name="UploadSourceLibraryRadio" Content="{x:Static res:Strings.Option_DashboardLibrary}"
                                                 GroupName="UploadSource"
                                                 VerticalAlignment="Center"
                                                 Foreground="{StaticResource TextBrush}"
                                                 Click="UploadSourceRadio_Click"/>
                                </StackPanel>
                                <StackPanel x:Name="UploadFilePanel" Orientation="Horizontal" Margin="0,0,0,8">
                                    <Button Content="{x:Static res:Strings.Button_PickMzdash}" Margin="0,0,8,0" Click="UploadPickFile_Click"/>
                                    <TextBlock x:Name="UploadPickedFileText" VerticalAlignment="Center"
                                               Style="{StaticResource MutedHintText}"
                                               Text="{x:Static res:Strings.Status_NoFileSelected}" TextTrimming="CharacterEllipsis"
                                               MaxWidth="500"/>
                                </StackPanel>
                                <StackPanel x:Name="UploadLibraryPanel" Orientation="Horizontal" Margin="0,0,0,8"
                                            Visibility="Collapsed">
                                    <TextBlock Text="{x:Static res:Strings.Label_Dashboard}" VerticalAlignment="Center" Width="100"/>
                                    <ComboBox x:Name="UploadLibraryCombo" Width="280" Margin="0,0,8,0"
                                              SelectionChanged="UploadLibraryCombo_SelectionChanged"/>
                                    <Button Content="{x:Static res:Strings.Button_Refresh}" Click="UploadLibraryRefresh_Click"/>
                                </StackPanel>
                                <Separator Margin="0,8,0,12"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Button x:Name="UploadNowButton" Content="{x:Static res:Strings.Button_UploadNow}" MinWidth="120"
                                            Style="{StaticResource MozaButtonPrimary}"
                                            Click="UploadNow_Click"/>
                                    <TextBlock x:Name="UploadStatusText" VerticalAlignment="Center"
                                               Style="{StaticResource MutedHintText}" Margin="14,0,0,0"
                                               Text="{x:Static res:Strings.Status_Idle}"/>
                                </StackPanel>
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="220"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{x:Static res:Strings.Label_DashboardName}" Style="{StaticResource KvKeyText}" Margin="0,3"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="UploadInfoNameText" Style="{StaticResource KvValueText}" Margin="0,3" Text="—"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{x:Static res:Strings.Label_RawSize}" Style="{StaticResource KvKeyText}" Margin="0,3"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="UploadInfoRawSizeText" Style="{StaticResource KvValueText}" Margin="0,3" Text="—"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{x:Static res:Strings.Label_Md5}" Style="{StaticResource KvKeyText}" Margin="0,3"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="UploadInfoMd5Text" Style="{StaticResource KvValueText}" Margin="0,3" Text="—"/>
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="{x:Static res:Strings.Label_InFlight}" Style="{StaticResource KvKeyText}" Margin="0,3"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="UploadInfoInFlightText" Style="{StaticResource KvValueText}" Margin="0,3" Text="—"/>
                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="{x:Static res:Strings.Label_LastAckBytes}" Style="{StaticResource KvKeyText}" Margin="0,3"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" x:Name="UploadInfoProgressText" Style="{StaticResource KvValueText}" Margin="0,3" Text="—"/>
                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="{x:Static res:Strings.Label_LastAckStatus}" Style="{StaticResource KvKeyText}" Margin="0,3"/>
                                    <TextBlock Grid.Row="5" Grid.Column="1" x:Name="UploadInfoStatusByteText" Style="{StaticResource KvValueText}" Margin="0,3" Text="—"/>
                                </Grid>
                                <TextBlock TextWrapping="Wrap" Style="{StaticResource MutedHintText}" Margin="0,14,0,0"
                                           Text="{x:Static res:Strings.Hint_UploadRequiresConnection}"/>
                            </StackPanel>
                        </ctrl:SectionCard>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="{x:Static res:Strings.TabHeader_WheelFiles}" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="22,18,22,8">
                    <ctrl:SectionCard Title="{x:Static res:Strings.Section_WheelFiles}"
                                      Subtitle="{x:Static res:Strings.Subtitle_WheelFiles}"
                                      Icon="{StaticResource IconDiag}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Button x:Name="WheelFilesRefreshButton" Content="{x:Static res:Strings.Button_Refresh}"
                                        Click="WheelFilesRefresh_Click" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock x:Name="WheelFilesStatusBox" VerticalAlignment="Center"
                                           Style="{StaticResource MutedHintText}" Text="—"/>
                            </StackPanel>
                            <TextBlock TextWrapping="Wrap" Style="{StaticResource MutedHintText}" Margin="0,0,0,10"
                                       Text="{x:Static res:Strings.Hint_DeleteDisabled}"/>
                            <DataGrid x:Name="WheelFilesGrid" AutoGenerateColumns="False" IsReadOnly="True"
                                      CanUserAddRows="False" CanUserDeleteRows="False" CanUserResizeRows="False"
                                      SelectionMode="Single" HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                      BorderThickness="1" RowHeight="24">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="{x:Static res:Strings.DataGridHeader_State}" Binding="{Binding State}" Width="80"/>
                                    <DataGridTextColumn Header="{x:Static res:Strings.DataGridHeader_Title}" Binding="{Binding Title}" Width="*"/>
                                    <DataGridTextColumn Header="{x:Static res:Strings.DataGridHeader_DirName}" Binding="{Binding DirName}" Width="200"/>
                                    <DataGridTextColumn Header="{x:Static res:Strings.DataGridHeader_Hash}" Binding="{Binding HashShort}" Width="120"/>
                                    <DataGridTextColumn Header="{x:Static res:Strings.DataGridHeader_LastModified}" Binding="{Binding LastModified}" Width="170"/>
                                    <DataGridTemplateColumn Header="" Width="80">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="{x:Static res:Strings.Button_Delete}" Padding="8,2"
                                                        Click="WheelFilesDelete_Click"
                                                        Tag="{Binding}"
                                                        IsEnabled="False"
                                                        ToolTip="{x:Static res:Strings.Tooltip_DeleteDisabled}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </ctrl:SectionCard>
                </ScrollViewer>
            </TabItem>

            <TabItem x:Name="SdkTab" Header="{x:Static res:Strings.TabHeader_Sdk}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="22,18,22,8">
                    <StackPanel>

                        <ctrl:SectionCard Title="{x:Static res:Strings.Section_CoapServer}"
                                          Subtitle="{x:Static res:Strings.Subtitle_CoapServer}"
                                          Icon="{StaticResource IconBolt}">
                            <StackPanel>
                                <TextBlock TextWrapping="Wrap" Style="{StaticResource MutedHintText}" Margin="0,0,0,10"
                                           Text="{x:Static res:Strings.Hint_CoapServerEnabled}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,8">
                                    <TextBlock Text="{x:Static res:Strings.SliderLabel_EnableCoapServer}" Style="{StaticResource SliderLabel}"/>
                                    <ctrl:OffOnToggle x:Name="SdkEmulationEnabledCheck" VerticalAlignment="Center"
                                              Checked="SdkEmulationEnabledCheck_Changed" Unchecked="SdkEmulationEnabledCheck_Changed"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <TextBlock Text="{x:Static res:Strings.Label_PortNumber}" Style="{StaticResource MutedHintText}"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock x:Name="SdkCoapPortText"
                                               Text="40266"
                                               FontFamily="{StaticResource FontMono}"
                                               Foreground="{StaticResource TextDimBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock TextWrapping="Wrap" Style="{StaticResource MutedHintText}" Margin="0,12,0,0"
                                           Text="{x:Static res:Strings.Hint_CoapStubProcessName}"/>
                            </StackPanel>
                        </ctrl:SectionCard>

                        <ctrl:SectionCard Title="{x:Static res:Strings.Section_UdpControl}"
                                          Subtitle="{x:Static res:Strings.Subtitle_UdpControl}"
                                          Icon="{StaticResource IconBolt}">
                            <StackPanel>
                                <TextBlock TextWrapping="Wrap" Style="{StaticResource MutedHintText}" Margin="0,0,0,10"
                                           Text="{x:Static res:Strings.Hint_UdpControlEnabled}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,8">
                                    <TextBlock Text="{x:Static res:Strings.SliderLabel_EnableUdpControl}" Style="{StaticResource SliderLabel}"/>
                                    <ctrl:OffOnToggle x:Name="UdpControlEnabledCheck" VerticalAlignment="Center"
                                              Checked="UdpControlEnabledCheck_Changed" Unchecked="UdpControlEnabledCheck_Changed"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <TextBlock Text="{x:Static res:Strings.Label_PortNumber}" Style="{StaticResource MutedHintText}"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock x:Name="UdpControlPortText"
                                               Text="40288"
                                               FontFamily="{StaticResource FontMono}"
                                               Foreground="{StaticResource TextDimBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </ctrl:SectionCard>

                        <ctrl:SectionCard Title="{x:Static res:Strings.Section_Status}" Icon="{StaticResource IconDiag}">
                            <StackPanel>
                                <TextBlock x:Name="SdkServerStatusText"
                                           Text="{x:Static res:Strings.Option_Disabled}"
                                           FontFamily="{StaticResource FontMono}"
                                           Foreground="{StaticResource TextDimBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,8"/>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <Button x:Name="SdkRefreshStatusButton" Content="{x:Static res:Strings.Button_Refresh}"
                                            Click="SdkRefreshStatusButton_Click" MinWidth="100"/>
                                </StackPanel>
                            </StackPanel>
                        </ctrl:SectionCard>

                        <ctrl:SectionCard Title="{x:Static res:Strings.Section_RecentRequests}"
                                          Subtitle="{x:Static res:Strings.Subtitle_RecentRequests}"
                                          Icon="{StaticResource IconDiag}">
                            <StackPanel>
                                <TextBlock Text="{x:Static res:Strings.Label_CoapServer}"
                                           Style="{StaticResource MutedHintText}"
                                           Margin="0,0,0,4"/>
                                <ListBox x:Name="SdkRecentRequestsList"
                                         FontFamily="{StaticResource FontMono}" FontSize="11"
                                         Background="{StaticResource BgDeepBrush}"
                                         Foreground="{StaticResource TextDimBrush}"
                                         BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                         Height="180"
                                         HorizontalContentAlignment="Stretch"/>
                                <TextBlock Text="{x:Static res:Strings.Label_UdpControlServer}"
                                           Style="{StaticResource MutedHintText}"
                                           Margin="0,12,0,4"/>
                                <ListBox x:Name="ControlUdpRecentRequestsList"
                                         FontFamily="{StaticResource FontMono}" FontSize="11"
                                         Background="{StaticResource BgDeepBrush}"
                                         Foreground="{StaticResource TextDimBrush}"
                                         BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                         Height="120"
                                         HorizontalContentAlignment="Stretch"/>
                            </StackPanel>
                        </ctrl:SectionCard>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ==================== IMPORT TAB ==================== -->
            <!-- Content is the PitHouseImportControl, instantiated in code-behind
                 and assigned to ImportTab.Content. Done in code rather than as a
                 named XAML element because a generated typed field of
                 MozaPlugin.UI.Import.* collides with the MozaPlugin class name. -->
            <TabItem x:Name="ImportTab" Header="{x:Static res:Strings.TabHeader_Import}"/>

            <TabItem x:Name="AboutTab" Header="{x:Static res:Strings.TabHeader_About}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="22,18,22,8">
                    <StackPanel>

                        <!-- ============ About / Project links ============ -->
                        <ctrl:SectionCard Title="{x:Static res:Strings.Section_About}"
                                          Subtitle="{x:Static res:Strings.Subtitle_About}"
                                          Icon="{StaticResource IconShield}">
                            <StackPanel>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{x:Static res:Strings.Label_AzomTitle}"
                                                   FontFamily="{StaticResource FontUi}"
                                                   FontSize="22" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextBrush}"/>
                                        <TextBlock x:Name="AboutVersionText"
                                                   Text="{x:Static res:Strings.Label_VersionPlaceholder}"
                                                   FontFamily="{StaticResource FontMono}"
                                                   FontSize="13"
                                                   Foreground="{StaticResource CyanBrush}"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock TextWrapping="Wrap"
                                           Style="{StaticResource MutedHintText}"
                                           Margin="0,0,0,16"
                                           Text="{x:Static res:Strings.Hint_AboutDescription}"/>
                                <TextBlock TextWrapping="Wrap"
                                           Style="{StaticResource MutedHintText}"
                                           FontStyle="Italic"
                                           Foreground="{StaticResource TextDimBrush}"
                                           Margin="0,0,0,16"
                                           Text="{x:Static res:Strings.Hint_ThanksToTesters}"/>
                                <TextBlock TextWrapping="Wrap"
                                           Style="{StaticResource MutedHintText}"
                                           Margin="0,0,0,12"
                                           Text="{x:Static res:Strings.Hint_SponsorshipsAppreciated}"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="{x:Static res:Strings.Button_Github}"
                                            Click="AboutGitHubButton_Click"
                                            Margin="0,0,8,0"
                                            ToolTip="{x:Static res:Strings.Tooltip_Github}"/>
                                    <Button Content="{x:Static res:Strings.Button_JoinDiscord}"
                                            Click="AboutDiscordButton_Click"
                                            Margin="0,0,8,0"
                                            ToolTip="{x:Static res:Strings.Tooltip_JoinDiscord}"/>
                                    <Button Content="{x:Static res:Strings.Button_SponsorDevelopment}"
                                            Click="AboutSponsorButton_Click"
                                            Foreground="{StaticResource GreenBrush}"
                                            BorderBrush="#6639FF88"
                                            Margin="0,0,8,0"
                                            ToolTip="{x:Static res:Strings.Tooltip_Sponsor}"/>
                                    <Button Content="{x:Static res:Strings.Button_Kofi}"
                                            Click="AboutKofiButton_Click"
                                            ToolTip="{x:Static res:Strings.Tooltip_Kofi}"/>
                                </StackPanel>
                            </StackPanel>
                        </ctrl:SectionCard>

                        <!-- ============ Updates ============
                             Owned by the SettingsControl.UpdateBanner.cs partial.
                             Banner is collapsed by default; only paints when a
                             newer release is detected. The settings row below it
                             (enable toggle, channel, "check now") is always
                             visible so users can opt out / pick stable vs dev. -->
                        <ctrl:SectionCard x:Name="UpdatesSection"
                                          Title="{x:Static res:Strings.Section_Updates}"
                                          Subtitle="{x:Static res:Strings.Subtitle_Updates}"
                                          Icon="{StaticResource IconRefresh}">
                            <StackPanel>
                                <Border x:Name="UpdateBannerBorder"
                                        Visibility="Collapsed"
                                        BorderBrush="{StaticResource CyanBrush}"
                                        BorderThickness="1"
                                        Background="{StaticResource BgDeepBrush}"
                                        Padding="12,10"
                                        Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock x:Name="UpdateBannerText"
                                                   FontFamily="{StaticResource FontUi}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource CyanBrush}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,8"/>
                                        <TextBlock x:Name="UpdateBannerProgressText"
                                                   Style="{StaticResource MutedHintText}"
                                                   TextWrapping="Wrap"
                                                   Visibility="Collapsed"
                                                   Margin="0,0,0,8"/>
                                        <StackPanel Orientation="Horizontal">
                                            <Button x:Name="UpdateBannerInstallButton"
                                                    Content="{x:Static res:Strings.Button_InstallUpdate}"
                                                    Click="UpdateBanner_Install_Click"
                                                    Margin="0,0,8,0"/>
                                            <Button x:Name="UpdateBannerRestartButton"
                                                    Content="{x:Static res:Strings.Button_RestartSimHub}"
                                                    Click="UpdateBanner_Restart_Click"
                                                    Visibility="Collapsed"
                                                    Margin="0,0,8,0"/>
                                            <Button x:Name="UpdateBannerOpenButton"
                                                    Content="{x:Static res:Strings.Button_OpenReleaseNotes}"
                                                    Click="UpdateBanner_OpenNotes_Click"
                                                    Margin="0,0,8,0"/>
                                            <Button x:Name="UpdateBannerSkipButton"
                                                    Content="{x:Static res:Strings.Button_SkipThisVersion}"
                                                    Click="UpdateBanner_Skip_Click"
                                                    Margin="0,0,8,0"/>
                                            <Button x:Name="UpdateBannerDismissButton"
                                                    Content="{x:Static res:Strings.Button_DismissUpdate}"
                                                    Click="UpdateBanner_Dismiss_Click"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Release notes for the latest available version
                                     (GitHub release body, rendered as selectable
                                     plain text). Shown only when notes are cached
                                     and an update is available / pending restart. -->
                                <StackPanel x:Name="UpdateReleaseNotesPanel"
                                            Visibility="Collapsed"
                                            Margin="0,0,0,14">
                                    <TextBlock x:Name="UpdateReleaseNotesHeader"
                                               Style="{StaticResource SectionTitleText}"
                                               Margin="0,0,0,6"/>
                                    <Border BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            Background="{StaticResource BgDeepBrush}"
                                            CornerRadius="4" Padding="2">
                                        <RichTextBox x:Name="UpdateReleaseNotesBox"
                                                     IsReadOnly="True"
                                                     IsDocumentEnabled="True"
                                                     Background="Transparent"
                                                     BorderThickness="0"
                                                     Foreground="{StaticResource TextDimBrush}"
                                                     FontFamily="{StaticResource FontUi}"
                                                     FontSize="12"
                                                     Padding="8"
                                                     MaxHeight="220"
                                                     VerticalScrollBarVisibility="Auto"/>
                                    </Border>
                                </StackPanel>

                                <ctrl:OffOnToggle x:Name="UpdateCheckEnabledToggle"
                                          Content="{x:Static res:Strings.Label_CheckForUpdates}"
                                          Click="UpdateCheckEnabled_Click"
                                          Margin="0,0,0,10"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Static res:Strings.Label_ReleaseChannel}"
                                               Style="{StaticResource MutedHintText}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,10,0"/>
                                    <ComboBox x:Name="UpdateChannelCombo"
                                              MinWidth="160"
                                              SelectionChanged="UpdateChannelCombo_SelectionChanged">
                                        <ComboBoxItem Content="{x:Static res:Strings.Option_ReleaseChannelStable}"/>
                                        <ComboBoxItem Content="{x:Static res:Strings.Option_ReleaseChannelDev}"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button x:Name="UpdateCheckNowButton"
                                            Content="{x:Static res:Strings.Button_CheckNow}"
                                            Click="UpdateCheckNow_Click"
                                            Margin="0,0,12,0"/>
                                    <TextBlock x:Name="UpdateLastCheckedText"
                                               Style="{StaticResource MutedHintText}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </ctrl:SectionCard>

                        <!-- Bandwidth visualization was moved to the Base tab's live header
                             (next to the temperature graph) as a single dual-line sparkline. -->

                        <!-- Serial Traffic Capture moved to the Options tab. -->

                        <!-- ============ Full Diagnostic Report (expandable) ============ -->
                        <ctrl:SectionCard Title="{x:Static res:Strings.Section_FullDiagReport}"
                                          Subtitle="{x:Static res:Strings.Subtitle_FullDiagReport}"
                                          Icon="{StaticResource IconDiag}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Button x:Name="FullDiagToggleButton" Content="{x:Static res:Strings.Button_Expand}"
                                            Click="FullDiagToggle_Click" Margin="0,0,8,0"/>
                                    <Button Content="{x:Static res:Strings.Button_CopyAll}" Click="DiagCopyAll_Click"
                                            Margin="0,0,8,0"/>
                                    <TextBlock x:Name="FullDiagSummaryText"
                                               Style="{StaticResource MutedHintText}"
                                               VerticalAlignment="Center"
                                               Text="{x:Static res:Strings.Hint_ClickExpandToRender}"/>
                                </StackPanel>
                                <TextBox x:Name="FullDiagReportBox"
                                         FontFamily="{StaticResource FontMono}" FontSize="11"
                                         Foreground="{StaticResource TextDimBrush}"
                                         Background="{StaticResource BgDeepBrush}"
                                         BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                         IsReadOnly="True" TextWrapping="NoWrap"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto"
                                         MaxHeight="400" Padding="10"
                                         Visibility="Collapsed"/>
                            </StackPanel>
                        </ctrl:SectionCard>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </DockPanel>
</UserControl>
