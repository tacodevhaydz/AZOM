                                                        </Grid>
                                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,8">
                                                            <ctrl:OffOnToggle Content="{x:Static res:Strings.Label_Enable}" IsChecked="{Binding Enabled}" VerticalAlignment="Center"/>
