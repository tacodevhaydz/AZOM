                                           VerticalAlignment="Center" Margin="0,0,18,0"/>
                                <TextBlock x:Name="Ab9StatusLabel" Text="{x:Static res:Strings.Status_SearchingForAb9}"
                                           Style="{StaticResource MutedHintText}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <ctrl:SectionCard Title="{x:Static res:Strings.Section_Ab9InputMode}" Icon="{StaticResource IconShift}">
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{x:Static res:Strings.SliderLabel_Mode}" Style="{StaticResource SliderLabel}"/>
                                <ComboBox Grid.Column="1" x:Name="Ab9InputModeCombo" Width="220" SelectionChanged="Ab9InputModeCombo_Changed">
                                    <ComboBoxItem Content="{x:Static res:Strings.Option_Ab9Shifter}" Tag="1"/>
                                    <ComboBoxItem Content="{x:Static res:Strings.Option_Ab9FlightSim}" Tag="0"/>
                                </ComboBox>
                            </Grid>
                        </ctrl:SectionCard>

                        <ctrl:SectionCard Title="{x:Static res:Strings.Section_MechanicalLayout}" Icon="{StaticResource IconShift}">
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{x:Static res:Strings.SliderLabel_Mode}" Style="{StaticResource SliderLabel}"/>
                                <ComboBox Grid.Column="1" x:Name="Ab9ModeCombo" Width="220" SelectionChanged="Ab9ModeCombo_Changed">
                                    <ComboBoxItem Content="{x:Static res:Strings.Option_Ab9Layout5R1}" Tag="0"/>
                                    <ComboBoxItem Content="{x:Static res:Strings.Option_Ab9Layout6R1}" Tag="4"/>
                                    <ComboBoxItem Content="{x:Static res:Strings.Option_Ab9Layout6R2}" Tag="5"/>
                                    <ComboBoxItem Content="{x:Static res:Strings.Option_Ab9Layout7R1}" Tag="6"/>
                                    <ComboBoxItem Content="{x:Static res:Strings.Option_Ab9Layout7R2}" Tag="7"/>
                                    <ComboBoxItem Content="{x:Static res:Strings.Option_Sequential}"   Tag="9"/>
                                </ComboBox>
                            </Grid>
                        </ctrl:SectionCard>

                        <ctrl:SectionCard Title="{x:Static res:Strings.Section_Feel}"
                                          Subtitle="{x:Static res:Strings.Subtitle_PerAxisMechanicalCharacter}"
                                          Icon="{StaticResource IconDamper}">
                            <StackPanel>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{x:Static res:Strings.SliderLabel_MechanicalResistance}" Style="{StaticResource SliderLabel}"/>
                                    <Slider Grid.Column="1" x:Name="Ab9MechResistanceSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="Ab9MechResistanceSlider_ValueChanged"/>
                                    <TextBox Grid.Column="2" x:Name="Ab9MechResistanceValue" Style="{StaticResource SliderValueEditBox}"
                                                 Tag="{Binding ElementName=Ab9MechResistanceSlider}"
                                                 KeyDown="SliderValueBox_KeyDown" LostFocus="SliderValueBox_LostFocus"
                                                 Text="50"/>
                                </Grid>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{x:Static res:Strings.SliderLabel_Spring}" Style="{StaticResource SliderLabel}"/>
                                    <Slider Grid.Column="1" x:Name="Ab9SpringSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="Ab9SpringSlider_ValueChanged"/>
                                    <TextBox Grid.Column="2" x:Name="Ab9SpringValue" Style="{StaticResource SliderValueEditBox}"
                                                 Tag="{Binding ElementName=Ab9SpringSlider}"
                                                 KeyDown="SliderValueBox_KeyDown" LostFocus="SliderValueBox_LostFocus"
                                                 Text="50"/>
                                </Grid>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{x:Static res:Strings.SliderLabel_NaturalDamping}" Style="{StaticResource SliderLabel}"/>
                                    <Slider Grid.Column="1" x:Name="Ab9DampingSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="Ab9DampingSlider_ValueChanged"/>
                                    <TextBox Grid.Column="2" x:Name="Ab9DampingValue" Style="{StaticResource SliderValueEditBox}"
                                                 Tag="{Binding ElementName=Ab9DampingSlider}"
                                                 KeyDown="SliderValueBox_KeyDown" LostFocus="SliderValueBox_LostFocus"
                                                 Text="50"/>
                                </Grid>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{x:Static res:Strings.SliderLabel_NaturalFriction}" Style="{StaticResource SliderLabel}"/>
                                    <Slider Grid.Column="1" x:Name="Ab9FrictionSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="Ab9FrictionSlider_ValueChanged"/>
                                    <TextBox Grid.Column="2" x:Name="Ab9FrictionValue" Style="{StaticResource SliderValueEditBox}"
                                                 Tag="{Binding ElementName=Ab9FrictionSlider}"
                                                 KeyDown="SliderValueBox_KeyDown" LostFocus="SliderValueBox_LostFocus"
                                                 Text="50"/>
                                </Grid>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{x:Static res:Strings.SliderLabel_MaxOutputTorqueLimit}" Style="{StaticResource SliderLabel}"/>
                                    <Slider Grid.Column="1" x:Name="Ab9MaxTorqueSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="Ab9MaxTorqueSlider_ValueChanged"/>
                                    <TextBox Grid.Column="2" x:Name="Ab9MaxTorqueValue" Style="{StaticResource SliderValueEditBox}"
                                                 Tag="{Binding ElementName=Ab9MaxTorqueSlider}"
                                                 KeyDown="SliderValueBox_KeyDown" LostFocus="SliderValueBox_LostFocus"
                                                 Text="50"/>
                                </Grid>
                            </StackPanel>
                        </ctrl:SectionCard>

                        <ctrl:SectionCard Title="{x:Static res:Strings.Section_EngineVibration}"
                                          Subtitle="{x:Static res:Strings.Subtitle_HostRenderedRumble}"
                                          Icon="{StaticResource IconBolt}">
                            <StackPanel>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{x:Static res:Strings.SliderLabel_Intensity}" Style="{StaticResource SliderLabel}"/>
                                    <Slider Grid.Column="1" x:Name="Ab9EngineVibIntensitySlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="Ab9EngineVibIntensitySlider_ValueChanged"/>
                                    <TextBox Grid.Column="2" x:Name="Ab9EngineVibIntensityValue" Style="{StaticResource SliderValueEditBox}"
                                                 Tag="{Binding ElementName=Ab9EngineVibIntensitySlider}"
                                                 KeyDown="SliderValueBox_KeyDown" LostFocus="SliderValueBox_LostFocus"
                                                 Text="0"/>
                                </Grid>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{x:Static res:Strings.SliderLabel_Frequency}" Style="{StaticResource SliderLabel}"/>
                                    <Slider Grid.Column="1" x:Name="Ab9EngineVibFreqSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="200" TickFrequency="10" ValueChanged="Ab9EngineVibFreqSlider_ValueChanged"/>
                                    <TextBox Grid.Column="2" x:Name="Ab9EngineVibFreqValue" Style="{StaticResource SliderValueEditBox}"
                                                 Tag="{Binding ElementName=Ab9EngineVibFreqSlider}"
                                                 KeyDown="SliderValueBox_KeyDown" LostFocus="SliderValueBox_LostFocus"
                                                 Text="100 Hz"/>
                                </Grid>
                            </StackPanel>
                        </ctrl:SectionCard>

                        <ctrl:SectionCard Title="{x:Static res:Strings.Section_GearShift}" Icon="{StaticResource IconShift}">
                            <StackPanel>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{x:Static res:Strings.SliderLabel_VibrationIntensity}" Style="{StaticResource SliderLabel}"/>
                                    <Slider Grid.Column="1" x:Name="Ab9GearShiftVibSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="Ab9GearShiftVibSlider_ValueChanged"/>
                                    <TextBox Grid.Column="2" x:Name="Ab9GearShiftVibValue" Style="{StaticResource SliderValueEditBox}"
                                                     Tag="{Binding ElementName=Ab9GearShiftVibSlider}"
                                                     KeyDown="SliderValueBox_KeyDown" LostFocus="SliderValueBox_LostFocus"
                                                     Text="0"/>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="{x:Static res:Strings.SliderLabel_VibrateOnNeutral}" Style="{StaticResource SliderLabel}"/>
                                    <ctrl:OffOnToggle x:Name="Ab9GearShiftVibrateOnNeutralCheck" VerticalAlignment="Center"
                                                      Checked="Ab9GearShiftVibrateOnNeutralCheck_Changed" Unchecked="Ab9GearShiftVibrateOnNeutralCheck_Changed"/>
                                </StackPanel>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{x:Static res:Strings.SliderLabel_ShiftDebounce}" Style="{StaticResource SliderLabel}"/>
                                    <Slider Grid.Column="1" x:Name="Ab9GearShiftDebounceSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="1000" TickFrequency="50" SmallChange="50" LargeChange="50" IsSnapToTickEnabled="True" ValueChanged="Ab9GearShiftDebounceSlider_ValueChanged"/>
                                    <TextBox Grid.Column="2" x:Name="Ab9GearShiftDebounceValue" Style="{StaticResource SliderValueEditBox}"
                                                     Tag="{Binding ElementName=Ab9GearShiftDebounceSlider}"
                                                     KeyDown="SliderValueBox_KeyDown" LostFocus="SliderValueBox_LostFocus"
                                                     Text="500 ms"/>
                                </Grid>
                            </StackPanel>
                        </ctrl:SectionCard>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ==================== SHIFTER TAB (HGP / SGP) ==================== -->
            <TabItem x:Name="ShifterTab" Header="{x:Static res:Strings.TabHeader_Shifter}" Visibility="Collapsed">
                <TabItem.Resources>
                    <StaticResource x:Key="ToggleOnBrush" ResourceKey="RedToggleOnBrush"/>
                    <SolidColorBrush x:Key="ToggleOnTextBrush" Color="{StaticResource RedColor}"/>
                </TabItem.Resources>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                    <StackPanel Margin="5">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Shifter settings (both HGP + SGP) -->
                            <ctrl:SectionCard Grid.Column="0" Title="{x:Static res:Strings.Section_ShifterSettings}"
                                              Icon="{StaticResource IconShift}"
                                              AccentBrush="{StaticResource RedBrush}" Margin="0,0,7,14">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,8">
                                        <TextBlock Text="{x:Static res:Strings.SliderLabel_ReverseDirection}" Style="{StaticResource SliderLabel}"/>
                                        <ctrl:OffOnToggle x:Name="ShifterDirectionCheck" VerticalAlignment="Center" Click="ShifterDirectionCheck_Click"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,8">
                                        <TextBlock Text="{x:Static res:Strings.SliderLabel_ShifterPaddleSync}" Style="{StaticResource SliderLabel}"/>
                                        <ctrl:OffOnToggle x:Name="ShifterPaddleSyncCheck" VerticalAlignment="Center" Click="ShifterPaddleSyncCheck_Click"/>
                                    </StackPanel>
                                </StackPanel>
                            </ctrl:SectionCard>

                            <!-- Calibration (HGP H-pattern only) -->
                            <ctrl:SectionCard Grid.Column="1" x:Name="ShifterCalCard" Title="{x:Static res:Strings.Section_Calibration}"
                                              Subtitle="{x:Static res:Strings.Subtitle_ShifterCalibrate}"
                                              Icon="{StaticResource IconCal}"
                                              AccentBrush="{StaticResource RedBrush}" Margin="7,0,0,14">
                                <StackPanel Margin="0,4">
                                    <Button x:Name="ShifterCalStartButton" Content="{x:Static res:Strings.Button_StartCalibration}" HorizontalAlignment="Left" Click="ShifterCalStartButton_Click"/>
                                    <TextBlock x:Name="ShifterCalStatus" Style="{StaticResource MutedHintText}" TextWrapping="Wrap" Margin="0,6,0,0" Visibility="Collapsed"/>
                                </StackPanel>
                            </ctrl:SectionCard>
                        </Grid>

                        <!-- LEDs (SGP sequential only — 2 configurable LEDs) -->
                        <ctrl:SectionCard x:Name="ShifterLedCard" Title="{x:Static res:Strings.Section_ShifterLeds}"
                                          Subtitle="{x:Static res:Strings.Subtitle_ShifterLeds}"
                                          Icon="{StaticResource IconLed}"
                                          AccentBrush="{StaticResource RedBrush}" Margin="0,0,0,14" Visibility="Collapsed">
                            <StackPanel>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{x:Static res:Strings.Label_ShifterLed1}" Style="{StaticResource SliderLabel}"/>
                                    <ComboBox Grid.Column="1" x:Name="ShifterLed1Combo" HorizontalAlignment="Left" Width="170" SelectionChanged="ShifterLed1Combo_Changed"/>
                                </Grid>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{x:Static res:Strings.Label_ShifterLed2}" Style="{StaticResource SliderLabel}"/>
                                    <ComboBox Grid.Column="1" x:Name="ShifterLed2Combo" HorizontalAlignment="Left" Width="170" SelectionChanged="ShifterLed2Combo_Changed"/>
                                </Grid>
                                <Grid Margin="0,8,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{x:Static res:Strings.SliderLabel_ShifterBrightness}" Style="{StaticResource SliderLabel}"/>
                                    <Slider Grid.Column="1" x:Name="ShifterBrightnessSlider" Minimum="0" Maximum="10"
                                            TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"
                                            ValueChanged="ShifterBrightnessSlider_ValueChanged"/>
                                    <TextBlock Grid.Column="2" x:Name="ShifterBrightnessValue" MinWidth="24"
                                               TextAlignment="Right" VerticalAlignment="Center" Text="10"/>
                                </Grid>
                            </StackPanel>
                        </ctrl:SectionCard>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ==================== mBOOSTER TAB ==================== -->
            <TabItem x:Name="MBoosterTab" Header="{x:Static res:Strings.TabHeader_MBooster}" Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Pinned pedal trace — shows every connected pedal's live
                         position (Brake/Throttle/Clutch), independent of device
                         selection, so it stays visible while the rest of the
                         tab scrolls underneath it. -->
                    <ctrl:SectionCard Grid.Row="0" Title="{x:Static res:Strings.Section_MBoosterPedals}"
                                      Subtitle="{x:Static res:Strings.Subtitle_MBoosterPedals}"
                                      Icon="{StaticResource IconPedals}" Margin="22,18,22,0">
                        <StackPanel>
                            <ctrl:BandwidthSparkline x:Name="MBoosterPedalTraceViz" Height="70"
                                                      InBrush="{StaticResource RedBrush}"
                                                      InFillBrush="{StaticResource McuFillBrush}"
                                                      OutBrush="{StaticResource GreenBrush}"
                                                      OutFillBrush="{StaticResource MotorFillBrush}"
                                                      ThirdBrush="{StaticResource BlueBrush}"
                                                      ThirdFillBrush="{StaticResource BwThirdFillBrush}"
                                                      MaxValue="100"
                                                      ShowGridlines="True"/>

                            <TextBlock TextWrapping="Wrap" Style="{StaticResource MutedHintText}" Margin="0,12,0,12" Text="{x:Static res:Strings.Hint_MBoosterIntro}"/>

                            <!-- One row per connected PEDAL (HID axis) — a chained mBooster
                                 hosting several pedals on one connection gets one row per axis,
                                 not one row for the whole connection. The label is a plain
                                 clickable Button (see MBoosterDeviceRowButtonStyle); clicking a
                                 row selects BOTH the physical device AND that specific pedal for
                                 the Pedal Feel/Sim Input/Effects/Calibration cards below,
                                 replacing the old trio of Device combo + per-axis Pedal Roles
                                 panel + Configure-pedal combo. Each row's own Role combo edits
                                 THAT pedal's Role regardless of which row is selected, with
                                 cross-row uniqueness enforced in code (assigning a role clears it
                                 off whichever other pedal previously held it). No per-device
                                 DisplayName editor here (not required) — the row label still
                                 reflects any DisplayName already set via BuildMBoosterComboLabel. -->
                            <ItemsControl x:Name="MBoosterDeviceRowsList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="160"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="160"/>
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" Style="{StaticResource MBoosterDeviceRowButtonStyle}"
                                                    Content="{Binding Label}" HorizontalAlignment="Left"
                                                    Click="MBoosterDeviceRow_Click"/>
                                            <TextBlock Grid.Column="1" Text="{x:Static res:Strings.SliderLabel_Role}" Style="{StaticResource LabelText}"
                                                       VerticalAlignment="Center" Margin="16,0,10,0"/>
                                            <ComboBox Grid.Column="2" SelectedIndex="{Binding RoleIndex, Mode=TwoWay}">
                                                <ComboBoxItem Content="{x:Static res:Strings.Option_Disabled}"/>
                                                <ComboBoxItem Content="{x:Static res:Strings.Option_Throttle}"/>
                                                <ComboBoxItem Content="{x:Static res:Strings.Option_Brake}"/>
                                                <ComboBoxItem Content="{x:Static res:Strings.Option_Clutch}"/>
                                            </ComboBox>
                                            <!-- Only shown for the selected row — editing a non-selected
                                                 device's name isn't useful since its config isn't on
                                                 screen anyway, and it declutters the common case. -->
                                            <TextBlock Grid.Column="3" Text="{x:Static res:Strings.SliderLabel_DisplayName}" Style="{StaticResource LabelText}"
                                                       VerticalAlignment="Center" Margin="16,0,10,0"
                                                       Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibility}}"/>
                                            <TextBox Grid.Column="4" Style="{StaticResource LfeNameBox}" MaxLength="40"
                                                     Text="{Binding DisplayName, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                     ToolTip="{x:Static res:Strings.Hint_MBoosterDisplayName}"
                                                     Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibility}}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ctrl:SectionCard>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="22,18,22,8">
                    <StackPanel>

                        <!-- Per-device panel: wraps Pedal Feel + Sim Input Mapping + Effects + Calibration into nested cards -->
                        <StackPanel x:Name="MBoosterDevicePanel" Visibility="Collapsed">

                            <ctrl:SectionCard Title="{x:Static res:Strings.Section_PedalFeelSimInput}"
                                              Icon="{StaticResource IconCurve}"
                                              IsCollapsible="True">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Left half: Pedal Feel -->
                                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                        <TextBlock Text="{x:Static res:Strings.Section_PedalFeel}" Style="{StaticResource SectionTitleText}" Margin="0,0,0,12"/>
                                        <ctrl:MozaCurveEditor x:Name="MBoosterInputCurveEditor" Height="220"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,12,0,20">
                                            <Button Content="{x:Static res:Strings.Button_Linear}" Margin="0,0,8,0" Click="MBoosterInputCurvePreset_Linear"/>
                                            <Button Content="{x:Static res:Strings.Button_SCurve}" Margin="0,0,8,0" Click="MBoosterInputCurvePreset_SCurve"/>
                                            <Button Content="{x:Static res:Strings.Button_Exponential}" Margin="0,0,8,0" Click="MBoosterInputCurvePreset_Exponential"/>
                                            <Button Content="{x:Static res:Strings.Button_Parabolic}" Click="MBoosterInputCurvePreset_Parabolic"/>
                                        </StackPanel>

                                        <TextBlock Text="{x:Static res:Strings.SliderLabel_TravelRangeMm}" Style="{StaticResource SliderLabel}" HorizontalAlignment="Left" Margin="0,0,0,6"/>
                                        <ctrl:MozaRangeSlider x:Name="MBoosterTravelRangeSlider" Height="90" Margin="0,0,0,16"
                                                              AccentBrush="{StaticResource CyanBrush}"
                                                              Minimum="3.8" Maximum="49.7" MinGap="3.8" MaxGap="32.1"
                                                              Unit="mm" Decimals="1"
                                                              LowValue="3.8" HighValue="35.9"
                                                              RangeChanged="MBoosterTravelRangeSlider_RangeChanged"/>

                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{x:Static res:Strings.SliderLabel_EndstopFrontStiffness}" Style="{StaticResource SliderLabel}"/>
                                            <Slider Grid.Column="1" x:Name="MBoosterEndstopFrontSlider" Style="{StaticResource SettingSlider}" Minimum="1" Maximum="10" TickFrequency="1" ValueChanged="MBoosterEndstopFrontSlider_ValueChanged"/>
                                            <TextBox Grid.Column="2" x:Name="MBoosterEndstopFrontValue" Style="{StaticResource SliderValueEditBox}"
                                                     Tag="{Binding ElementName=MBoosterEndstopFrontSlider}"
                                                     KeyDown="SliderValueBox_KeyDown" LostFocus="SliderValueBox_LostFocus"
                                                     Text="1"/>
                                        </Grid>
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{x:Static res:Strings.SliderLabel_EndstopEndStiffness}" Style="{StaticResource SliderLabel}"/>
                                            <Slider Grid.Column="1" x:Name="MBoosterEndstopEndSlider" Style="{StaticResource SettingSlider}" Minimum="1" Maximum="10" TickFrequency="1" ValueChanged="MBoosterEndstopEndSlider_ValueChanged"/>
                                            <TextBox Grid.Column="2" x:Name="MBoosterEndstopEndValue" Style="{StaticResource SliderValueEditBox}"
                                                     Tag="{Binding ElementName=MBoosterEndstopEndSlider}"
                                                     KeyDown="SliderValueBox_KeyDown" LostFocus="SliderValueBox_LostFocus"
                                                     Text="1"/>
                                        </Grid>
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{x:Static res:Strings.SliderLabel_DeadzoneKg}" Style="{StaticResource SliderLabel}"/>
                                            <TextBlock Grid.Column="1" Text="0" Style="{StaticResource SliderRangeEndLabel}" Margin="0,0,6,0"/>
                                            <Slider Grid.Column="2" x:Name="MBoosterDeadzoneSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="40" TickFrequency="0.1" ValueChanged="MBoosterDeadzoneSlider_ValueChanged"/>
                                            <TextBlock Grid.Column="3" Text="40" Style="{StaticResource SliderRangeEndLabel}" Margin="6,0,0,0"/>
                                            <TextBox Grid.Column="4" x:Name="MBoosterDeadzoneValue" Style="{StaticResource SliderValueEditBox}"
                                                     Tag="{Binding ElementName=MBoosterDeadzoneSlider}"
                                                     KeyDown="SliderValueBox_KeyDown" LostFocus="SliderValueBox_LostFocus"
                                                     Text="0.0"/>
                                        </Grid>
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{x:Static res:Strings.SliderLabel_MaxForceKg}" Style="{StaticResource SliderLabel}"/>
                                            <TextBlock Grid.Column="1" Text="0" Style="{StaticResource SliderRangeEndLabel}" Margin="0,0,6,0"/>
                                            <Slider Grid.Column="2" x:Name="MBoosterMaxForceSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="200" TickFrequency="1" ValueChanged="MBoosterMaxForceSlider_ValueChanged"/>
                                            <TextBlock Grid.Column="3" Text="200" Style="{StaticResource SliderRangeEndLabel}" Margin="6,0,0,0"/>
                                            <TextBox Grid.Column="4" x:Name="MBoosterMaxForceValue" Style="{StaticResource SliderValueEditBox}"
                                                     Tag="{Binding ElementName=MBoosterMaxForceSlider}"
                                                     KeyDown="SliderValueBox_KeyDown" LostFocus="SliderValueBox_LostFocus"
                                                     Text="200"/>
                                        </Grid>
                                        <!-- Data-store sliders, driven by MBoosterInputCurveEditor -->
                                        <StackPanel Visibility="Collapsed">
