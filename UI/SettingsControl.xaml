<UserControl x:Class="MozaPlugin.SettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:profilescommon="clr-namespace:SimHub.Plugins.ProfilesCommon;assembly=SimHub.Plugins"
             xmlns:ctrl="clr-namespace:MozaControls"
             xmlns:ui="clr-namespace:MozaPlugin.UI"
             Padding="0"
             Background="{DynamicResource BgPanelBrush}"
             TextElement.Foreground="{DynamicResource TextBrush}"
             TextElement.FontFamily="{DynamicResource FontUi}"
             TextElement.FontSize="13">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MozaPlugin;component/Themes/MozaTheme.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/MozaPlugin;component/Themes/MozaIcons.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Legacy keys preserved so the hidden Wheel/AB9/mBooster/Hub tabs (kept in
                 the visual tree but Visibility=Collapsed in Phase 1) still resolve.
                 They route to the new design's brushes + typography so any pixels they
                 do emit blend in. Phase 2 deletes these along with the stub tabs. -->
            <Style x:Key="SectionHeader" TargetType="TextBlock" BasedOn="{StaticResource SectionTitleText}">
                <Setter Property="Margin" Value="0,20,0,8"/>
                <Setter Property="FontSize" Value="14"/>
            </Style>
            <Style x:Key="SliderLabel" TargetType="TextBlock" BasedOn="{StaticResource LabelText}">
                <Setter Property="Width" Value="180"/>
            </Style>
            <Style x:Key="SliderValue" TargetType="TextBlock">
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Width" Value="60"/>
                <Setter Property="TextAlignment" Value="Right"/>
                <Setter Property="Margin" Value="8,0,0,0"/>
                <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
                <Setter Property="Foreground" Value="{StaticResource CyanBrush}"/>
            </Style>
            <!-- Editable slider value: looks like the read-only SliderValue text
                 while idle, reveals editable chrome on hover/focus. KeyDown +
                 LostFocus handlers in code-behind parse the typed value and
                 push it back to the paired Slider via Tag (which is bound to
                 the slider with ElementName). GotFocus strips the unit suffix
                 (e.g. "100%" → "100") and selects the digits so the user can
                 only edit the numeric portion. -->
            <Style x:Key="SliderValueEditBox" TargetType="TextBox">
                <EventSetter Event="GotFocus" Handler="SliderValueBox_GotFocus"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <!-- Wide enough for the longest canonical value in any box —
                     "120 kph" (Trigger Speed) at FontMono 14pt is the tightest fit. -->
                <Setter Property="Width" Value="78"/>
                <Setter Property="Height" Value="26"/>
                <Setter Property="Padding" Value="6,2"/>
                <Setter Property="Margin" Value="8,0,0,0"/>
                <Setter Property="TextAlignment" Value="Right"/>
                <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Foreground" Value="{StaticResource CyanBrush}"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CaretBrush" Value="{StaticResource CyanBrush}"/>
                <Setter Property="SelectionBrush" Value="{StaticResource CyanBrush}"/>
                <Setter Property="SelectionOpacity" Value="0.35"/>
                <Setter Property="Cursor" Value="IBeam"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="3"
                                    SnapsToDevicePixels="True">
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              Focusable="False"
                                              HorizontalScrollBarVisibility="Hidden"
                                              VerticalScrollBarVisibility="Hidden"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgCard2Brush}"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                </Trigger>
                                <Trigger Property="IsKeyboardFocused" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgCardBrush}"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BorderGlowBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <!-- Slider rows live in 3-column Grids (Auto label / * slider / Auto value)
                 so the slider stretches to fill its container's remaining width
                 instead of sitting at a fixed 300 px and leaving a gap on the
                 right edge of the card. -->
            <Style x:Key="SettingSlider" TargetType="Slider" BasedOn="{StaticResource MozaSlider}">
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="MinWidth" Value="160"/>
                <Setter Property="IsSnapToTickEnabled" Value="True"/>
            </Style>
            <!-- Accent-colored slider variants. Foreground cascades to the
                 thumb + decrease-track fill via TemplateBindings in MozaSlider,
                 so a slider on the throttle (green) or brake/handbrake (red)
                 cards picks up the matching accent without a fresh template. -->
            <Style x:Key="GreenSettingSlider" TargetType="Slider" BasedOn="{StaticResource SettingSlider}">
                <Setter Property="Foreground" Value="{StaticResource GreenFillBrush}"/>
            </Style>
            <Style x:Key="RedSettingSlider" TargetType="Slider" BasedOn="{StaticResource SettingSlider}">
                <Setter Property="Foreground" Value="{StaticResource RedFillBrush}"/>
            </Style>
            <!-- Value-box accent variants. Only Foreground / caret / selection
                 brush change; everything else (hover, focus, padding) inherits
                 from SliderValueEditBox. -->
            <Style x:Key="GreenSliderValueEditBox" TargetType="TextBox" BasedOn="{StaticResource SliderValueEditBox}">
                <Setter Property="Foreground" Value="{StaticResource GreenBrush}"/>
                <Setter Property="CaretBrush" Value="{StaticResource GreenBrush}"/>
                <Setter Property="SelectionBrush" Value="{StaticResource GreenBrush}"/>
            </Style>
            <Style x:Key="RedSliderValueEditBox" TargetType="TextBox" BasedOn="{StaticResource SliderValueEditBox}">
                <Setter Property="Foreground" Value="{StaticResource RedBrush}"/>
                <Setter Property="CaretBrush" Value="{StaticResource RedBrush}"/>
                <Setter Property="SelectionBrush" Value="{StaticResource RedBrush}"/>
            </Style>
            <Style x:Key="TempValue" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
                <Setter Property="FontSize" Value="18"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="10,0,20,0"/>
                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            </Style>
            <Style x:Key="ConnectionDot" TargetType="Ellipse">
                <Setter Property="Width" Value="12"/>
                <Setter Property="Height" Value="12"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="0,0,8,0"/>
            </Style>
            <Style x:Key="ColorRect" TargetType="Border">
                <Setter Property="Width" Value="28"/>
                <Setter Property="Height" Value="28"/>
                <Setter Property="BorderBrush" Value="#555"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="3"/>
                <Setter Property="Margin" Value="2,0"/>
                <Setter Property="Cursor" Value="Hand"/>
            </Style>
            <Style x:Key="LedIndex" TargetType="TextBlock">
                <Setter Property="Width" Value="28"/>
                <Setter Property="TextAlignment" Value="Center"/>
                <Setter Property="Foreground" Value="{StaticResource TextFaintBrush}"/>
                <Setter Property="FontSize" Value="10"/>
                <Setter Property="Margin" Value="2,0"/>
            </Style>

            <!-- Default styles for native WPF controls used throughout (Buttons,
                 CheckBoxes, ComboBoxes get the new dark aesthetic automatically). -->
            <Style TargetType="Button" BasedOn="{StaticResource MozaButton}"/>
            <Style TargetType="CheckBox" BasedOn="{StaticResource MozaCheckBox}"/>
            <Style TargetType="ComboBox" BasedOn="{StaticResource MozaCombo}"/>
            <Style TargetType="Slider" BasedOn="{StaticResource MozaSlider}"/>
            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            </Style>
            <Style TargetType="Separator">
                <Setter Property="Background" Value="{StaticResource BorderBrush}"/>
                <Setter Property="Height" Value="1"/>
            </Style>
            <Style TargetType="Expander">
                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                <Setter Property="Background" Value="{StaticResource BgCardBrush}"/>
            </Style>
            <Style TargetType="ProgressBar">
                <Setter Property="Background" Value="{StaticResource BgTrackBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource CyanBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            </Style>
            <Style TargetType="DataGrid">
                <Setter Property="Background" Value="{StaticResource BgCardBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderBrush}"/>
                <Setter Property="VerticalGridLinesBrush" Value="{StaticResource BorderBrush}"/>
                <Setter Property="RowBackground" Value="{StaticResource BgCardBrush}"/>
                <Setter Property="AlternatingRowBackground" Value="{StaticResource BgCard2Brush}"/>
            </Style>

            <!-- Row-grid template used by every restyled slider row -->
            <Style x:Key="RowGrid" TargetType="Grid">
                <Setter Property="Margin" Value="0,4"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <DockPanel LastChildFill="True">
        <!-- ============ Top bar (brand + connection + profile) ============ -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource TopBarBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="22,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <!-- Brand block -->
                <Border Grid.Column="0"
                        BorderThickness="0,0,1,0" BorderBrush="{StaticResource BorderBrush}"
                        Padding="0,0,18,0" Margin="0,0,18,0">
                    <StackPanel Orientation="Horizontal">
                        <Rectangle Width="28" Height="28" Fill="{StaticResource CyanBrush}"
                                   RadiusX="3" RadiusY="3" Margin="0,0,10,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="UNOFFICIAL"
                                       FontSize="8" FontWeight="SemiBold"
                                       Foreground="{StaticResource AmberBrush}"
                                       Background="#22FFB84D"
                                       Padding="5,1"
                                       HorizontalAlignment="Left"/>
                            <TextBlock Text="MOZA" FontWeight="Bold" FontSize="13"
                                       Foreground="{StaticResource TextBrush}"/>
                            <TextBlock Text="SimHub Plugin" FontSize="9"
                                       Foreground="{StaticResource TextFaintBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Connection pill + enable toggle -->
                <ctrl:ConnectionPill Grid.Column="1" x:Name="ConnectionPill"
                                     Margin="0,0,12,0"
                                     VerticalAlignment="Center"/>

                <!-- Legacy hidden controls kept for code-behind binding contracts.
                     ConnectionIndicator + ConnectionLabel are written by .cs; we
                     route those updates into ConnectionPill from code-behind. -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Visibility="Collapsed">
                    <Ellipse x:Name="ConnectionIndicator" Style="{StaticResource ConnectionDot}" Fill="Gray"/>
                    <TextBlock x:Name="ConnectionLabel" Text="Disconnected"/>
                </StackPanel>

                <ctrl:OffOnToggle Grid.Column="2" x:Name="ConnectionToggle"
                                  Margin="0,0,12,0" IsChecked="True"
                                  Checked="ConnectionToggle_Changed"
                                  Unchecked="ConnectionToggle_Changed"
                                  VerticalAlignment="Center"/>

                <Button Grid.Column="3" x:Name="RefreshButton" Content="REFRESH"
                        Click="RefreshButton_Click" VerticalAlignment="Center"/>

                <!-- Profile selector (right-aligned via column 4 stretch) -->
                <profilescommon:ProfileList Grid.Column="4" x:Name="ProfileListControl"
                                            Margin="18,0,0,0"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Status hint banners: port-locked-by-other-app, restart notice,
             profile-not-added-in-SimHub. Items bound by code-behind every
             ~500ms; the list diff suppresses unchanged-tick rebuilds. -->
        <ItemsControl x:Name="HintBanners" DockPanel.Dock="Top"
                      Margin="22,12,22,0" KeyboardNavigation.TabNavigation="None">
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type ui:StatusHint}">
                    <Border Style="{StaticResource BannerBorder}" Margin="0,0,0,6">
                        <StackPanel>
                            <TextBlock Text="{Binding Title}" FontWeight="Bold"
                                       Foreground="#FFD7A0"/>
                            <TextBlock Text="{Binding Body}" Foreground="#FFD7A0"
                                       TextWrapping="Wrap" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Tabs -->
        <TabControl Style="{StaticResource MozaTabControl}">

            <!-- ==================== BASE TAB ==================== -->
            <TabItem Header="Base">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="22,18,22,8">
                    <StackPanel>
                        <!-- Live telemetry header -->
                        <Border Background="{StaticResource BgCardBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1" CornerRadius="8"
                                Padding="18" Margin="0,0,0,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="240"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ctrl:SteeringArc Grid.Column="0" x:Name="SteeringArcViz"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Margin="18,0,0,0">
                                    <DockPanel Margin="0,0,0,12" LastChildFill="False">
                                        <Button DockPanel.Dock="Left" x:Name="BaseCalibrateButton"
                                                Content="CALIBRATE CENTER"
                                                Click="BaseCalibrateButton_Click"
                                                VerticalAlignment="Center"/>
                                        <TextBlock DockPanel.Dock="Left" x:Name="BaseCalibrateStatus"
                                                   Style="{StaticResource MutedHintText}"
                                                   VerticalAlignment="Center"
                                                   Margin="10,0,0,0"/>
                                        <ctrl:SegmentedControl DockPanel.Dock="Right"
                                                               x:Name="PerformanceOutputCombo"
                                                               SelectionChanged="PerformanceOutputCombo_Changed"
                                                               VerticalAlignment="Center">
                                            <ListBoxItem Content="Reserved"/>
                                            <ListBoxItem Content="Full"/>
                                        </ctrl:SegmentedControl>
                                        <TextBlock DockPanel.Dock="Right"
                                                   Text="Performance Output"
                                                   Style="{StaticResource LabelText}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,10,0"/>
                                    </DockPanel>
                                    <!-- Combined MCU + MOSFET + MOTOR rolling graph
                                         (replaces the three fake-meter TempCells).
                                         Shares a 0–120 °C scale; the legend row
                                         below shows the colour key + live values. -->
                                    <Border Style="{StaticResource InnerCardBorder}" Padding="10,8">
                                        <StackPanel>
                                            <ctrl:TemperatureGraph x:Name="TemperatureGraphViz" Height="80"
                                                                   McuBrush="{StaticResource CyanBrush}"
                                                                   MosfetBrush="{StaticResource AmberBrush}"
                                                                   MotorBrush="{StaticResource RedBrush}"
                                                                   McuFillBrush="{StaticResource McuFillBrush}"
                                                                   MosfetFillBrush="{StaticResource MosfetFillBrush}"
                                                                   MotorFillBrush="{StaticResource MotorFillBrush}"/>
                                            <Grid Margin="0,6,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                    <Ellipse Width="6" Height="6" VerticalAlignment="Center"
                                                             Fill="{StaticResource CyanBrush}" Margin="0,0,6,0"/>
                                                    <TextBlock Text="MCU" Style="{StaticResource KvKeyText}"/>
                                                    <TextBlock x:Name="McuTempLegend" Text="—"
                                                               Style="{StaticResource KvValueText}"
                                                               Foreground="{StaticResource CyanBrush}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                    <Ellipse Width="6" Height="6" VerticalAlignment="Center"
                                                             Fill="{StaticResource AmberBrush}" Margin="0,0,6,0"/>
                                                    <TextBlock Text="MOSFET" Style="{StaticResource KvKeyText}"/>
                                                    <TextBlock x:Name="MosfetTempLegend" Text="—"
                                                               Style="{StaticResource KvValueText}"
                                                               Foreground="{StaticResource AmberBrush}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                    <Ellipse Width="6" Height="6" VerticalAlignment="Center"
                                                             Fill="{StaticResource RedBrush}" Margin="0,0,6,0"/>
                                                    <TextBlock Text="MOTOR" Style="{StaticResource KvKeyText}"/>
                                                    <TextBlock x:Name="MotorTempLegend" Text="—"
                                                               Style="{StaticResource KvValueText}"
                                                               Foreground="{StaticResource RedBrush}"/>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Legacy text-based readouts: hidden but kept so code-behind
                             that writes to SteeringAngleLabel.Text etc. still works.
                             .cs additionally pushes Angle into SteeringArcViz and
                             numeric values into the *TempCell controls. -->
                        <StackPanel Visibility="Collapsed">
                            <TextBlock x:Name="SteeringAngleLabel" Text="--"/>
                            <TextBlock x:Name="McuTempLabel" Text="--"/>
                            <TextBlock x:Name="MosfetTempLabel" Text="--"/>
                            <TextBlock x:Name="MotorTempLabel" Text="--"/>
                        </StackPanel>

                        <!-- Core Settings + Gearshift Vibration side-by-side: both are
                             "configure-then-forget" sliders that benefit from being
                             visible together at the top of the tab. -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ctrl:SectionCard Grid.Column="0" Title="CORE SETTINGS"
                                              Icon="{StaticResource IconBolt}" Margin="0,0,7,14">
                                <StackPanel>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Wheel Rotation Angle" Style="{StaticResource SliderLabel}"/>
                                        <Slider Grid.Column="1" x:Name="RotationSlider" Style="{StaticResource SettingSlider}" Minimum="90" Maximum="2700" TickFrequency="10" SmallChange="10" LargeChange="10" IsSnapToTickEnabled="True" ValueChanged="RotationSlider_ValueChanged"/>
                                        <TextBox Grid.Column="2" x:Name="RotationValue" Style="{StaticResource SliderValueEditBox}"
                                                 Tag="{Binding ElementName=RotationSlider}"
                                                 KeyDown="SliderValueBox_KeyDown" LostFocus="SliderValueBox_LostFocus"
                                                 Text="900°"/>
                                    </Grid>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Game FFB Strength" Style="{StaticResource SliderLabel}"/>
                                        <Slider Grid.Column="1" x:Name="FfbStrengthSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="FfbStrengthSlider_ValueChanged"/>
                                        <TextBox Grid.Column="2" x:Name="FfbStrengthValue" Style="{StaticResource SliderValueEditBox}"
                                                 Tag="{Binding ElementName=FfbStrengthSlider}"
                                                 KeyDown="SliderValueBox_KeyDown" LostFocus="SliderValueBox_LostFocus"
                                                 Text="80%"/>
                                    </Grid>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Base Torque Output" Style="{StaticResource SliderLabel}"/>
                                        <Slider Grid.Column="1" x:Name="TorqueSlider" Style="{StaticResource SettingSlider}" Minimum="50" Maximum="100" TickFrequency="5" ValueChanged="TorqueSlider_ValueChanged"/>
                                        <TextBox Grid.Column="2" x:Name="TorqueValue" Style="{StaticResource SliderValueEditBox}"
                                                 Tag="{Binding ElementName=TorqueSlider}"
                                                 KeyDown="SliderValueBox_KeyDown" LostFocus="SliderValueBox_LostFocus"
                                                 Text="100%"/>
                                    </Grid>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Maximum Wheel Speed" Style="{StaticResource SliderLabel}"/>
                                        <Slider Grid.Column="1" x:Name="SpeedSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="200" TickFrequency="1" ValueChanged="SpeedSlider_ValueChanged"/>
                                        <TextBox Grid.Column="2" x:Name="SpeedValue" Style="{StaticResource SliderValueEditBox}"
                                                 Tag="{Binding ElementName=SpeedSlider}"
                                                 KeyDown="SliderValueBox_KeyDown" LostFocus="SliderValueBox_LostFocus"
                                                 Text="100%"/>
                                    </Grid>
                                </StackPanel>
                            </ctrl:SectionCard>

                            <ctrl:SectionCard Grid.Column="1" Title="GEARSHIFT VIBRATION"
                                              Icon="{StaticResource IconShift}" Margin="7,0,0,14">
                                <StackPanel>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Shift Intensity" Style="{StaticResource SliderLabel}"/>
                                        <Slider Grid.Column="1" x:Name="GearshiftVibrationSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="5" TickFrequency="1" SmallChange="1" LargeChange="1" IsSnapToTickEnabled="True" ValueChanged="GearshiftVibrationSlider_ValueChanged"/>
                                        <TextBox Grid.Column="2" x:Name="GearshiftVibrationValue" Style="{StaticResource SliderValueEditBox}"
                                                 Tag="{Binding ElementName=GearshiftVibrationSlider}"
                                                 KeyDown="SliderValueBox_KeyDown" LostFocus="SliderValueBox_LostFocus"
                                                 Text="0"/>
                                    </Grid>
                                    <StackPanel Orientation="Horizontal" Margin="0,4">
                                        <TextBlock Text="Vibrate on Neutral" Style="{StaticResource SliderLabel}"/>
                                        <ctrl:OffOnToggle x:Name="GearshiftVibrateOnNeutralCheck" VerticalAlignment="Center"
                                                  Checked="GearshiftVibrateOnNeutralCheck_Changed" Unchecked="GearshiftVibrateOnNeutralCheck_Changed"/>
                                    </StackPanel>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Shift Debounce" Style="{StaticResource SliderLabel}"/>
                                        <Slider Grid.Column="1" x:Name="GearshiftDebounceSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="1000" TickFrequency="50" SmallChange="50" LargeChange="50" IsSnapToTickEnabled="True" ValueChanged="GearshiftDebounceSlider_ValueChanged"/>
                                        <TextBox Grid.Column="2" x:Name="GearshiftDebounceValue" Style="{StaticResource SliderValueEditBox}"
                                                 Tag="{Binding ElementName=GearshiftDebounceSlider}"
                                                 KeyDown="SliderValueBox_KeyDown" LostFocus="SliderValueBox_LostFocus"
                                                 Text="500 ms"/>
                                    </Grid>
                                </StackPanel>
                            </ctrl:SectionCard>
                        </Grid>

                        <!-- Wheelbase + Game effects sit side-by-side: same widget shape
                             (4 sliders each), benefit from being readable as a pair. -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ctrl:SectionCard Grid.Column="0" Title="WHEELBASE EFFECTS"
                                              Icon="{StaticResource IconDamper}" Margin="0,0,7,14">
                                <StackPanel>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Wheel Damper" Style="{StaticResource SliderLabel}"/>
                                        <Slider Grid.Column="1" x:Name="DamperSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="DamperSlider_ValueChanged"/>
                                        <TextBox Grid.Column="2" x:Name="DamperValue" Style="{StaticResource SliderValueEditBox}"
                                                 Tag="{Binding ElementName=DamperSlider}"
                                                 KeyDown="SliderValueBox_KeyDown" LostFocus="SliderValueBox_LostFocus"
                                                 Text="0%"/>
                                    </Grid>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Wheel Friction" Style="{StaticResource SliderLabel}"/>
                                        <Slider Grid.Column="1" x:Name="FrictionSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="FrictionSlider_ValueChanged"/>
                                        <TextBox Grid.Column="2" x:Name="FrictionValue" Style="{StaticResource SliderValueEditBox}"
                                                 Tag="{Binding ElementName=FrictionSlider}"
                                                 KeyDown="SliderValueBox_KeyDown" LostFocus="SliderValueBox_LostFocus"
                                                 Text="0%"/>
                                    </Grid>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Natural Inertia" Style="{StaticResource SliderLabel}"/>
                                        <Slider Grid.Column="1" x:Name="InertiaSlider" Style="{StaticResource SettingSlider}" Minimum="100" Maximum="500" TickFrequency="50" ValueChanged="InertiaSlider_ValueChanged"/>
                                        <TextBox Grid.Column="2" x:Name="InertiaValue" Style="{StaticResource SliderValueEditBox}"
                                                 Tag="{Binding ElementName=InertiaSlider}"
                                                 KeyDown="SliderValueBox_KeyDown" LostFocus="SliderValueBox_LostFocus"
                                                 Text="250"/>
                                    </Grid>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Wheel Spring" Style="{StaticResource SliderLabel}"/>
                                        <Slider Grid.Column="1" x:Name="SpringSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="SpringSlider_ValueChanged"/>
                                        <TextBox Grid.Column="2" x:Name="SpringValue" Style="{StaticResource SliderValueEditBox}"
                                                 Tag="{Binding ElementName=SpringSlider}"
                                                 KeyDown="SliderValueBox_KeyDown" LostFocus="SliderValueBox_LostFocus"
                                                 Text="0%"/>
                                    </Grid>
                                </StackPanel>
                            </ctrl:SectionCard>

                            <ctrl:SectionCard Grid.Column="1" Title="GAME EFFECTS"
                                              Icon="{StaticResource IconGame}" Margin="7,0,0,14">
                                <StackPanel>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Game Damper" Style="{StaticResource SliderLabel}"/>
                                        <Slider Grid.Column="1" x:Name="GameDamperSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="5" ValueChanged="GameDamperSlider_ValueChanged"/>
                                        <TextBox Grid.Column="2" x:Name="GameDamperValue" Style="{StaticResource SliderValueEditBox}"
                                                 Tag="{Binding ElementName=GameDamperSlider}"
                                                 KeyDown="SliderValueBox_KeyDown" LostFocus="SliderValueBox_LostFocus"
                                                 Text="50%"/>
                                    </Grid>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Game Friction" Style="{StaticResource SliderLabel}"/>
                                        <Slider Grid.Column="1" x:Name="GameFrictionSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="5" ValueChanged="GameFrictionSlider_ValueChanged"/>
                                        <TextBox Grid.Column="2" x:Name="GameFrictionValue" Style="{StaticResource SliderValueEditBox}"
                                                 Tag="{Binding ElementName=GameFrictionSlider}"
                                                 KeyDown="SliderValueBox_KeyDown" LostFocus="SliderValueBox_LostFocus"
                                                 Text="50%"/>
                                    </Grid>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Game Inertia" Style="{StaticResource SliderLabel}"/>
                                        <Slider Grid.Column="1" x:Name="GameInertiaSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="5" ValueChanged="GameInertiaSlider_ValueChanged"/>
                                        <TextBox Grid.Column="2" x:Name="GameInertiaValue" Style="{StaticResource SliderValueEditBox}"
                                                 Tag="{Binding ElementName=GameInertiaSlider}"
                                                 KeyDown="SliderValueBox_KeyDown" LostFocus="SliderValueBox_LostFocus"
                                                 Text="50%"/>
                                    </Grid>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Game Spring" Style="{StaticResource SliderLabel}"/>
                                        <Slider Grid.Column="1" x:Name="GameSpringSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="5" ValueChanged="GameSpringSlider_ValueChanged"/>
                                        <TextBox Grid.Column="2" x:Name="GameSpringValue" Style="{StaticResource SliderValueEditBox}"
                                                 Tag="{Binding ElementName=GameSpringSlider}"
                                                 KeyDown="SliderValueBox_KeyDown" LostFocus="SliderValueBox_LostFocus"
                                                 Text="100%"/>
                                    </Grid>
                                </StackPanel>
                            </ctrl:SectionCard>
                        </Grid>

                        <!-- Protection + Soft Limit sit side-by-side: both small safety
                             cards (toggle + a slider), pair nicely. -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ctrl:SectionCard Grid.Column="0" Title="PROTECTION"
                                              Icon="{StaticResource IconShield}" Margin="0,0,7,14">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,8">
                                        <TextBlock Text="Hands-Off Protection" Style="{StaticResource SliderLabel}"/>
                                        <ctrl:OffOnToggle x:Name="ProtectionCheck" VerticalAlignment="Center" Click="ProtectionCheck_Click"/>
                                    </StackPanel>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Steering Wheel Inertia" Style="{StaticResource SliderLabel}"/>
                                        <Slider Grid.Column="1" x:Name="NaturalInertiaSlider" Style="{StaticResource SettingSlider}" Minimum="100" Maximum="4000" TickFrequency="50" ValueChanged="NaturalInertiaSlider_ValueChanged"/>
                                        <TextBox Grid.Column="2" x:Name="NaturalInertiaValue" Style="{StaticResource SliderValueEditBox}"
                                                 Tag="{Binding ElementName=NaturalInertiaSlider}"
                                                 KeyDown="SliderValueBox_KeyDown" LostFocus="SliderValueBox_LostFocus"
                                                 Text="1100"/>
                                    </Grid>
                                </StackPanel>
                            </ctrl:SectionCard>

                            <ctrl:SectionCard Grid.Column="1" Title="SOFT LIMIT"
                                              Icon="{StaticResource IconLimit}" Margin="7,0,0,14">
                                <StackPanel>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Stiffness" Style="{StaticResource SliderLabel}"/>
                                        <Slider Grid.Column="1" x:Name="SoftLimitStiffnessSlider" Style="{StaticResource SettingSlider}" Minimum="1" Maximum="10" TickFrequency="1" ValueChanged="SoftLimitStiffnessSlider_ValueChanged"/>
                                        <TextBox Grid.Column="2" x:Name="SoftLimitStiffnessValue" Style="{StaticResource SliderValueEditBox}"
                                                 Tag="{Binding ElementName=SoftLimitStiffnessSlider}"
                                                 KeyDown="SliderValueBox_KeyDown" LostFocus="SliderValueBox_LostFocus"
                                                 Text="5"/>
                                    </Grid>
                                    <StackPanel Orientation="Horizontal" Margin="0,8">
                                        <TextBlock Text="Retain Game FFB" Style="{StaticResource SliderLabel}"/>
                                        <ctrl:OffOnToggle x:Name="SoftLimitRetainCheck" VerticalAlignment="Center" Click="SoftLimitRetainCheck_Click"/>
                                    </StackPanel>
                                </StackPanel>
                            </ctrl:SectionCard>
                        </Grid>

                        <!-- FFB Equalizer + Output Curve sit side-by-side: same widget
                             shape (a node graph with a row of preset buttons), benefit
                             from being readable together. -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <ctrl:SectionCard Grid.Column="0" Title="FFB EQUALIZER"
                                              Subtitle="// per-band gain · 100% = neutral · 400% = max boost"
                                              Icon="{StaticResource IconEq}" Margin="0,0,7,14">
                                <StackPanel>
                                    <ctrl:MozaCurveEditor x:Name="FfbEqualizer"
                                                          Style="{StaticResource MozaEqualizerLineStyle}"
                                                          Height="280"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                        <Button Content="FLAT" Margin="0,0,8,0" Click="FfbEqPreset_Flat"/>
                                        <Button Content="FALLOFF" Click="FfbEqPreset_Falloff"/>
                                    </StackPanel>
                                </StackPanel>
                            </ctrl:SectionCard>

                            <ctrl:SectionCard Grid.Column="1" Title="FFB OUTPUT CURVE"
                                              Subtitle="// drag the 5 nodes to shape response"
                                              Icon="{StaticResource IconCurve}"
                                              AccentBrush="{StaticResource GreenBrush}" Margin="7,0,0,14">
                                <StackPanel>
                                    <ctrl:MozaCurveEditor x:Name="FfbCurveEditor" Height="280"
                                                          AccentBrush="{StaticResource GreenBrush}"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                        <Button Content="LINEAR" Margin="0,0,8,0" Click="FfbCurvePreset_Linear"/>
                                        <Button Content="S CURVE" Margin="0,0,8,0" Click="FfbCurvePreset_SCurve"/>
                                        <Button Content="EXPONENTIAL" Margin="0,0,8,0" Click="FfbCurvePreset_Exponential"/>
                                        <Button Content="PARABOLIC" Click="FfbCurvePreset_Parabolic"/>
                                    </StackPanel>
                                </StackPanel>
                            </ctrl:SectionCard>
                        </Grid>

                        <!-- Data-store sliders, driven by the editors above (visibility
                             collapsed so they don't render but their x:Name + ValueChanged
                             still resolve through the existing two-way bindings). -->
                        <StackPanel Visibility="Collapsed">
                            <Slider x:Name="Eq1Slider" Minimum="0" Maximum="400" TickFrequency="1" ValueChanged="Eq1Slider_ValueChanged"/>
                            <TextBox x:Name="Eq1Value" Text="100%"/>
                            <Slider x:Name="Eq2Slider" Minimum="0" Maximum="400" TickFrequency="1" ValueChanged="Eq2Slider_ValueChanged"/>
                            <TextBox x:Name="Eq2Value" Text="100%"/>
                            <Slider x:Name="Eq3Slider" Minimum="0" Maximum="400" TickFrequency="1" ValueChanged="Eq3Slider_ValueChanged"/>
                            <TextBox x:Name="Eq3Value" Text="100%"/>
                            <Slider x:Name="Eq4Slider" Minimum="0" Maximum="400" TickFrequency="1" ValueChanged="Eq4Slider_ValueChanged"/>
                            <TextBox x:Name="Eq4Value" Text="100%"/>
                            <Slider x:Name="Eq5Slider" Minimum="0" Maximum="400" TickFrequency="1" ValueChanged="Eq5Slider_ValueChanged"/>
                            <TextBox x:Name="Eq5Value" Text="100%"/>
                            <Slider x:Name="Eq6Slider" Minimum="0" Maximum="400" TickFrequency="1" ValueChanged="Eq6Slider_ValueChanged"/>
                            <TextBox x:Name="Eq6Value" Text="100%"/>
                            <Slider x:Name="FfbCurveY1Slider" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="FfbCurveY1Slider_ValueChanged"/>
                            <TextBox x:Name="FfbCurveY1Value" Text="20"/>
                            <Slider x:Name="FfbCurveY2Slider" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="FfbCurveY2Slider_ValueChanged"/>
                            <TextBox x:Name="FfbCurveY2Value" Text="40"/>
                            <Slider x:Name="FfbCurveY3Slider" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="FfbCurveY3Slider_ValueChanged"/>
                            <TextBox x:Name="FfbCurveY3Value" Text="60"/>
                            <Slider x:Name="FfbCurveY4Slider" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="FfbCurveY4Slider_ValueChanged"/>
                            <TextBox x:Name="FfbCurveY4Value" Text="80"/>
                            <Slider x:Name="FfbCurveY5Slider" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="FfbCurveY5Slider_ValueChanged"/>
                            <TextBox x:Name="FfbCurveY5Value" Text="100"/>
                        </StackPanel>

                        <!-- Miscellaneous + High Speed Damping sit side-by-side: small
                             cards that round out the tab at the bottom. -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ctrl:SectionCard Grid.Column="0" Title="MISCELLANEOUS"
                                              Icon="{StaticResource IconMisc}" Margin="0,0,7,14">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,8">
                                        <TextBlock Text="Force Feedback Reversal" Style="{StaticResource SliderLabel}"/>
                                        <ctrl:OffOnToggle x:Name="FfbReverseCheck" VerticalAlignment="Center" Click="FfbReverseCheck_Click"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,8">
                                        <TextBlock Text="Standby Mode" Style="{StaticResource SliderLabel}"/>
                                        <ctrl:OffOnToggle x:Name="StandbyCheck" VerticalAlignment="Center" Click="StandbyCheck_Click"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,8">
                                        <TextBlock Text="Base Status LED" Style="{StaticResource SliderLabel}"/>
                                        <ctrl:OffOnToggle x:Name="LedStatusCheck" VerticalAlignment="Center" Click="LedStatusCheck_Click"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,8">
                                        <TextBlock Text="Bluetooth" Style="{StaticResource SliderLabel}"/>
                                        <ctrl:OffOnToggle x:Name="BluetoothCheck" VerticalAlignment="Center" Click="BluetoothCheck_Click"/>
                                    </StackPanel>
                                </StackPanel>
                            </ctrl:SectionCard>

                            <ctrl:SectionCard Grid.Column="1" Title="HIGH SPEED DAMPING"
                                              Subtitle="// I have no idea what these settings do"
                                              Icon="{StaticResource IconSpeed}" Margin="7,0,0,14">
                                <StackPanel>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Damping Level" Style="{StaticResource SliderLabel}"/>
                                        <Slider Grid.Column="1" x:Name="SpeedDampingSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="SpeedDampingSlider_ValueChanged"/>
                                        <TextBox Grid.Column="2" x:Name="SpeedDampingValue" Style="{StaticResource SliderValueEditBox}"
                                                 Tag="{Binding ElementName=SpeedDampingSlider}"
                                                 KeyDown="SliderValueBox_KeyDown" LostFocus="SliderValueBox_LostFocus"
                                                 Text="0%"/>
                                    </Grid>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Trigger Speed" Style="{StaticResource SliderLabel}"/>
                                        <Slider Grid.Column="1" x:Name="SpeedDampingPointSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="400" TickFrequency="10" ValueChanged="SpeedDampingPointSlider_ValueChanged"/>
                                        <TextBox Grid.Column="2" x:Name="SpeedDampingPointValue" Style="{StaticResource SliderValueEditBox}"
                                                 Tag="{Binding ElementName=SpeedDampingPointSlider}"
                                                 KeyDown="SliderValueBox_KeyDown" LostFocus="SliderValueBox_LostFocus"
                                                 Text="120 kph"/>
                                    </Grid>
                                </StackPanel>
                            </ctrl:SectionCard>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ==================== WHEEL TAB (Phase 6: hidden) ====================
                 Wheel-input settings + live paddle/button display now live in the
                 per-device MozaWheelSettingsControl "Inputs" sub-tab. The controls
                 here stay in the visual tree (Visibility=Collapsed) so the device
                 pane can forward user input to them, triggering this code-behind's
                 existing handler + persistence logic. -->
            <TabItem x:Name="WheelTab" Header="Wheel" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                    <StackPanel Margin="5">

                        <!-- Live Input -->
                        <TextBlock Text="Paddles" Style="{StaticResource SectionHeader}"/>
                        <StackPanel x:Name="SplitPaddlePanel" Orientation="Horizontal" Margin="0,0,0,10">
                            <StackPanel Margin="0,0,20,0" Width="100">
                                <TextBlock Text="Left Paddle" Foreground="Gray" FontSize="11"/>
                                <ProgressBar x:Name="LeftPaddleBar" Height="14" Minimum="0" Maximum="100" Value="0"/>
                            </StackPanel>
                            <StackPanel Width="100">
                                <TextBlock Text="Right Paddle" Foreground="Gray" FontSize="11"/>
                                <ProgressBar x:Name="RightPaddleBar" Height="14" Minimum="0" Maximum="100" Value="0"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel x:Name="CombinedPaddlePanel" Orientation="Horizontal" Margin="0,0,0,10" Visibility="Collapsed">
                            <StackPanel Width="100">
                                <TextBlock Text="Combined" Foreground="Gray" FontSize="11"/>
                                <ProgressBar x:Name="CombinedPaddleBar" Height="14" Minimum="0" Maximum="100" Value="0"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Active Buttons -->
                        <TextBlock Text="Buttons" Style="{StaticResource SectionHeader}" Margin="0,4,0,8"/>
                        <TextBlock x:Name="ActiveButtonsText" FontFamily="Consolas" FontSize="12"
                                   Foreground="Gray" Margin="0,0,0,10" TextWrapping="Wrap">None</TextBlock>

                        <!-- Paddle Settings -->
                        <TextBlock Text="Paddle Settings" Style="{StaticResource SectionHeader}"/>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Paddles Mode" Style="{StaticResource SliderLabel}"/>
                            <ComboBox Grid.Column="1" x:Name="WheelPaddlesModeCombo" Width="140" SelectionChanged="WheelPaddlesModeCombo_Changed">
                                <ComboBoxItem Content="Buttons"/>
                                <ComboBoxItem Content="Combined"/>
                                <ComboBoxItem Content="Split"/>
                            </ComboBox>
                        </Grid>
                        <Grid x:Name="WheelClutchPointPanel" Margin="0,4" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Clutch Split Point" Style="{StaticResource SliderLabel}"/>
                            <Slider Grid.Column="1" x:Name="WheelClutchPointSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="WheelClutchPointSlider_ValueChanged"/>
                            <TextBox Grid.Column="2" x:Name="WheelClutchPointValue" Style="{StaticResource SliderValueEditBox}"
                                                 Tag="{Binding ElementName=WheelClutchPointSlider}"
                                                 KeyDown="SliderValueBox_KeyDown" LostFocus="SliderValueBox_LostFocus"
                                                 Text="50%"/>
                        </Grid>

                        <!-- Input Settings (knob + stick) -->
                        <TextBlock Text="Input Settings" Style="{StaticResource SectionHeader}"/>
                        <Grid x:Name="KnobModeLegacyPanel" Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Rotary Encoders" Style="{StaticResource SliderLabel}"/>
                            <ComboBox Grid.Column="1" x:Name="KnobModeCombo" Width="140" SelectionChanged="KnobModeCombo_Changed">
                                <ComboBoxItem Content="Buttons"/>
                                <ComboBoxItem Content="Knob"/>
                            </ComboBox>
                        </Grid>
                        <StackPanel x:Name="KnobSignalModePanel" Visibility="Collapsed">
                            <Grid x:Name="KnobSignalMode0Row" Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Rotary 1" Style="{StaticResource SliderLabel}"/>
                                <ComboBox Grid.Column="1" x:Name="KnobSignalMode0Combo" Width="140" SelectionChanged="KnobSignalMode0Combo_Changed">
                                    <ComboBoxItem Content="Buttons"/><ComboBoxItem Content="Knob"/>
                                </ComboBox>
                            </Grid>
                            <Grid x:Name="KnobSignalMode1Row" Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Rotary 2" Style="{StaticResource SliderLabel}"/>
                                <ComboBox Grid.Column="1" x:Name="KnobSignalMode1Combo" Width="140" SelectionChanged="KnobSignalMode1Combo_Changed">
                                    <ComboBoxItem Content="Buttons"/><ComboBoxItem Content="Knob"/>
                                </ComboBox>
                            </Grid>
                            <Grid x:Name="KnobSignalMode2Row" Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Rotary 3" Style="{StaticResource SliderLabel}"/>
                                <ComboBox Grid.Column="1" x:Name="KnobSignalMode2Combo" Width="140" SelectionChanged="KnobSignalMode2Combo_Changed">
                                    <ComboBoxItem Content="Buttons"/><ComboBoxItem Content="Knob"/>
                                </ComboBox>
                            </Grid>
                            <Grid x:Name="KnobSignalMode3Row" Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Rotary 4" Style="{StaticResource SliderLabel}"/>
                                <ComboBox Grid.Column="1" x:Name="KnobSignalMode3Combo" Width="140" SelectionChanged="KnobSignalMode3Combo_Changed">
                                    <ComboBoxItem Content="Buttons"/><ComboBoxItem Content="Knob"/>
                                </ComboBox>
                            </Grid>
                            <Grid x:Name="KnobSignalMode4Row" Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Rotary 5" Style="{StaticResource SliderLabel}"/>
                                <ComboBox Grid.Column="1" x:Name="KnobSignalMode4Combo" Width="140" SelectionChanged="KnobSignalMode4Combo_Changed">
                                    <ComboBoxItem Content="Buttons"/><ComboBoxItem Content="Knob"/>
                                </ComboBox>
                            </Grid>
                        </StackPanel>
                        <StackPanel x:Name="StickModeOldPanel" Orientation="Horizontal" Margin="0,8" Visibility="Collapsed">
                            <TextBlock Text="Stick as D-Pad" Style="{StaticResource SliderLabel}"/>
                            <ctrl:OffOnToggle x:Name="StickModeCheck" VerticalAlignment="Center" Click="StickModeCheck_Click"/>
                        </StackPanel>
                        <Grid x:Name="StickModeNewPanel" Margin="0,8" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Joystick Assignment" Style="{StaticResource SliderLabel}"/>
                            <ComboBox Grid.Column="1" x:Name="StickModeCombo" Width="120" SelectionChanged="StickModeCombo_Changed">
                                <ComboBoxItem Content="None"/>
                                <ComboBoxItem Content="Left"/>
                                <ComboBoxItem Content="Right"/>
                            </ComboBox>
                        </Grid>

                        <TextBlock TextWrapping="Wrap" Foreground="Gray" FontSize="11" Margin="0,12,0,0"
                                   Text="LED and button settings are in the MOZA Wheel device tab under Devices."/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ==================== HANDBRAKE TAB ==================== -->
            <TabItem x:Name="HandbrakeTab" Header="Handbrake" Visibility="Collapsed">
                <!-- Red accent for active button-selectors (SegmentedControl
                     selected item, OffOnToggle ON pill). The templates resolve
                     these keys via DynamicResource, so overriding them here
                     tints every active control inside the Handbrake tab. -->
                <TabItem.Resources>
                    <StaticResource x:Key="ToggleOnBrush" ResourceKey="RedToggleOnBrush"/>
                    <SolidColorBrush x:Key="ToggleOnTextBrush" Color="{StaticResource RedColor}"/>
                </TabItem.Resources>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                    <StackPanel Margin="5">

                        <!-- Live Input (POSITION card) + CALIBRATION side-by-side. -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ctrl:SectionCard Grid.Column="0" Title="POSITION"
                                              Subtitle="// live handbrake input"
                                              Icon="{StaticResource IconHandbrake}"
                                              AccentBrush="{StaticResource RedBrush}"
                                              Margin="0,0,7,14">
                                <StackPanel>
                                    <StackPanel x:Name="HandbrakeAxisPanel" Margin="0,4">
                                        <TextBlock Text="Position" Style="{StaticResource MutedHintText}" Margin="0,0,0,4"/>
                                        <ProgressBar x:Name="HandbrakeBar" Height="14" Minimum="0" Maximum="100" Value="0"
                                                     HorizontalAlignment="Stretch"/>
                                    </StackPanel>
                                    <TextBlock x:Name="HandbrakeButtonStatus" FontFamily="Consolas" FontSize="14"
                                               FontWeight="Normal" Margin="0,4" Visibility="Collapsed">Released</TextBlock>
                                </StackPanel>
                            </ctrl:SectionCard>

                            <ctrl:SectionCard Grid.Column="1" Title="CALIBRATION"
                                              Subtitle="// pull the handbrake fully once"
                                              Icon="{StaticResource IconCal}"
                                              AccentBrush="{StaticResource RedBrush}"
                                              Margin="7,0,0,14">
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <Button x:Name="HbCalStartButton" Content="START CALIBRATION" Margin="0,0,10,0" Click="HbCalStartButton_Click"/>
                                    <Button x:Name="HbCalStopButton" Content="STOP" Click="HbCalStopButton_Click"/>
                                    <TextBlock x:Name="HbCalStatus" Style="{StaticResource MutedHintText}" Margin="14,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </ctrl:SectionCard>
                        </Grid>

                        <!-- Handbrake Settings + Range side-by-side. -->
