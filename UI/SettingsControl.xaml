                                            <ctrl:OffOnToggle Grid.Column="1" x:Name="BaseLfeAbsVibrateOnNeutral" Tag="abs" Margin="0,0,38,0" VerticalAlignment="Center" Checked="BaseLfeVibrateOnNeutral_Changed" Unchecked="BaseLfeVibrateOnNeutral_Changed"/>
                                        </Grid>
                                        <Grid Margin="0,6,0,0">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{x:Static res:Strings.SliderLabel_ShiftDebounce}" Style="{StaticResource LfeLabel}" VerticalAlignment="Center"/>
                                            <TextBox Grid.Column="1" x:Name="BaseLfeAbsDebounceValue" Width="58" Margin="0,0,38,0" Style="{StaticResource SliderValueEditBox}" Tag="{Binding ElementName=BaseLfeAbsDebounceSlider}" KeyDown="SliderValueBox_KeyDown" LostFocus="SliderValueBox_LostFocus" Text="50 ms"/>
                                        </Grid>
                                        <Slider x:Name="BaseLfeAbsDebounceSlider" Tag="abs" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="1000" TickFrequency="50" SmallChange="50" LargeChange="50" IsSnapToTickEnabled="True" Margin="0,2,0,0" ValueChanged="BaseLfeDebounce_ValueChanged"/>
                                    </StackPanel>
                            </StackPanel>
                        </ctrl:SectionCard>
                        <ctrl:SectionCard Grid.Row="1" Grid.Column="1" VerticalAlignment="Top" Title="{x:Static res:Strings.Section_EffectsSlot3}" Icon="{StaticResource IconShift}" Margin="7,0,0,0">
