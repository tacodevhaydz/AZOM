                            <Slider x:Name="Ab9FrictionSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="Ab9FrictionSlider_ValueChanged"/>
                            <TextBlock x:Name="Ab9FrictionValue" Style="{StaticResource SliderValue}" Text="50"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <TextBlock Text="Max Output Torque Limit" Style="{StaticResource SliderLabel}"/>
                            <Slider x:Name="Ab9MaxTorqueSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="Ab9MaxTorqueSlider_ValueChanged"/>
                            <TextBlock x:Name="Ab9MaxTorqueValue" Style="{StaticResource SliderValue}" Text="50"/>
                        </StackPanel>

                        <TextBlock Text="Engine Vibration" Style="{StaticResource SectionHeader}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <TextBlock Text="Intensity" Style="{StaticResource SliderLabel}"/>
                            <Slider x:Name="Ab9EngineVibIntensitySlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="Ab9EngineVibIntensitySlider_ValueChanged"/>
                            <TextBlock x:Name="Ab9EngineVibIntensityValue" Style="{StaticResource SliderValue}" Text="0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <TextBlock Text="Frequency" Style="{StaticResource SliderLabel}"/>
                            <Slider x:Name="Ab9EngineVibFreqSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="300" TickFrequency="10" ValueChanged="Ab9EngineVibFreqSlider_ValueChanged"/>
                            <TextBlock x:Name="Ab9EngineVibFreqValue" Style="{StaticResource SliderValue}" Text="100 Hz"/>
                        </StackPanel>

                        <TextBlock Text="Gear Shift" Style="{StaticResource SectionHeader}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <TextBlock Text="Vibration Intensity" Style="{StaticResource SliderLabel}"/>
                            <Slider x:Name="Ab9GearShiftVibSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="Ab9GearShiftVibSlider_ValueChanged"/>
                            <TextBlock x:Name="Ab9GearShiftVibValue" Style="{StaticResource SliderValue}" Text="0"/>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ==================== mBOOSTER TAB ==================== -->
            <TabItem x:Name="MBoosterTab" Header="mBooster" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                    <StackPanel Margin="5">
                        <TextBlock Text="Moza mBooster Pedals" Style="{StaticResource SectionHeader}"/>
                        <TextBlock TextWrapping="Wrap" Foreground="Gray" FontSize="11" Margin="0,0,0,12">
                            Each connected mBooster appears below. Pick a role (Throttle/Brake/Clutch) per device to route its
                            pedal position. Effects are host-rendered per the documented protocol — enable each effect you want
                            to feel and adjust its intensity. The Calibration section is experimental and may not be honored by
                            mBooster firmware.
                        </TextBlock>

                        <!-- Device selector -->
                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <TextBlock Text="Device" Style="{StaticResource SliderLabel}"/>
                            <ComboBox x:Name="MBoosterDeviceCombo" Width="320" SelectionChanged="MBoosterDeviceCombo_Changed"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <Ellipse x:Name="MBoosterStatusDot" Style="{StaticResource ConnectionDot}" Fill="Gray"/>
                            <TextBlock x:Name="MBoosterStatusLabel" Text="No mBooster connected" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Per-device panel -->
                        <StackPanel x:Name="MBoosterDevicePanel" Visibility="Collapsed">
                            <TextBlock Text="Pedal Role" Style="{StaticResource SectionHeader}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <TextBlock Text="Role" Style="{StaticResource SliderLabel}"/>
                                <ComboBox x:Name="MBoosterRoleCombo" Width="160" SelectionChanged="MBoosterRoleCombo_Changed">
                                    <ComboBoxItem Content="Disabled"  Tag="0"/>
                                    <ComboBoxItem Content="Throttle"  Tag="1"/>
                                    <ComboBoxItem Content="Brake"     Tag="2"/>
                                    <ComboBoxItem Content="Clutch"    Tag="3"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <TextBlock Text="Position" Style="{StaticResource SliderLabel}"/>
                                <ProgressBar x:Name="MBoosterPositionBar" Width="220" Height="14" Minimum="0" Maximum="100" Value="0"/>
                                <TextBlock x:Name="MBoosterPositionLabel" Style="{StaticResource SliderValue}" Text="0 %"/>
                            </StackPanel>

                            <!-- Effects -->
                            <TextBlock Text="Effects" Style="{StaticResource SectionHeader}"/>
                            <TextBlock Foreground="Gray" FontSize="11" Margin="0,0,0,8" TextWrapping="Wrap">
                                Effect triggers (per protocol note): ABS fires on the game's ABS-active signal; Lockup fires under heavy braking
                                (brake &gt; 0.8); Threshold fires on a rising-edge of brake pressure (0.6 → release at 0.3); Engine runs continuously
                                from RPM. Engine intensity is automatically clamped to 10 % at the apply layer (engine runs continuously, much
                                louder than the others).
                            </TextBlock>

                            <Expander Header="ABS" IsExpanded="True">
                                <StackPanel Margin="8,4">
                                    <StackPanel Orientation="Horizontal" Margin="0,4">
                                        <CheckBox x:Name="MBoosterAbsEnable" Content="Enable" VerticalAlignment="Center" Width="120" Checked="MBoosterAbsEnable_Changed" Unchecked="MBoosterAbsEnable_Changed"/>
                                        <Slider x:Name="MBoosterAbsIntensity" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="MBoosterAbsIntensity_ValueChanged"/>
                                        <TextBlock x:Name="MBoosterAbsIntensityValue" Style="{StaticResource SliderValue}" Text="50"/>
                                        <Button x:Name="MBoosterAbsTest" Content="Test 1s" Margin="6,0,0,0" Padding="10,2" Click="MBoosterAbsTest_Click"/>
                                    </StackPanel>
                                </StackPanel>
                            </Expander>
                            <Expander Header="Lockup" IsExpanded="True">
                                <StackPanel Margin="8,4">
                                    <StackPanel Orientation="Horizontal" Margin="0,4">
                                        <CheckBox x:Name="MBoosterLockupEnable" Content="Enable" VerticalAlignment="Center" Width="120" Checked="MBoosterLockupEnable_Changed" Unchecked="MBoosterLockupEnable_Changed"/>
                                        <Slider x:Name="MBoosterLockupIntensity" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="MBoosterLockupIntensity_ValueChanged"/>
                                        <TextBlock x:Name="MBoosterLockupIntensityValue" Style="{StaticResource SliderValue}" Text="50"/>
                                        <Button x:Name="MBoosterLockupTest" Content="Test 1s" Margin="6,0,0,0" Padding="10,2" Click="MBoosterLockupTest_Click"/>
                                    </StackPanel>
                                </StackPanel>
                            </Expander>
                            <Expander Header="Threshold" IsExpanded="True">
                                <StackPanel Margin="8,4">
                                    <StackPanel Orientation="Horizontal" Margin="0,4">
                                        <CheckBox x:Name="MBoosterThresholdEnable" Content="Enable" VerticalAlignment="Center" Width="120" Checked="MBoosterThresholdEnable_Changed" Unchecked="MBoosterThresholdEnable_Changed"/>
                                        <Slider x:Name="MBoosterThresholdIntensity" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="MBoosterThresholdIntensity_ValueChanged"/>
                                        <TextBlock x:Name="MBoosterThresholdIntensityValue" Style="{StaticResource SliderValue}" Text="50"/>
                                        <Button x:Name="MBoosterThresholdTest" Content="Test 1s" Margin="6,0,0,0" Padding="10,2" Click="MBoosterThresholdTest_Click"/>
                                    </StackPanel>
                                </StackPanel>
                            </Expander>
                            <Expander Header="Engine (continuous — auto-clamped to 10%)" IsExpanded="False">
                                <StackPanel Margin="8,4">
                                    <StackPanel Orientation="Horizontal" Margin="0,4">
                                        <CheckBox x:Name="MBoosterEngineEnable" Content="Enable" VerticalAlignment="Center" Width="120" Checked="MBoosterEngineEnable_Changed" Unchecked="MBoosterEngineEnable_Changed"/>
                                        <Slider x:Name="MBoosterEngineIntensity" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="MBoosterEngineIntensity_ValueChanged"/>
                                        <TextBlock x:Name="MBoosterEngineIntensityValue" Style="{StaticResource SliderValue}" Text="50"/>
                                        <Button x:Name="MBoosterEngineTest" Content="Test 1s" Margin="6,0,0,0" Padding="10,2" Click="MBoosterEngineTest_Click"/>
                                    </StackPanel>
                                </StackPanel>
                            </Expander>

                            <Expander Header="Calibration (experimental — may not be honored by mBooster firmware)" IsExpanded="False" Margin="0,12,0,0">
                                <StackPanel Margin="8,4">
                                    <TextBlock TextWrapping="Wrap" Foreground="Goldenrod" FontSize="11" Margin="0,0,0,8">
                                        The pedal-config command surface (direction / min / max / 5-point curve) is from the standard Moza pedal
                                        protocol. Whether mBooster firmware acknowledges these reads/writes is unverified — your changes may
                                        appear to take effect locally but be silently ignored by the device. Use "Read from device" to check
                                        whether values come back at all.
                                    </TextBlock>
                                    <StackPanel Orientation="Horizontal" Margin="0,4">
                                        <CheckBox x:Name="MBoosterDirCheck" Content="Reversed direction" Checked="MBoosterDirCheck_Changed" Unchecked="MBoosterDirCheck_Changed"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,4">
                                        <TextBlock Text="Min (raw)" Style="{StaticResource SliderLabel}"/>
                                        <Slider x:Name="MBoosterMinSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="65535" TickFrequency="1024" ValueChanged="MBoosterMinSlider_ValueChanged"/>
                                        <TextBlock x:Name="MBoosterMinValue" Style="{StaticResource SliderValue}" Text="0"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,4">
                                        <TextBlock Text="Max (raw)" Style="{StaticResource SliderLabel}"/>
                                        <Slider x:Name="MBoosterMaxSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="65535" TickFrequency="1024" ValueChanged="MBoosterMaxSlider_ValueChanged"/>
                                        <TextBlock x:Name="MBoosterMaxValue" Style="{StaticResource SliderValue}" Text="0"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,8">
                                        <Button x:Name="MBoosterReadCalButton" Content="Read from device" Padding="12,4" Margin="0,0,6,0" Click="MBoosterReadCalButton_Click"/>
                                        <Button x:Name="MBoosterApplyCalButton" Content="Apply" Padding="12,4" Click="MBoosterApplyCalButton_Click"/>
                                    </StackPanel>
                                </StackPanel>
                            </Expander>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ==================== HUB TAB ==================== -->
            <TabItem x:Name="HubTab" Header="Hub" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                    <StackPanel Margin="5">

                        <TextBlock Text="Universal Hub" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Text="Port connection status reported by the hub. Polled every 2 seconds."
                                   Foreground="Gray" FontSize="11" Margin="0,0,0,12" TextWrapping="Wrap"/>

                        <!-- Pedals Port -->
                        <TextBlock Text="Pedals" Style="{StaticResource SectionHeader}" Margin="0,4,0,8"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <Ellipse x:Name="HubPedals1Dot" Style="{StaticResource ConnectionDot}" Fill="Gray"/>
                            <TextBlock Text="Pedals Port" Style="{StaticResource SliderLabel}"/>
                            <TextBlock x:Name="HubPedals1Label" Text="--" FontFamily="Consolas"/>
                        </StackPanel>

                        <!-- Accessory Ports -->
                        <TextBlock Text="Accessories" Style="{StaticResource SectionHeader}" Margin="0,12,0,8"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <Ellipse x:Name="HubPort1Dot" Style="{StaticResource ConnectionDot}" Fill="Gray"/>
                            <TextBlock Text="Port 1" Style="{StaticResource SliderLabel}"/>
                            <TextBlock x:Name="HubPort1Label" Text="--" FontFamily="Consolas"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <Ellipse x:Name="HubPort2Dot" Style="{StaticResource ConnectionDot}" Fill="Gray"/>
                            <TextBlock Text="Port 2" Style="{StaticResource SliderLabel}"/>
                            <TextBlock x:Name="HubPort2Label" Text="--" FontFamily="Consolas"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <Ellipse x:Name="HubPort3Dot" Style="{StaticResource ConnectionDot}" Fill="Gray"/>
                            <TextBlock Text="Port 3" Style="{StaticResource SliderLabel}"/>
                            <TextBlock x:Name="HubPort3Label" Text="--" FontFamily="Consolas"/>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ==================== OPTIONS TAB ==================== -->
            <TabItem Header="Options">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                    <StackPanel Margin="5">

                        <TextBlock Text="Profiles" Style="{StaticResource SectionHeader}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,8">
                            <TextBlock Text="Apply profile settings on launch" Style="{StaticResource SliderLabel}"/>
                            <CheckBox x:Name="AutoApplyProfileCheck" VerticalAlignment="Center"
                                      Checked="AutoApplyProfileCheck_Changed" Unchecked="AutoApplyProfileCheck_Changed"/>
                        </StackPanel>

                        <TextBlock Text="Wheel LED Output (RPM / Buttons)" Style="{StaticResource SectionHeader}"/>
                        <TextBlock TextWrapping="Wrap" Foreground="Gray" FontSize="11" Margin="0,0,0,8"
                                   Text="Recommended: leave LED options below OFF unless you experience LED issues."/>
                        <StackPanel Orientation="Horizontal" Margin="0,8">
                            <TextBlock Text="Limit updates to wheel" Style="{StaticResource SliderLabel}"/>
                            <CheckBox x:Name="LimitWheelUpdatesCheck" VerticalAlignment="Center"
                                      Checked="LimitWheelUpdatesCheck_Changed" Unchecked="LimitWheelUpdatesCheck_Changed"/>
                        </StackPanel>
                        <TextBlock Text="Only send LED data when it actually changes."
                                   Foreground="Gray" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"/>
                        <StackPanel Orientation="Horizontal" Margin="0,8">
                            <TextBlock Text="Always resend bitmask" Style="{StaticResource SliderLabel}"/>
                            <CheckBox x:Name="AlwaysResendBitmaskCheck" VerticalAlignment="Center"
                                      Checked="AlwaysResendBitmaskCheck_Changed" Unchecked="AlwaysResendBitmaskCheck_Changed"/>
                        </StackPanel>
                        <TextBlock Text="Always send the LED bitmask with color updates, even if unchanged. Causes extra traffic so do not use unless required."
                                   Foreground="Gray" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"/>

                        <TextBlock Text="USB Detection" Style="{StaticResource SectionHeader}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,8">
                            <TextBlock Text="Disable serial-probe fallback (advanced)" Style="{StaticResource SliderLabel}"/>
                            <CheckBox x:Name="DisableSerialProbeFallbackCheck" VerticalAlignment="Center"
                                      Checked="DisableSerialProbeFallbackCheck_Changed" Unchecked="DisableSerialProbeFallbackCheck_Changed"/>
                        </StackPanel>
                        <TextBlock Text="Default behaviour: Moza devices are discovered via Windows USB enumeration. If that returns nothing (Wine/Proton without USB enumeration, driver missing) the plugin falls back to writing a Moza protocol probe to every COM port. Check this to forbid the probe entirely — guarantees no Moza writes to non-Moza serial devices, but Moza hardware won't be found on systems where the registry path is unavailable."
                                   Foreground="Gray" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"/>

                        <StackPanel Orientation="Horizontal" Margin="0,8">
                            <TextBlock Text="Disable AB9 active-shifter detection" Style="{StaticResource SliderLabel}"/>
                            <CheckBox x:Name="DisableAb9DetectionCheck" VerticalAlignment="Center"
                                      Checked="DisableAb9DetectionCheck_Changed" Unchecked="DisableAb9DetectionCheck_Changed"/>
                        </StackPanel>
                        <TextBlock Text="Skip the AB9 reconnect probe. Auto-skipped already whenever the MOZA USB registry path returns empty (Wine/Proton), because the COM-port sweep that runs in that mode can lock up SimHub. Check this to skip the probe explicitly on any system. The wheelbase probe fallback is unaffected."
                                   Foreground="Gray" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"/>

                        <TextBlock Text="Dashboard Telemetry" Style="{StaticResource SectionHeader}"/>
                        <!-- Hidden: dashboard upload/download UI is collapsed while the feature is in
                             development. Runtime values are forced off in MozaPlugin (Init cache wiring
                             and ApplyTelemetrySettings); underlying settings, handlers, and the
                             upload/download scaffolding are intentionally preserved. Un-collapse this
                             StackPanel and revert the forced-false consumption sites to re-enable. -->
                        <StackPanel Visibility="Collapsed">
                            <CheckBox x:Name="UploadDashboardCheck" Content="Upload dashboard on connect"
                                      Margin="0,8,0,4" Checked="UploadDashboard_Changed" Unchecked="UploadDashboard_Changed"/>
                            <TextBlock TextWrapping="Wrap" Foreground="Gray" FontSize="11" Margin="0,0,0,8"
                                       Text="Attempt to upload selected mzdash file.  Experimental."/>
                            <CheckBox x:Name="DownloadDashboardCheck" Content="Download dashboards from wheel"
                                      Margin="0,8,0,4" Checked="DownloadDashboard_Changed" Unchecked="DownloadDashboard_Changed"/>
                            <TextBlock TextWrapping="Wrap" Foreground="Gray" FontSize="11" Margin="0,0,0,8"
                                       Text="Download dashboard files stored on the wheel.  Experimental."/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="Wheel firmware era:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox x:Name="FirmwareEraCombo" Width="500"
                                      SelectionChanged="FirmwareEra_Changed">
                                <ComboBoxItem Content="Auto — Attempt to detect from wheel handshake"/>
                                <ComboBoxItem Content="2024 era — (URL subscription)"/>
                                <ComboBoxItem Content="2025 era — VGS"/>
                                <ComboBoxItem Content="2026 era — CSP/KSP"/>
                            </ComboBox>
                        </StackPanel>
                        <TextBlock TextWrapping="Wrap" Foreground="Gray" FontSize="11" Margin="0,2,0,8"
                                   Text="Auto detects the wheel's firmware era from its handshake (catalog push and identity) and picks the matching wire protocol. Override only if telemetry stays broken — pick the era that matches your wheel hardware. Telemetry restarts automatically on change."/>

                        <TextBlock Text="Reset" Style="{StaticResource SectionHeader}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,8">
                            <Button x:Name="ClearAllSettingsButton" Content="Clear All Settings &amp; Profiles"
                                    Padding="12,4" Click="ClearAllSettingsButton_Click"/>
                        </StackPanel>
                        <TextBlock Text="This will reset all plugin settings and profiles to their defaults."
                                   Foreground="Gray" FontSize="11" Margin="0,4,0,0"/>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Upload">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10,5">

                        <!-- Work-in-progress banner: dashboard upload isn't functional yet
                             on current firmware. Wheel never opens the file-transfer ack
                             channel (sess=0x04) in response to our connect handshake, so
                             the type=0x01 ready ack never arrives and the upload times out.
                             Investigation tools live in tools/causal-diff-sess04,
                             tools/pre-sess04-traffic-inventory, tools/grp0e-register-scan.
                             Banner stays until upload completes end-to-end on at least one
                             wheel + firmware combo. -->
                        <Border Background="#3D2E00" BorderBrush="#FFB300" BorderThickness="2"
                                CornerRadius="3" Padding="12,10" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock FontSize="16" FontWeight="Bold" Foreground="#FFD54F"
                                           Text="⚠  Not working yet"/>
                                <TextBlock TextWrapping="Wrap" Foreground="#FFE082" FontSize="11" Margin="0,4,0,0"
                                           Text="Dashboard upload is in development and does NOT currently push files to the wheel. The UI here builds the upload bundle and starts the handshake, but the wheel doesn't engage the file-transfer state machine on our connect sequence, so the upload times out without writing anything. Nothing here is destructive — the button is safe to click, it just won't apply your dashboard. Use PitHouse for real uploads in the meantime."/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Dashboard Upload" Style="{StaticResource SectionHeader}"/>
                        <TextBlock TextWrapping="Wrap" Foreground="Gray" FontSize="11" Margin="0,0,0,8"
                                   Text="Push a .mzdash file to the connected wheel. Pick a local file or choose from the dashboard library (wheel-cached + folder + builtin), then click Upload now. Status reflects the latest wheel ack sub-msg (type=0x01 progress / type=0x11 complete) — bytes_written should rise toward total_size and end equal on a clean upload."/>

                        <!-- Source: file picker -->
                        <TextBlock Text="Source" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <RadioButton x:Name="UploadSourceFileRadio" Content="Local .mzdash file"
                                         GroupName="UploadSource" IsChecked="True"
                                         Margin="0,0,16,0" VerticalAlignment="Center"
                                         Click="UploadSourceRadio_Click"/>
                            <RadioButton x:Name="UploadSourceLibraryRadio" Content="Dashboard library"
                                         GroupName="UploadSource"
                                         VerticalAlignment="Center"
                                         Click="UploadSourceRadio_Click"/>
                        </StackPanel>

                        <StackPanel x:Name="UploadFilePanel" Orientation="Horizontal" Margin="0,0,0,6">
                            <Button Content="Pick .mzdash…" Padding="6,2" Margin="0,0,8,0"
                                    Click="UploadPickFile_Click"/>
                            <TextBlock x:Name="UploadPickedFileText" VerticalAlignment="Center"
                                       Foreground="Gray" FontSize="11"
                                       Text="(no file selected)" TextTrimming="CharacterEllipsis"
                                       MaxWidth="500"/>
                        </StackPanel>

                        <StackPanel x:Name="UploadLibraryPanel" Orientation="Horizontal" Margin="0,0,0,6"
                                    Visibility="Collapsed">
                            <TextBlock Text="Dashboard:" VerticalAlignment="Center" Width="100"/>
                            <ComboBox x:Name="UploadLibraryCombo" Width="280" Margin="0,0,8,0"
                                      SelectionChanged="UploadLibraryCombo_SelectionChanged"/>
                            <Button Content="Refresh list" Padding="6,2"
                                    Click="UploadLibraryRefresh_Click"/>
                        </StackPanel>

                        <!-- Action + status -->
                        <Separator Margin="0,8,0,8"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Button x:Name="UploadNowButton" Content="Upload now" Padding="10,3"
                                    MinWidth="120" Click="UploadNow_Click"/>
                            <TextBlock x:Name="UploadStatusText" VerticalAlignment="Center"
                                       Foreground="Gray" FontSize="11" Margin="12,0,0,0"
                                       Text="idle"/>
                        </StackPanel>

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Dashboard name:" Foreground="Gray" FontSize="11" Margin="0,2"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="UploadInfoNameText"
                                       FontFamily="Consolas" FontSize="11" Margin="0,2" Text="—"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Raw size:" Foreground="Gray" FontSize="11" Margin="0,2"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="UploadInfoRawSizeText"
                                       FontFamily="Consolas" FontSize="11" Margin="0,2" Text="—"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="MD5:" Foreground="Gray" FontSize="11" Margin="0,2"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="UploadInfoMd5Text"
                                       FontFamily="Consolas" FontSize="11" Margin="0,2" Text="—"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="In flight:" Foreground="Gray" FontSize="11" Margin="0,2"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="UploadInfoInFlightText"
                                       FontFamily="Consolas" FontSize="11" Margin="0,2" Text="—"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Last ack bytes_written / total:" Foreground="Gray" FontSize="11" Margin="0,2"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" x:Name="UploadInfoProgressText"
                                       FontFamily="Consolas" FontSize="11" Margin="0,2" Text="—"/>

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Last ack status byte:" Foreground="Gray" FontSize="11" Margin="0,2"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" x:Name="UploadInfoStatusByteText"
                                       FontFamily="Consolas" FontSize="11" Margin="0,2" Text="—"/>
                        </Grid>

                        <TextBlock TextWrapping="Wrap" Foreground="Gray" FontSize="11" Margin="0,12,0,0"
                                   Text="Note: Uploads require the wheel to be connected and a management session negotiated. PNG resources referenced by widgets are not yet bundled — single-file mzdash uploads only (Gap 2 of the upload protocol implementation plan)."/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Wheel Files">
                <DockPanel Margin="10,5">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Wheel Files" Style="{StaticResource SectionHeader}" Margin="0,0,16,0"/>
                        <Button x:Name="WheelFilesRefreshButton" Content="Refresh" Padding="6,2"
                                Click="WheelFilesRefresh_Click" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock x:Name="WheelFilesStatusBox" VerticalAlignment="Center"
                                   Foreground="Gray" FontSize="11" Text="—"/>
                    </StackPanel>
                    <TextBlock DockPanel.Dock="Top" TextWrapping="Wrap" Foreground="Gray" FontSize="11" Margin="0,0,0,8"
                               Text="Dashboards the wheel reports via session 0x09 configJson state. Delete is temporarily disabled — the `completelyRemove` RPC currently wedges firmware until the wheelbase is power-cycled. List refreshes after every upload + on connect."/>
                    <DataGrid x:Name="WheelFilesGrid" AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False" CanUserDeleteRows="False" CanUserResizeRows="False"
                              SelectionMode="Single" HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              BorderThickness="1" RowHeight="22">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="State" Binding="{Binding State}" Width="70"/>
                            <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="*"/>
                            <DataGridTextColumn Header="DirName" Binding="{Binding DirName}" Width="200"/>
                            <DataGridTextColumn Header="Hash" Binding="{Binding HashShort}" Width="100"/>
                            <DataGridTextColumn Header="Last modified" Binding="{Binding LastModified}" Width="160"/>
                            <DataGridTemplateColumn Header="" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Delete" Padding="6,1"
                                                Click="WheelFilesDelete_Click"
                                                Tag="{Binding}"
                                                IsEnabled="False"
                                                ToolTip="Disabled — completelyRemove RPC currently wedges wheel firmware until the wheelbase is power-cycled."/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <TabItem Header="Diagnostics">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10,5">
                        <!-- Serial traffic capture -->
                        <TextBlock Text="Serial traffic capture" Style="{StaticResource SectionHeader}"/>
                        <TextBlock TextWrapping="Wrap" Foreground="Gray" FontSize="11" Margin="0,0,0,8"
                                   Text="Records every TX/RX frame on the wheelbase and AB9 serial pipes with timestamps. Data lives in memory only — nothing is saved between SimHub launches. Click Stop to view the buffer; click Export to save a ZIP bundle (capture log + diagnostics dump + [Moza] log lines)."/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Button x:Name="SerialCaptureToggleButton" Content="Start capture" Padding="6,2"
                                    Click="SerialCaptureToggle_Click" MinWidth="120"/>
                            <TextBlock x:Name="SerialCaptureStatusText" Text="idle" VerticalAlignment="Center"
                                       Margin="10,0,0,0" Foreground="Gray" FontSize="11"/>
                        </StackPanel>

                        <CheckBox x:Name="StartCaptureOnNextLaunchCheck"
                                  Content="Start capture on next launch (one-shot — auto-clears after firing)"
                                  Click="StartCaptureOnNextLaunch_Click"
                                  Margin="0,0,0,8"
                                  ToolTip="Arms the capture so it begins immediately when the plugin re-initializes (next SimHub launch or plugin reload). Useful for catching connect/handshake traffic that's hard to arm in time manually."/>

                        <TextBox x:Name="SerialCaptureOutputBox" FontFamily="Consolas" FontSize="11"
                                 IsReadOnly="True" TextWrapping="NoWrap" AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                 Height="220" Margin="0,0,0,6" Visibility="Collapsed"/>

                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="SerialCaptureExportButton" Content="Export bundle (ZIP)…"
                                    Padding="6,2" Click="SerialCaptureExport_Click" IsEnabled="False"/>
                            <Button x:Name="SerialCaptureCopyButton" Content="Copy capture to clipboard"
                                    Padding="6,2" Click="SerialCaptureCopy_Click"
                                    Margin="6,0,0,0" IsEnabled="False"/>
                        </StackPanel>

                        <Separator Margin="0,12,0,8"/>

                        <TextBlock Text="Diagnostics" Style="{StaticResource SectionHeader}"/>
                        <TextBlock TextWrapping="Wrap" Foreground="Gray" FontSize="11" Margin="0,0,0,8"
                                   Text="Live dump of wheel identity, display sub-device identity, dashboard state from the wheel's configJson RPC, and session/connection info. Refreshes ~1/s."/>

                        <!-- Plugin info -->
                        <TextBlock Text="Plugin" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBlock x:Name="DiagPluginBox" FontFamily="Consolas" FontSize="11"
                                   TextWrapping="Wrap" Text="—" Margin="0,0,0,10"/>

                        <Separator Margin="0,4,0,8"/>

                        <!-- USB detection (registry-based discovery) -->
                        <TextBlock Text="USB detection" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBlock x:Name="DiagUsbDetectionBox" FontFamily="Consolas" FontSize="11"
                                   TextWrapping="Wrap" Text="—" Margin="0,0,0,10"/>

                        <Separator Margin="0,4,0,8"/>

                        <!-- Wheel identity -->
                        <TextBlock Text="Wheel identity" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBlock x:Name="DiagWheelIdentityBox" FontFamily="Consolas" FontSize="11"
                                   TextWrapping="Wrap" Text="—" Margin="0,0,0,10"/>

                        <Separator Margin="0,4,0,8"/>

                        <!-- Display sub-device identity -->
                        <TextBlock Text="Display sub-device identity" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBlock x:Name="DiagDisplayIdentityBox" FontFamily="Consolas" FontSize="11"
                                   TextWrapping="Wrap" Text="—" Margin="0,0,0,10"/>

                        <Separator Margin="0,4,0,8"/>

                        <!-- Dashboard state (session 0x09 configJson RPC) -->
                        <TextBlock Text="Wheel dashboard state (session 0x09)" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBlock x:Name="DiagDashboardStateBox" FontFamily="Consolas" FontSize="11"
                                   TextWrapping="Wrap" Text="—" Margin="0,0,0,10"/>

                        <Separator Margin="0,4,0,8"/>

                        <!-- Tile-server state (session 0x03, if received) -->
                        <TextBlock Text="Tile-server state (session 0x03)" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBlock x:Name="DiagTileServerBox" FontFamily="Consolas" FontSize="11"
                                   TextWrapping="Wrap" Text="—" Margin="0,0,0,10"/>

                        <Separator Margin="0,4,0,8"/>

                        <!-- Session / connection -->
                        <TextBlock Text="Session state" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBlock x:Name="DiagSessionBox" FontFamily="Consolas" FontSize="11"
                                   TextWrapping="Wrap" Text="—" Margin="0,0,0,10"/>

                        <Separator Margin="0,4,0,8"/>

                        <TextBlock Text="Wheel channel catalog" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBlock x:Name="DiagWheelCatalogBox" FontFamily="Consolas" FontSize="11"
                                   TextWrapping="Wrap" Text="—" Margin="0,0,0,10"/>

                        <Separator Margin="0,4,0,8"/>

                        <TextBlock Text="Last subscription sent" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBlock x:Name="DiagSubscriptionBox" FontFamily="Consolas" FontSize="11"
                                   TextWrapping="Wrap" Text="—" Margin="0,0,0,10"/>

                        <Separator Margin="0,4,0,8"/>

                        <TextBlock Text="Wheel response on session 0x02 (5s window after subscription)"
                                   FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBlock x:Name="DiagSubscriptionResponseBox" FontFamily="Consolas" FontSize="11"
                                   TextWrapping="Wrap" Text="—" Margin="0,0,0,10"/>

                        <Button Content="Copy all to clipboard" Padding="6,2"
                                Click="DiagCopyAll_Click" HorizontalAlignment="Left" Margin="0,4,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </DockPanel>
</UserControl>
