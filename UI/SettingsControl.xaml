                                        <TextBlock Text="{x:Static res:Strings.SliderLabel_AutoStandbyTimeout}" Style="{StaticResource SliderLabel}"/>
                                        <ComboBox x:Name="AutoStandbyTimeoutCombo" Width="110" VerticalAlignment="Center"
                                                  SelectionChanged="AutoStandbyTimeoutCombo_Changed">
                                            <ComboBoxItem Tag="0" Content="{x:Static res:Strings.Option_Disabled}"/>
                                            <ComboBoxItem Tag="1" Content="{x:Static res:Strings.Option_Time1Min}"/>
                                            <ComboBoxItem Tag="2" Content="{x:Static res:Strings.Option_Time2Min}"/>
                                            <ComboBoxItem Tag="3" Content="{x:Static res:Strings.Option_Time3Min}"/>
                                            <ComboBoxItem Tag="5" Content="{x:Static res:Strings.Option_Time5Min}"/>
                                            <ComboBoxItem Tag="10" Content="{x:Static res:Strings.Option_Time10Min}"/>
                                            <ComboBoxItem Tag="15" Content="{x:Static res:Strings.Option_Time15Min}"/>
                                            <ComboBoxItem Tag="20" Content="{x:Static res:Strings.Option_Time20Min}"/>
                                            <ComboBoxItem Tag="30" Content="{x:Static res:Strings.Option_Time30Min}"/>
                                            <ComboBoxItem Tag="45" Content="{x:Static res:Strings.Option_Time45Min}"/>
                                            <ComboBoxItem Tag="60" Content="{x:Static res:Strings.Option_Time1Hour}"/>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,8">
                                        <TextBlock Text="{x:Static res:Strings.SliderLabel_BaseStatusLed}" Style="{StaticResource SliderLabel}"/>
                                        <ctrl:OffOnToggle x:Name="LedStatusCheck" VerticalAlignment="Center" Click="LedStatusCheck_Click"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,8">
                                        <TextBlock Text="{x:Static res:Strings.SliderLabel_Bluetooth}" Style="{StaticResource SliderLabel}"/>
                                        <ctrl:OffOnToggle x:Name="BluetoothCheck" VerticalAlignment="Center" Click="BluetoothCheck_Click"/>
                                    </StackPanel>
                                </StackPanel>
                            </ctrl:SectionCard>

                            <ctrl:SectionCard Grid.Column="1" Title="{x:Static res:Strings.Section_HighSpeedDamping}"
                                              Subtitle="{x:Static res:Strings.Subtitle_HighSpeedDamping}"
                                              Icon="{StaticResource IconSpeed}" Margin="7,0,0,14">
                                <StackPanel>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{x:Static res:Strings.SliderLabel_DampingLevel}" Style="{StaticResource SliderLabel}"/>
                                        <Slider Grid.Column="1" x:Name="SpeedDampingSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="SpeedDampingSlider_ValueChanged"/>
                                        <TextBox Grid.Column="2" x:Name="SpeedDampingValue" Style="{StaticResource SliderValueEditBox}"
                                                 Tag="{Binding ElementName=SpeedDampingSlider}"
                                                 KeyDown="SliderValueBox_KeyDown" LostFocus="SliderValueBox_LostFocus"
                                                 Text="0%"/>
                                    </Grid>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{x:Static res:Strings.SliderLabel_TriggerSpeed}" Style="{StaticResource SliderLabel}"/>
                                        <Slider Grid.Column="1" x:Name="SpeedDampingPointSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="400" TickFrequency="10" ValueChanged="SpeedDampingPointSlider_ValueChanged"/>
                                        <TextBox Grid.Column="2" x:Name="SpeedDampingPointValue" Style="{StaticResource SliderValueEditBox}"
                                                 Tag="{Binding ElementName=SpeedDampingPointSlider}"
                                                 KeyDown="SliderValueBox_KeyDown" LostFocus="SliderValueBox_LostFocus"
                                                 Text="120 kph"/>
                                    </Grid>
                                </StackPanel>
                            </ctrl:SectionCard>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ==================== WHEEL TAB (Phase 6: hidden) ====================
                 Wheel-input settings + live paddle/button display now live in the
                 per-device MozaWheelSettingsControl "Inputs" sub-tab. The controls
                 here stay in the visual tree (Visibility=Collapsed) so the device
                 pane can forward user input to them, triggering this code-behind's
                 existing handler + persistence logic. -->
            <TabItem x:Name="WheelTab" Header="{x:Static res:Strings.TabHeader_Wheel}" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                    <StackPanel Margin="5">

                        <!-- Live Input -->
                        <TextBlock Text="{x:Static res:Strings.Section_Paddles}" Style="{StaticResource SectionHeader}"/>
                        <StackPanel x:Name="SplitPaddlePanel" Orientation="Horizontal" Margin="0,0,0,10">
                            <StackPanel Margin="0,0,20,0" Width="100">
                                <TextBlock Text="{x:Static res:Strings.Label_LeftPaddle}" Foreground="Gray" FontSize="11"/>
                                <ProgressBar x:Name="LeftPaddleBar" Height="14" Minimum="0" Maximum="100" Value="0"/>
                            </StackPanel>
                            <StackPanel Width="100">
                                <TextBlock Text="{x:Static res:Strings.Label_RightPaddle}" Foreground="Gray" FontSize="11"/>
                                <ProgressBar x:Name="RightPaddleBar" Height="14" Minimum="0" Maximum="100" Value="0"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel x:Name="CombinedPaddlePanel" Orientation="Horizontal" Margin="0,0,0,10" Visibility="Collapsed">
                            <StackPanel Width="100">
                                <TextBlock Text="{x:Static res:Strings.Label_Combined}" Foreground="Gray" FontSize="11"/>
                                <ProgressBar x:Name="CombinedPaddleBar" Height="14" Minimum="0" Maximum="100" Value="0"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Active Buttons -->
                        <TextBlock Text="{x:Static res:Strings.Section_Buttons}" Style="{StaticResource SectionHeader}" Margin="0,4,0,8"/>
                        <TextBlock x:Name="ActiveButtonsText" FontFamily="Consolas" FontSize="12"
                                   Foreground="Gray" Margin="0,0,0,10" TextWrapping="Wrap">None</TextBlock>

                        <!-- Paddle Settings -->
                        <TextBlock Text="{x:Static res:Strings.Section_PaddleSettings}" Style="{StaticResource SectionHeader}"/>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{x:Static res:Strings.SliderLabel_PaddlesMode}" Style="{StaticResource SliderLabel}"/>
                            <ComboBox Grid.Column="1" x:Name="WheelPaddlesModeCombo" Width="140" SelectionChanged="WheelPaddlesModeCombo_Changed">
                                <ComboBoxItem Content="{x:Static res:Strings.Section_Buttons}"/>
                                <ComboBoxItem Content="{x:Static res:Strings.Label_Combined}"/>
                                <ComboBoxItem Content="{x:Static res:Strings.Option_Split}"/>
                            </ComboBox>
                        </Grid>
                        <Grid x:Name="WheelClutchPointPanel" Margin="0,4" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{x:Static res:Strings.SliderLabel_ClutchSplitPoint}" Style="{StaticResource SliderLabel}"/>
                            <Slider Grid.Column="1" x:Name="WheelClutchPointSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="WheelClutchPointSlider_ValueChanged"/>
                            <TextBox Grid.Column="2" x:Name="WheelClutchPointValue" Style="{StaticResource SliderValueEditBox}"
                                                 Tag="{Binding ElementName=WheelClutchPointSlider}"
                                                 KeyDown="SliderValueBox_KeyDown" LostFocus="SliderValueBox_LostFocus"
                                                 Text="50%"/>
                        </Grid>

                        <!-- Input Settings (knob + stick) -->
                        <TextBlock Text="{x:Static res:Strings.Section_InputSettings}" Style="{StaticResource SectionHeader}"/>
                        <Grid x:Name="KnobModeLegacyPanel" Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{x:Static res:Strings.SliderLabel_RotaryEncoders}" Style="{StaticResource SliderLabel}"/>
                            <ComboBox Grid.Column="1" x:Name="KnobModeCombo" Width="140" SelectionChanged="KnobModeCombo_Changed">
                                <ComboBoxItem Content="{x:Static res:Strings.Section_Buttons}"/>
                                <ComboBoxItem Content="{x:Static res:Strings.Option_Knob}"/>
                            </ComboBox>
                        </Grid>
                        <StackPanel x:Name="KnobSignalModePanel" Visibility="Collapsed">
                            <Grid x:Name="KnobSignalMode0Row" Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{x:Static res:Strings.SliderLabel_Rotary1}" Style="{StaticResource SliderLabel}"/>
                                <ComboBox Grid.Column="1" x:Name="KnobSignalMode0Combo" Width="140" SelectionChanged="KnobSignalMode0Combo_Changed">
                                    <ComboBoxItem Content="{x:Static res:Strings.Section_Buttons}"/><ComboBoxItem Content="{x:Static res:Strings.Option_Knob}"/>
                                </ComboBox>
                            </Grid>
                            <Grid x:Name="KnobSignalMode1Row" Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{x:Static res:Strings.SliderLabel_Rotary2}" Style="{StaticResource SliderLabel}"/>
                                <ComboBox Grid.Column="1" x:Name="KnobSignalMode1Combo" Width="140" SelectionChanged="KnobSignalMode1Combo_Changed">
                                    <ComboBoxItem Content="{x:Static res:Strings.Section_Buttons}"/><ComboBoxItem Content="{x:Static res:Strings.Option_Knob}"/>
                                </ComboBox>
                            </Grid>
                            <Grid x:Name="KnobSignalMode2Row" Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{x:Static res:Strings.SliderLabel_Rotary3}" Style="{StaticResource SliderLabel}"/>
                                <ComboBox Grid.Column="1" x:Name="KnobSignalMode2Combo" Width="140" SelectionChanged="KnobSignalMode2Combo_Changed">
                                    <ComboBoxItem Content="{x:Static res:Strings.Section_Buttons}"/><ComboBoxItem Content="{x:Static res:Strings.Option_Knob}"/>
                                </ComboBox>
                            </Grid>
                            <Grid x:Name="KnobSignalMode3Row" Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{x:Static res:Strings.SliderLabel_Rotary4}" Style="{StaticResource SliderLabel}"/>
                                <ComboBox Grid.Column="1" x:Name="KnobSignalMode3Combo" Width="140" SelectionChanged="KnobSignalMode3Combo_Changed">
                                    <ComboBoxItem Content="{x:Static res:Strings.Section_Buttons}"/><ComboBoxItem Content="{x:Static res:Strings.Option_Knob}"/>
                                </ComboBox>
                            </Grid>
                            <Grid x:Name="KnobSignalMode4Row" Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{x:Static res:Strings.SliderLabel_Rotary5}" Style="{StaticResource SliderLabel}"/>
                                <ComboBox Grid.Column="1" x:Name="KnobSignalMode4Combo" Width="140" SelectionChanged="KnobSignalMode4Combo_Changed">
                                    <ComboBoxItem Content="{x:Static res:Strings.Section_Buttons}"/><ComboBoxItem Content="{x:Static res:Strings.Option_Knob}"/>
                                </ComboBox>
                            </Grid>
                        </StackPanel>
                        <StackPanel x:Name="StickModeOldPanel" Orientation="Horizontal" Margin="0,8" Visibility="Collapsed">
                            <TextBlock Text="{x:Static res:Strings.SliderLabel_StickAsDpad}" Style="{StaticResource SliderLabel}"/>
                            <ctrl:OffOnToggle x:Name="StickModeCheck" VerticalAlignment="Center" Click="StickModeCheck_Click"/>
                        </StackPanel>
                        <Grid x:Name="StickModeNewPanel" Margin="0,8" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{x:Static res:Strings.SliderLabel_JoystickAssignment}" Style="{StaticResource SliderLabel}"/>
                            <ComboBox Grid.Column="1" x:Name="StickModeCombo" Width="120" SelectionChanged="StickModeCombo_Changed">
                                <ComboBoxItem Content="{x:Static res:Strings.Option_None}"/>
                                <ComboBoxItem Content="{x:Static res:Strings.Option_Left}"/>
                                <ComboBoxItem Content="{x:Static res:Strings.Option_Right}"/>
                            </ComboBox>
                        </Grid>

                        <TextBlock TextWrapping="Wrap" Foreground="Gray" FontSize="11" Margin="0,12,0,0"
                                   Text="{x:Static res:Strings.Hint_LedButtonSettingsInDeviceTab}"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ==================== HANDBRAKE TAB ==================== -->
            <TabItem x:Name="HandbrakeTab" Header="{x:Static res:Strings.TabHeader_Handbrake}" Visibility="Collapsed">
                <!-- Red accent for active button-selectors (SegmentedControl
                     selected item, OffOnToggle ON pill). The templates resolve
                     these keys via DynamicResource, so overriding them here
                     tints every active control inside the Handbrake tab. -->
                <TabItem.Resources>
                    <StaticResource x:Key="ToggleOnBrush" ResourceKey="RedToggleOnBrush"/>
                    <SolidColorBrush x:Key="ToggleOnTextBrush" Color="{StaticResource RedColor}"/>
                </TabItem.Resources>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                    <StackPanel Margin="5">

                        <!-- Live Input (POSITION card) + CALIBRATION side-by-side. -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ctrl:SectionCard Grid.Column="0" Title="{x:Static res:Strings.Section_Position}"
                                              Subtitle="{x:Static res:Strings.Subtitle_LiveHandbrakeInput}"
                                              Icon="{StaticResource IconHandbrake}"
                                              AccentBrush="{StaticResource RedBrush}"
                                              Margin="0,0,7,14">
                                <StackPanel>
                                    <StackPanel x:Name="HandbrakeAxisPanel" Margin="0,4">
                                        <TextBlock Text="{x:Static res:Strings.Label_Position}" Style="{StaticResource MutedHintText}" Margin="0,0,0,4"/>
                                        <ProgressBar x:Name="HandbrakeBar" Height="14" Minimum="0" Maximum="100" Value="0"
                                                     HorizontalAlignment="Stretch"/>
                                    </StackPanel>
                                    <TextBlock x:Name="HandbrakeButtonStatus" FontFamily="Consolas" FontSize="14"
                                               FontWeight="Normal" Margin="0,4" Visibility="Collapsed">Released</TextBlock>
                                </StackPanel>
                            </ctrl:SectionCard>

                            <ctrl:SectionCard Grid.Column="1" Title="{x:Static res:Strings.Section_Calibration}"
                                              Subtitle="{x:Static res:Strings.Subtitle_PullHandbrakeFully}"
                                              Icon="{StaticResource IconCal}"
                                              AccentBrush="{StaticResource RedBrush}"
                                              Margin="7,0,0,14">
                                <StackPanel Margin="0,4">
                                    <Button x:Name="HbCalStartButton" Content="{x:Static res:Strings.Button_StartCalibration}" HorizontalAlignment="Left" Click="HbCalStartButton_Click"/>
                                    <TextBlock x:Name="HbCalStatus" Style="{StaticResource MutedHintText}" TextWrapping="Wrap" Margin="0,6,0,0" Visibility="Collapsed"/>
                                </StackPanel>
                            </ctrl:SectionCard>
                        </Grid>

                        <!-- Handbrake Settings + Range side-by-side. -->
                        <!-- HANDBRAKE SETTINGS (mode/threshold/direction + range) on the left,
                             OUTPUT CURVE on the right. Mirrors the BRAKE page's combined
                             "Direction & Range" card style. -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ctrl:SectionCard Grid.Column="0" Title="{x:Static res:Strings.Section_HandbrakeSettings}"
                                              Icon="{StaticResource IconHandbrake}"
                                              AccentBrush="{StaticResource RedBrush}" Margin="0,0,7,14">
                                <StackPanel>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{x:Static res:Strings.SliderLabel_Mode}" Style="{StaticResource SliderLabel}"/>
                                        <ctrl:SegmentedControl Grid.Column="1" x:Name="HandbrakeModeCombo"
                                                               HorizontalAlignment="Left"
                                                               SelectionChanged="HandbrakeModeCombo_Changed">
                                            <ListBoxItem Content="{x:Static res:Strings.Option_Axis}"/>
                                            <ListBoxItem Content="{x:Static res:Strings.Option_Button}"/>
                                        </ctrl:SegmentedControl>
                                    </Grid>
                                    <Grid x:Name="HandbrakeThresholdPanel" Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{x:Static res:Strings.SliderLabel_ButtonThreshold}" Style="{StaticResource SliderLabel}"/>
                                        <Slider Grid.Column="1" x:Name="HandbrakeThresholdSlider" Style="{StaticResource RedSettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="HandbrakeThresholdSlider_ValueChanged"/>
                                        <TextBox Grid.Column="2" x:Name="HandbrakeThresholdValue" Style="{StaticResource RedSliderValueEditBox}"
                                                     Tag="{Binding ElementName=HandbrakeThresholdSlider}"
                                                     KeyDown="SliderValueBox_KeyDown" LostFocus="SliderValueBox_LostFocus"
                                                     Text="50%"/>
                                    </Grid>
                                    <StackPanel Orientation="Horizontal" Margin="0,8">
                                        <TextBlock Text="{x:Static res:Strings.SliderLabel_ReverseDirection}" Style="{StaticResource SliderLabel}"/>
                                        <ctrl:OffOnToggle x:Name="HandbrakeDirectionCheck" VerticalAlignment="Center" Click="HandbrakeDirectionCheck_Click"/>
                                    </StackPanel>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{x:Static res:Strings.SliderLabel_RangeStart}" Style="{StaticResource SliderLabel}"/>
                                        <Slider Grid.Column="1" x:Name="HandbrakeMinSlider" Style="{StaticResource RedSettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="HandbrakeMinSlider_ValueChanged"/>
                                        <TextBox Grid.Column="2" x:Name="HandbrakeMinValue" Style="{StaticResource RedSliderValueEditBox}"
                                                     Tag="{Binding ElementName=HandbrakeMinSlider}"
                                                     KeyDown="SliderValueBox_KeyDown" LostFocus="SliderValueBox_LostFocus"
                                                     Text="0%"/>
                                    </Grid>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{x:Static res:Strings.SliderLabel_RangeEnd}" Style="{StaticResource SliderLabel}"/>
                                        <Slider Grid.Column="1" x:Name="HandbrakeMaxSlider" Style="{StaticResource RedSettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="HandbrakeMaxSlider_ValueChanged"/>
                                        <TextBox Grid.Column="2" x:Name="HandbrakeMaxValue" Style="{StaticResource RedSliderValueEditBox}"
                                                     Tag="{Binding ElementName=HandbrakeMaxSlider}"
                                                     KeyDown="SliderValueBox_KeyDown" LostFocus="SliderValueBox_LostFocus"
                                                     Text="100%"/>
                                    </Grid>
                                </StackPanel>
                            </ctrl:SectionCard>

                            <ctrl:SectionCard Grid.Column="1" Title="{x:Static res:Strings.Section_OutputCurve}"
                                              Subtitle="{x:Static res:Strings.Subtitle_MapPhysicalPullToGame}"
                                              Icon="{StaticResource IconCurve}"
                                              AccentBrush="{StaticResource RedBrush}" Margin="7,0,0,14">
                                <StackPanel>
                                    <ctrl:MozaCurveEditor x:Name="HandbrakeCurveEditor" Height="260"
                                                          AccentBrush="{StaticResource RedBrush}"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                        <Button Content="{x:Static res:Strings.Button_Linear}" Margin="0,0,8,0" Click="HbCurvePreset_Linear"/>
                                        <Button Content="{x:Static res:Strings.Button_SCurve}" Margin="0,0,8,0" Click="HbCurvePreset_SCurve"/>
                                        <Button Content="{x:Static res:Strings.Button_Exponential}" Margin="0,0,8,0" Click="HbCurvePreset_Exponential"/>
                                        <Button Content="{x:Static res:Strings.Button_Parabolic}" Click="HbCurvePreset_Parabolic"/>
                                    </StackPanel>
                                </StackPanel>
                            </ctrl:SectionCard>
                        </Grid>

                        <!-- Data-store sliders, driven by HandbrakeCurveEditor -->
                        <StackPanel Visibility="Collapsed">
                            <Slider x:Name="HbY1Slider" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="HbY1Slider_ValueChanged"/>
                            <TextBox x:Name="HbY1Value" Text="20"/>
                            <Slider x:Name="HbY2Slider" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="HbY2Slider_ValueChanged"/>
                            <TextBox x:Name="HbY2Value" Text="40"/>
                            <Slider x:Name="HbY3Slider" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="HbY3Slider_ValueChanged"/>
                            <TextBox x:Name="HbY3Value" Text="60"/>
                            <Slider x:Name="HbY4Slider" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="HbY4Slider_ValueChanged"/>
                            <TextBox x:Name="HbY4Value" Text="80"/>
                            <Slider x:Name="HbY5Slider" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="HbY5Slider_ValueChanged"/>
                            <TextBox x:Name="HbY5Value" Text="100"/>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ==================== PEDALS TAB ==================== -->
            <TabItem x:Name="PedalsTab" Header="{x:Static res:Strings.TabHeader_Pedals}" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="22,18,22,8">
                    <StackPanel>

                        <!-- Live Input (3 colored bars stacked horizontally) -->
                        <Border Background="{StaticResource BgCardBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1" CornerRadius="8"
                                Padding="18,14" Margin="0,0,0,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="{x:Static res:Strings.Label_Throttle}" Style="{StaticResource MutedHintText}" Margin="0,0,0,4"/>
                                    <ProgressBar x:Name="ThrottleBar" Height="14" Minimum="0" Maximum="100" Value="0"
                                                 Foreground="{StaticResource GreenBrush}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="4,0">
                                    <TextBlock Text="{x:Static res:Strings.Label_Brake}" Style="{StaticResource MutedHintText}" Margin="0,0,0,4"/>
                                    <ProgressBar x:Name="BrakeBar" Height="14" Minimum="0" Maximum="100" Value="0"
                                                 Foreground="{StaticResource RedBrush}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Margin="8,0,0,0">
                                    <TextBlock Text="{x:Static res:Strings.Label_Clutch}" Style="{StaticResource MutedHintText}" Margin="0,0,0,4"/>
                                    <ProgressBar x:Name="ClutchBar" Height="14" Minimum="0" Maximum="100" Value="0"
                                                 Foreground="{StaticResource CyanBrush}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Pedal sub-selector chips -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Button x:Name="PedalSelectorThrottle" Content="{x:Static res:Strings.Label_Throttle}"
                                    Style="{StaticResource MozaButtonPrimary}"
                                    Margin="0,0,8,0" Padding="22,8"
                                    Click="PedalSelector_Throttle_Click"
                                    Tag="green"/>
                            <Button x:Name="PedalSelectorBrake" Content="{x:Static res:Strings.Label_Brake}"
                                    Margin="0,0,8,0" Padding="22,8"
                                    Click="PedalSelector_Brake_Click"
                                    Tag="red"/>
                            <Button x:Name="PedalSelectorClutch" Content="{x:Static res:Strings.Label_Clutch}"
                                    Padding="22,8"
                                    Click="PedalSelector_Clutch_Click"
                                    Tag="cyan"/>
                        </StackPanel>

                        <!-- ===== THROTTLE ===== -->
                        <StackPanel x:Name="ThrottlePedalGroup">
                            <!-- Green accent override for active button-selectors
                                 inside this group (toggle ON pill, SegmentedControl
                                 selected item). -->
                            <StackPanel.Resources>
                                <StaticResource x:Key="ToggleOnBrush" ResourceKey="GreenToggleOnBrush"/>
                                <SolidColorBrush x:Key="ToggleOnTextBrush" Color="{StaticResource GreenColor}"/>
                            </StackPanel.Resources>
                        <!-- THROTTLE Direction & Range + Output Curve side-by-side. -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ctrl:SectionCard Grid.Column="0" Title="{x:Static res:Strings.Section_ThrottleDirectionRange}"
                                              Icon="{StaticResource IconPedals}"
                                          AccentBrush="{StaticResource GreenBrush}"
                                              Margin="0,0,7,14">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,8">
                                        <TextBlock Text="{x:Static res:Strings.SliderLabel_ReverseDirection}" Style="{StaticResource SliderLabel}"/>
                                        <ctrl:OffOnToggle x:Name="ThrottleDirCheck" VerticalAlignment="Center" Click="ThrottleDirCheck_Click"/>
                                    </StackPanel>
