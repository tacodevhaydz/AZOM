                                                                HorizontalAlignment="Left" Style="{StaticResource MozaButtonDanger}"
                                                                Click="MBoosterDeleteCustomEffect_Click" Tag="{Binding}"/>
                                                    </StackPanel>
                                                </Expander>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Button x:Name="MBoosterAddCustomEffectButton" Content="{x:Static res:Strings.Button_AddCustomEffect}"
                                            Margin="0,4,0,0" HorizontalAlignment="Left" Click="MBoosterAddCustomEffectButton_Click"/>
                                </StackPanel>
                            </ctrl:SectionCard>

                            <ctrl:SectionCard Title="{x:Static res:Strings.Section_Calibration}"
