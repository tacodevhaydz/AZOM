                        <Grid x:Name="StickModeNewPanel" Margin="0,8" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{x:Static res:Strings.SliderLabel_JoystickAssignment}" Style="{StaticResource SliderLabel}"/>
                            <ComboBox Grid.Column="1" x:Name="StickModeCombo" Width="120" SelectionChanged="StickModeCombo_Changed">
                                <ComboBoxItem Content="{x:Static res:Strings.Option_None}"/>
                                <ComboBoxItem Content="{x:Static res:Strings.Option_Left}"/>
                                <ComboBoxItem Content="{x:Static res:Strings.Option_Right}"/>
                            </ComboBox>
                        </Grid>

                        <TextBlock TextWrapping="Wrap" Foreground="Gray" FontSize="11" Margin="0,12,0,0"
                                   Text="{x:Static res:Strings.Hint_LedButtonSettingsInDeviceTab}"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ==================== HANDBRAKE TAB ==================== -->
            <TabItem x:Name="HandbrakeTab" Header="{x:Static res:Strings.TabHeader_Handbrake}" Visibility="Collapsed">
                <!-- Red accent for active button-selectors (SegmentedControl
                     selected item, OffOnToggle ON pill). The templates resolve
                     these keys via DynamicResource, so overriding them here
                     tints every active control inside the Handbrake tab. -->
                <TabItem.Resources>
                    <StaticResource x:Key="ToggleOnBrush" ResourceKey="RedToggleOnBrush"/>
                    <SolidColorBrush x:Key="ToggleOnTextBrush" Color="{StaticResource RedColor}"/>
                </TabItem.Resources>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                    <StackPanel Margin="5">

                        <!-- Live Input (POSITION card) + CALIBRATION side-by-side. -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ctrl:SectionCard Grid.Column="0" Title="{x:Static res:Strings.Section_Position}"
                                              Subtitle="{x:Static res:Strings.Subtitle_LiveHandbrakeInput}"
                                              Icon="{StaticResource IconHandbrake}"
                                              AccentBrush="{StaticResource RedBrush}"
                                              Margin="0,0,7,14">
                                <StackPanel>
                                    <StackPanel x:Name="HandbrakeAxisPanel" Margin="0,4">
                                        <TextBlock Text="{x:Static res:Strings.Label_Position}" Style="{StaticResource MutedHintText}" Margin="0,0,0,4"/>
                                        <ProgressBar x:Name="HandbrakeBar" Height="14" Minimum="0" Maximum="100" Value="0"
                                                     HorizontalAlignment="Stretch"/>
                                    </StackPanel>
                                    <TextBlock x:Name="HandbrakeButtonStatus" FontFamily="Consolas" FontSize="14"
                                               FontWeight="Normal" Margin="0,4" Visibility="Collapsed">Released</TextBlock>
                                </StackPanel>
                            </ctrl:SectionCard>

                            <ctrl:SectionCard Grid.Column="1" Title="{x:Static res:Strings.Section_Calibration}"
                                              Subtitle="{x:Static res:Strings.Subtitle_PullHandbrakeFully}"
                                              Icon="{StaticResource IconCal}"
                                              AccentBrush="{StaticResource RedBrush}"
                                              Margin="7,0,0,14">
                                <StackPanel Margin="0,4">
                                    <Button x:Name="HbCalStartButton" Content="{x:Static res:Strings.Button_StartCalibration}" HorizontalAlignment="Left" Click="HbCalStartButton_Click"/>
                                    <TextBlock x:Name="HbCalStatus" Style="{StaticResource MutedHintText}" TextWrapping="Wrap" Margin="0,6,0,0" Visibility="Collapsed"/>
                                </StackPanel>
                            </ctrl:SectionCard>
                        </Grid>

                        <!-- Handbrake Settings + Range side-by-side. -->
                        <!-- HANDBRAKE SETTINGS (mode/threshold/direction + range) on the left,
                             OUTPUT CURVE on the right. Mirrors the BRAKE page's combined
                             "Direction & Range" card style. -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ctrl:SectionCard Grid.Column="0" Title="{x:Static res:Strings.Section_HandbrakeSettings}"
                                              Icon="{StaticResource IconHandbrake}"
                                              AccentBrush="{StaticResource RedBrush}" Margin="0,0,7,14">
                                <StackPanel>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{x:Static res:Strings.SliderLabel_Mode}" Style="{StaticResource SliderLabel}"/>
                                        <ctrl:SegmentedControl Grid.Column="1" x:Name="HandbrakeModeCombo"
                                                               HorizontalAlignment="Left"
                                                               SelectionChanged="HandbrakeModeCombo_Changed">
                                            <ListBoxItem Content="{x:Static res:Strings.Option_Axis}"/>
                                            <ListBoxItem Content="{x:Static res:Strings.Option_Button}"/>
                                        </ctrl:SegmentedControl>
                                    </Grid>
                                    <Grid x:Name="HandbrakeThresholdPanel" Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{x:Static res:Strings.SliderLabel_ButtonThreshold}" Style="{StaticResource SliderLabel}"/>
                                        <Slider Grid.Column="1" x:Name="HandbrakeThresholdSlider" Style="{StaticResource RedSettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="HandbrakeThresholdSlider_ValueChanged"/>
                                        <TextBox Grid.Column="2" x:Name="HandbrakeThresholdValue" Style="{StaticResource RedSliderValueEditBox}"
                                                     Tag="{Binding ElementName=HandbrakeThresholdSlider}"
                                                     KeyDown="SliderValueBox_KeyDown" LostFocus="SliderValueBox_LostFocus"
