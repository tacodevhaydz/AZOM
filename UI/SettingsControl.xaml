                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{x:Static res:Strings.SliderLabel_Intensity}" Style="{StaticResource LfeLabel}" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" x:Name="BaseLfeGearshiftIntensityValue" Width="58" Style="{StaticResource SliderValueEditBox}" Tag="{Binding ElementName=BaseLfeGearshiftIntensity}" KeyDown="SliderValueBox_KeyDown" LostFocus="SliderValueBox_LostFocus" Text="50"/>
                                        <TextBlock Grid.Column="2" x:Name="BaseLfeGearshiftIntensityCalc" Visibility="Collapsed" Foreground="{StaticResource CyanBrush}" FontFamily="{StaticResource FontMono}" FontSize="13" Width="58" TextAlignment="Right" VerticalAlignment="Center"/>
                                        <Button Grid.Column="3" Tag="gearshift:intensity" Click="BaseLfeFx_Click" ToolTip="{x:Static res:Strings.Tooltip_EditFormula}" Width="34" Height="22" Padding="2" Margin="4,0,0,0" Background="Transparent" BorderThickness="0" Cursor="Hand" VerticalAlignment="Center"><TextBlock Text="𝑓(𝑥)" FontFamily="Cambria Math, Segoe UI" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource TextDimBrush}"/></Button>
                                    </Grid>
                                    <Slider x:Name="BaseLfeGearshiftIntensity" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" Margin="0,2,0,0" ValueChanged="BaseLfeGearshiftIntensity_ValueChanged"/>
                                    <TextBlock x:Name="BaseLfeGearshiftIntensityFormulaText" Visibility="Collapsed" Foreground="{StaticResource CyanBrush}" FontFamily="{StaticResource FontMono}" FontSize="11" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{x:Static res:Strings.SliderLabel_Smoothness}" Style="{StaticResource LfeLabel}" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" x:Name="BaseLfeGearshiftSmoothnessValue" Width="58" Style="{StaticResource SliderValueEditBox}" Tag="{Binding ElementName=BaseLfeGearshiftSmoothness}" KeyDown="SliderValueBox_KeyDown" LostFocus="SliderValueBox_LostFocus" Text="100"/>
                                        <TextBlock Grid.Column="2" x:Name="BaseLfeGearshiftSmoothnessCalc" Visibility="Collapsed" Foreground="{StaticResource CyanBrush}" FontFamily="{StaticResource FontMono}" FontSize="13" Width="58" TextAlignment="Right" VerticalAlignment="Center"/>
                                        <Button Grid.Column="3" Tag="gearshift:smoothness" Click="BaseLfeFx_Click" ToolTip="{x:Static res:Strings.Tooltip_EditFormula}" Width="34" Height="22" Padding="2" Margin="4,0,0,0" Background="Transparent" BorderThickness="0" Cursor="Hand" VerticalAlignment="Center"><TextBlock Text="𝑓(𝑥)" FontFamily="Cambria Math, Segoe UI" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource TextDimBrush}"/></Button>
                                    </Grid>
                                    <Slider x:Name="BaseLfeGearshiftSmoothness" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" Margin="0,2,0,0" ValueChanged="BaseLfeGearshiftSmoothness_ValueChanged"/>
                                    <TextBlock x:Name="BaseLfeGearshiftSmoothnessFormulaText" Visibility="Collapsed" Foreground="{StaticResource CyanBrush}" FontFamily="{StaticResource FontMono}" FontSize="11" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                    <StackPanel x:Name="BaseLfeGearshiftEdgeOptions" Visibility="Collapsed">
                                        <Grid Margin="0,6,0,0">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{x:Static res:Strings.SliderLabel_VibrateOnNeutral}" Style="{StaticResource LfeLabel}" VerticalAlignment="Center"/>
                                            <ctrl:OffOnToggle Grid.Column="1" x:Name="BaseLfeGearshiftVibrateOnNeutral" Tag="gearshift" Margin="0,0,38,0" VerticalAlignment="Center" Checked="BaseLfeVibrateOnNeutral_Changed" Unchecked="BaseLfeVibrateOnNeutral_Changed"/>
                                        </Grid>
                                        <Grid Margin="0,6,0,0">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{x:Static res:Strings.SliderLabel_ShiftDebounce}" Style="{StaticResource LfeLabel}" VerticalAlignment="Center"/>
                                            <TextBox Grid.Column="1" x:Name="BaseLfeGearshiftDebounceValue" Width="58" Margin="0,0,38,0" Style="{StaticResource SliderValueEditBox}" Tag="{Binding ElementName=BaseLfeGearshiftDebounceSlider}" KeyDown="SliderValueBox_KeyDown" LostFocus="SliderValueBox_LostFocus" Text="50 ms"/>
                                        </Grid>
                                        <Slider x:Name="BaseLfeGearshiftDebounceSlider" Tag="gearshift" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="1000" TickFrequency="50" SmallChange="50" LargeChange="50" IsSnapToTickEnabled="True" Margin="0,2,0,0" ValueChanged="BaseLfeDebounce_ValueChanged"/>
                                    </StackPanel>
                            </StackPanel>
                        </ctrl:SectionCard>
                        </Grid>
                        <!-- LFE-GEN-END -->
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem x:Name="WheelTab" Header="{x:Static res:Strings.TabHeader_Wheel}" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                    <StackPanel Margin="5">

                        <!-- Live Input -->
                        <TextBlock Text="{x:Static res:Strings.Section_Paddles}" Style="{StaticResource SectionHeader}"/>
                        <StackPanel x:Name="SplitPaddlePanel" Orientation="Horizontal" Margin="0,0,0,10">
                            <StackPanel Margin="0,0,20,0" Width="100">
                                <TextBlock Text="{x:Static res:Strings.Label_LeftPaddle}" Foreground="Gray" FontSize="11"/>
                                <ProgressBar x:Name="LeftPaddleBar" Height="14" Minimum="0" Maximum="100" Value="0"/>
                            </StackPanel>
                            <StackPanel Width="100">
                                <TextBlock Text="{x:Static res:Strings.Label_RightPaddle}" Foreground="Gray" FontSize="11"/>
                                <ProgressBar x:Name="RightPaddleBar" Height="14" Minimum="0" Maximum="100" Value="0"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel x:Name="CombinedPaddlePanel" Orientation="Horizontal" Margin="0,0,0,10" Visibility="Collapsed">
                            <StackPanel Width="100">
                                <TextBlock Text="{x:Static res:Strings.Label_Combined}" Foreground="Gray" FontSize="11"/>
                                <ProgressBar x:Name="CombinedPaddleBar" Height="14" Minimum="0" Maximum="100" Value="0"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Active Buttons -->
                        <TextBlock Text="{x:Static res:Strings.Section_Buttons}" Style="{StaticResource SectionHeader}" Margin="0,4,0,8"/>
                        <TextBlock x:Name="ActiveButtonsText" FontFamily="Consolas" FontSize="12"
                                   Foreground="Gray" Margin="0,0,0,10" TextWrapping="Wrap">None</TextBlock>

                        <!-- Paddle Settings -->
                        <TextBlock Text="{x:Static res:Strings.Section_PaddleSettings}" Style="{StaticResource SectionHeader}"/>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{x:Static res:Strings.SliderLabel_PaddlesMode}" Style="{StaticResource SliderLabel}"/>
                            <ComboBox Grid.Column="1" x:Name="WheelPaddlesModeCombo" Width="140" SelectionChanged="WheelPaddlesModeCombo_Changed">
                                <ComboBoxItem Content="{x:Static res:Strings.Section_Buttons}"/>
                                <ComboBoxItem Content="{x:Static res:Strings.Label_Combined}"/>
                                <ComboBoxItem Content="{x:Static res:Strings.Option_Split}"/>
                            </ComboBox>
                        </Grid>
                        <Grid x:Name="WheelClutchPointPanel" Margin="0,4" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{x:Static res:Strings.SliderLabel_ClutchSplitPoint}" Style="{StaticResource SliderLabel}"/>
                            <Slider Grid.Column="1" x:Name="WheelClutchPointSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="WheelClutchPointSlider_ValueChanged"/>
                            <TextBox Grid.Column="2" x:Name="WheelClutchPointValue" Style="{StaticResource SliderValueEditBox}"
                                                 Tag="{Binding ElementName=WheelClutchPointSlider}"
                                                 KeyDown="SliderValueBox_KeyDown" LostFocus="SliderValueBox_LostFocus"
                                                 Text="50%"/>
                        </Grid>

                        <!-- Input Settings (knob + stick) -->
                        <TextBlock Text="{x:Static res:Strings.Section_InputSettings}" Style="{StaticResource SectionHeader}"/>
                        <Grid x:Name="KnobModeLegacyPanel" Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{x:Static res:Strings.SliderLabel_RotaryEncoders}" Style="{StaticResource SliderLabel}"/>
                            <ComboBox Grid.Column="1" x:Name="KnobModeCombo" Width="140" SelectionChanged="KnobModeCombo_Changed">
                                <ComboBoxItem Content="{x:Static res:Strings.Section_Buttons}"/>
                                <ComboBoxItem Content="{x:Static res:Strings.Option_Knob}"/>
                            </ComboBox>
                        </Grid>
                        <StackPanel x:Name="KnobSignalModePanel" Visibility="Collapsed">
                            <Grid x:Name="KnobSignalMode0Row" Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{x:Static res:Strings.SliderLabel_Rotary1}" Style="{StaticResource SliderLabel}"/>
                                <ComboBox Grid.Column="1" x:Name="KnobSignalMode0Combo" Width="140" SelectionChanged="KnobSignalMode0Combo_Changed">
                                    <ComboBoxItem Content="{x:Static res:Strings.Section_Buttons}"/><ComboBoxItem Content="{x:Static res:Strings.Option_Knob}"/>
                                </ComboBox>
                            </Grid>
                            <Grid x:Name="KnobSignalMode1Row" Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{x:Static res:Strings.SliderLabel_Rotary2}" Style="{StaticResource SliderLabel}"/>
                                <ComboBox Grid.Column="1" x:Name="KnobSignalMode1Combo" Width="140" SelectionChanged="KnobSignalMode1Combo_Changed">
                                    <ComboBoxItem Content="{x:Static res:Strings.Section_Buttons}"/><ComboBoxItem Content="{x:Static res:Strings.Option_Knob}"/>
                                </ComboBox>
                            </Grid>
                            <Grid x:Name="KnobSignalMode2Row" Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{x:Static res:Strings.SliderLabel_Rotary3}" Style="{StaticResource SliderLabel}"/>
                                <ComboBox Grid.Column="1" x:Name="KnobSignalMode2Combo" Width="140" SelectionChanged="KnobSignalMode2Combo_Changed">
                                    <ComboBoxItem Content="{x:Static res:Strings.Section_Buttons}"/><ComboBoxItem Content="{x:Static res:Strings.Option_Knob}"/>
                                </ComboBox>
                            </Grid>
                            <Grid x:Name="KnobSignalMode3Row" Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{x:Static res:Strings.SliderLabel_Rotary4}" Style="{StaticResource SliderLabel}"/>
                                <ComboBox Grid.Column="1" x:Name="KnobSignalMode3Combo" Width="140" SelectionChanged="KnobSignalMode3Combo_Changed">
                                    <ComboBoxItem Content="{x:Static res:Strings.Section_Buttons}"/><ComboBoxItem Content="{x:Static res:Strings.Option_Knob}"/>
                                </ComboBox>
                            </Grid>
                            <Grid x:Name="KnobSignalMode4Row" Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{x:Static res:Strings.SliderLabel_Rotary5}" Style="{StaticResource SliderLabel}"/>
                                <ComboBox Grid.Column="1" x:Name="KnobSignalMode4Combo" Width="140" SelectionChanged="KnobSignalMode4Combo_Changed">
                                    <ComboBoxItem Content="{x:Static res:Strings.Section_Buttons}"/><ComboBoxItem Content="{x:Static res:Strings.Option_Knob}"/>
                                </ComboBox>
                            </Grid>
                        </StackPanel>
                        <StackPanel x:Name="StickModeOldPanel" Orientation="Horizontal" Margin="0,8" Visibility="Collapsed">
                            <TextBlock Text="{x:Static res:Strings.SliderLabel_StickAsDpad}" Style="{StaticResource SliderLabel}"/>
