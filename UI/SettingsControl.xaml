                                                                    Background="Transparent" BorderThickness="0" Cursor="Hand">
                                                                <Path Data="{StaticResource IconEdit}"
                                                                      Stretch="Uniform" Width="14" Height="14"
                                                                      Stroke="{DynamicResource TextDimBrush}"
