                                </Grid>
                                <TextBlock x:Name="BaseLfeGearshiftTriggerText" Margin="0,4,0,0" Foreground="{StaticResource TextDimBrush}" FontSize="11" TextTrimming="CharacterEllipsis"/>
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{x:Static res:Strings.SliderLabel_FrequencyHz}" Style="{StaticResource LfeLabel}" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" x:Name="BaseLfeGearshiftFrequencyValue" Width="58" Style="{StaticResource SliderValueEditBox}" Tag="{Binding ElementName=BaseLfeGearshiftFrequencySlider}" KeyDown="SliderValueBox_KeyDown" LostFocus="SliderValueBox_LostFocus" Text="100"/>
                                        <TextBlock Grid.Column="2" x:Name="BaseLfeGearshiftFrequencyCalc" Visibility="Collapsed" Foreground="{StaticResource CyanBrush}" FontFamily="{StaticResource FontMono}" FontSize="13" Width="58" TextAlignment="Right" VerticalAlignment="Center"/>
                                        <Button Grid.Column="3" Tag="gearshift:frequency" Click="BaseLfeFx_Click" ToolTip="{x:Static res:Strings.Tooltip_EditFormula}" Width="34" Height="22" Padding="2" Margin="4,0,0,0" Background="Transparent" BorderThickness="0" Cursor="Hand" VerticalAlignment="Center"><TextBlock Text="𝑓(𝑥)" FontFamily="Cambria Math, Segoe UI" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource TextDimBrush}"/></Button>
                                    </Grid>
                                    <Slider x:Name="BaseLfeGearshiftFrequencySlider" Style="{StaticResource SettingSlider}" Minimum="20" Maximum="100" TickFrequency="1" Margin="0,2,0,0" ValueChanged="BaseLfeGearshiftFrequencySlider_ValueChanged"/>
                                    <TextBlock x:Name="BaseLfeGearshiftFrequencyFormulaText" Visibility="Collapsed" Foreground="{StaticResource CyanBrush}" FontFamily="{StaticResource FontMono}" FontSize="11" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                    <StackPanel x:Name="BaseLfeGearshiftFreqLimits" Visibility="Collapsed" Margin="0,4,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{x:Static res:Strings.Label_FormulaLimitsHz}" Style="{StaticResource LabelText}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" x:Name="BaseLfeGearshiftFreqRangeText" Foreground="{StaticResource CyanBrush}" FontFamily="{StaticResource FontMono}" FontSize="11" VerticalAlignment="Center"/>
                                        </Grid>
