<UserControl x:Class="MozaPlugin.SettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:profilescommon="clr-namespace:SimHub.Plugins.ProfilesCommon;assembly=SimHub.Plugins"
             xmlns:ctrl="clr-namespace:MozaControls"
             xmlns:ui="clr-namespace:MozaPlugin.UI"
             xmlns:res="clr-namespace:MozaPlugin.Resources"
             Padding="0"
             Background="{DynamicResource BgPanelBrush}"
             TextElement.Foreground="{DynamicResource TextBrush}"
             TextElement.FontFamily="{DynamicResource FontUi}"
             TextElement.FontSize="13">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MozaPlugin;component/Themes/MozaTheme.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/MozaPlugin;component/Themes/MozaIcons.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Legacy keys preserved so the hidden Wheel/AB9/mBooster/Hub tabs (kept in
                 the visual tree but Visibility=Collapsed in Phase 1) still resolve.
                 They route to the new design's brushes + typography so any pixels they
                 do emit blend in. Phase 2 deletes these along with the stub tabs. -->
            <Style x:Key="SectionHeader" TargetType="TextBlock" BasedOn="{StaticResource SectionTitleText}">
                <Setter Property="Margin" Value="0,20,0,8"/>
                <Setter Property="FontSize" Value="14"/>
            </Style>
            <!-- Slider/toggle row labels. MinWidth keeps short labels aligned across
                 rows (English: ~180px is the widest); MaxWidth caps growth so a
                 verbose translation can't squeeze the slider below usable size.
                 TextWrapping lets long labels break to a second line rather than
                 clipping; the row Grid (Auto column) sizes vertically to fit. -->
            <Style x:Key="SliderLabel" TargetType="TextBlock" BasedOn="{StaticResource LabelText}">
                <Setter Property="MinWidth" Value="180"/>
                <Setter Property="MaxWidth" Value="280"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
                <Setter Property="Margin" Value="0,0,12,0"/>
            </Style>
            <Style x:Key="SliderValue" TargetType="TextBlock">
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Width" Value="60"/>
                <Setter Property="TextAlignment" Value="Right"/>
                <Setter Property="Margin" Value="8,0,0,0"/>
                <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
                <Setter Property="Foreground" Value="{StaticResource CyanBrush}"/>
            </Style>
            <!-- Editable slider value: looks like the read-only SliderValue text
                 while idle, reveals editable chrome on hover/focus. KeyDown +
                 LostFocus handlers in code-behind parse the typed value and
                 push it back to the paired Slider via Tag (which is bound to
                 the slider with ElementName). GotFocus strips the unit suffix
                 (e.g. "100%" → "100") and selects the digits so the user can
                 only edit the numeric portion. -->
            <Style x:Key="SliderValueEditBox" TargetType="TextBox">
                <EventSetter Event="GotFocus" Handler="SliderValueBox_GotFocus"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <!-- Wide enough for the longest canonical value in any box —
                     "120 kph" (Trigger Speed) at FontMono 14pt is the tightest fit. -->
                <Setter Property="Width" Value="78"/>
                <Setter Property="Height" Value="26"/>
                <Setter Property="Padding" Value="6,2"/>
                <Setter Property="Margin" Value="8,0,0,0"/>
                <Setter Property="TextAlignment" Value="Right"/>
                <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Foreground" Value="{StaticResource CyanBrush}"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CaretBrush" Value="{StaticResource CyanBrush}"/>
                <Setter Property="SelectionBrush" Value="{StaticResource CyanBrush}"/>
                <Setter Property="SelectionOpacity" Value="0.35"/>
                <Setter Property="Cursor" Value="IBeam"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="3"
                                    SnapsToDevicePixels="True">
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              Focusable="False"
                                              HorizontalScrollBarVisibility="Hidden"
                                              VerticalScrollBarVisibility="Hidden"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgCard2Brush}"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                </Trigger>
                                <Trigger Property="IsKeyboardFocused" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgCardBrush}"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BorderGlowBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <!-- Slider rows live in 3-column Grids (Auto label / * slider / Auto value)
                 so the slider stretches to fill its container's remaining width
                 instead of sitting at a fixed 300 px and leaving a gap on the
                 right edge of the card. -->
            <Style x:Key="SettingSlider" TargetType="Slider" BasedOn="{StaticResource MozaSlider}">
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="MinWidth" Value="80"/>
                <Setter Property="IsSnapToTickEnabled" Value="True"/>
            </Style>
            <!-- Accent-colored slider variants. Foreground cascades to the
                 thumb + decrease-track fill via TemplateBindings in MozaSlider,
                 so a slider on the throttle (green) or brake/handbrake (red)
                 cards picks up the matching accent without a fresh template. -->
            <Style x:Key="GreenSettingSlider" TargetType="Slider" BasedOn="{StaticResource SettingSlider}">
                <Setter Property="Foreground" Value="{StaticResource GreenFillBrush}"/>
            </Style>
            <Style x:Key="RedSettingSlider" TargetType="Slider" BasedOn="{StaticResource SettingSlider}">
                <Setter Property="Foreground" Value="{StaticResource RedFillBrush}"/>
            </Style>
            <!-- Value-box accent variants. Only Foreground / caret / selection
                 brush change; everything else (hover, focus, padding) inherits
                 from SliderValueEditBox. -->
            <Style x:Key="GreenSliderValueEditBox" TargetType="TextBox" BasedOn="{StaticResource SliderValueEditBox}">
                <Setter Property="Foreground" Value="{StaticResource GreenBrush}"/>
                <Setter Property="CaretBrush" Value="{StaticResource GreenBrush}"/>
                <Setter Property="SelectionBrush" Value="{StaticResource GreenBrush}"/>
            </Style>
            <Style x:Key="RedSliderValueEditBox" TargetType="TextBox" BasedOn="{StaticResource SliderValueEditBox}">
                <Setter Property="Foreground" Value="{StaticResource RedBrush}"/>
                <Setter Property="CaretBrush" Value="{StaticResource RedBrush}"/>
                <Setter Property="SelectionBrush" Value="{StaticResource RedBrush}"/>
            </Style>
            <Style x:Key="TempValue" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
                <Setter Property="FontSize" Value="18"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="10,0,20,0"/>
                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            </Style>
            <Style x:Key="ConnectionDot" TargetType="Ellipse">
                <Setter Property="Width" Value="12"/>
                <Setter Property="Height" Value="12"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="0,0,8,0"/>
            </Style>
            <Style x:Key="ColorRect" TargetType="Border">
                <Setter Property="Width" Value="28"/>
                <Setter Property="Height" Value="28"/>
                <Setter Property="BorderBrush" Value="#555"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="3"/>
                <Setter Property="Margin" Value="2,0"/>
                <Setter Property="Cursor" Value="Hand"/>
            </Style>
            <Style x:Key="LedIndex" TargetType="TextBlock">
                <Setter Property="Width" Value="28"/>
                <Setter Property="TextAlignment" Value="Center"/>
                <Setter Property="Foreground" Value="{StaticResource TextFaintBrush}"/>
                <Setter Property="FontSize" Value="10"/>
                <Setter Property="Margin" Value="2,0"/>
            </Style>

            <!-- Default styles for native WPF controls used throughout (Buttons,
                 CheckBoxes, ComboBoxes get the new dark aesthetic automatically). -->
            <Style TargetType="Button" BasedOn="{StaticResource MozaButton}"/>
            <Style TargetType="CheckBox" BasedOn="{StaticResource MozaCheckBox}"/>
            <Style TargetType="ComboBox" BasedOn="{StaticResource MozaCombo}"/>
            <Style TargetType="Slider" BasedOn="{StaticResource MozaSlider}"/>
            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            </Style>
            <Style TargetType="Separator">
                <Setter Property="Background" Value="{StaticResource BorderBrush}"/>
                <Setter Property="Height" Value="1"/>
            </Style>
            <Style TargetType="Expander">
                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                <Setter Property="Background" Value="{StaticResource BgCardBrush}"/>
            </Style>
            <Style TargetType="ProgressBar">
                <Setter Property="Background" Value="{StaticResource BgTrackBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource CyanBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            </Style>
            <Style TargetType="DataGrid">
                <Setter Property="Background" Value="{StaticResource BgCardBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderBrush}"/>
                <Setter Property="VerticalGridLinesBrush" Value="{StaticResource BorderBrush}"/>
                <Setter Property="RowBackground" Value="{StaticResource BgCardBrush}"/>
                <Setter Property="AlternatingRowBackground" Value="{StaticResource BgCard2Brush}"/>
            </Style>

            <!-- Row-grid template used by every restyled slider row -->
            <Style x:Key="RowGrid" TargetType="Grid">
                <Setter Property="Margin" Value="0,4"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <DockPanel LastChildFill="True">
        <!-- ============ Top bar (brand + connection + profile) ============ -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource TopBarBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="22,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <!-- Brand block -->
                <Border Grid.Column="0"
                        BorderThickness="0,0,1,0" BorderBrush="{StaticResource BorderBrush}"
                        Padding="0,0,18,0" Margin="0,0,18,0">
                    <StackPanel Orientation="Horizontal">
                        <Image Width="32" Height="32" Margin="0,0,10,0"
                               Source="{StaticResource MozaWheelBrandIcon}"/>
                        <!-- AZOM wordmark — Space Grotesk Bold outlines (matches the website), vector for crisp Wine/Proton rendering -->
                        <Path VerticalAlignment="Center" HorizontalAlignment="Left"
                              Width="63" Height="16" Stretch="Uniform"
                              Fill="{StaticResource TextBrush}"
                              Data="F1 M0 714 L184 14 L414 14 L598 714 L462 714 L424 560 L174 560 L136 714 L0 714Z M205 438 L393 438 L308 97 L290 97 L205 438Z M722 714 L722 546 L1068 148 L1068 132 L732 132 L732 14 L1206 14 L1206 182 L860 580 L860 596 L1208 596 L1208 714 L722 714Z M1650 728 Q1518 728 1440 655.5 Q1362 583 1362 448 L1362 280 Q1362 145 1440 72.5 Q1518 0 1650 0 Q1782 0 1860 72.5 Q1938 145 1938 280 L1938 448 Q1938 583 1860 655.5 Q1782 728 1650 728Z M1650 610 Q1724 610 1765 567 Q1806 524 1806 452 L1806 276 Q1806 204 1765 161 Q1724 118 1650 118 Q1577 118 1535.5 161 Q1494 204 1494 276 L1494 452 Q1494 524 1535.5 567 Q1577 610 1650 610Z M2114 714 L2114 14 L2359 14 L2480 624 L2498 624 L2619 14 L2864 14 L2864 714 L2736 714 L2736 111 L2718 111 L2598 714 L2380 714 L2260 111 L2242 111 L2242 714 L2114 714Z"/>
                    </StackPanel>
                </Border>

                <!-- Connection pill + enable toggle -->
                <ctrl:ConnectionPill Grid.Column="1" x:Name="ConnectionPill"
                                     Margin="0,0,12,0"
                                     VerticalAlignment="Center"/>

                <!-- Legacy hidden controls kept for code-behind binding contracts.
                     ConnectionIndicator + ConnectionLabel are written by .cs; we
                     route those updates into ConnectionPill from code-behind. -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Visibility="Collapsed">
                    <Ellipse x:Name="ConnectionIndicator" Style="{StaticResource ConnectionDot}" Fill="Gray"/>
                    <TextBlock x:Name="ConnectionLabel" Text="{x:Static res:Strings.Status_Disconnected}"/>
                </StackPanel>

                <ctrl:OffOnToggle Grid.Column="2" x:Name="ConnectionToggle"
                                  Margin="0,0,12,0" IsChecked="True"
                                  Checked="ConnectionToggle_Changed"
                                  Unchecked="ConnectionToggle_Changed"
                                  VerticalAlignment="Center"/>

                <Button Grid.Column="3" x:Name="RefreshButton" Content="{x:Static res:Strings.Button_Refresh}"
                        Click="RefreshButton_Click" VerticalAlignment="Center"/>

                <!-- Right-aligned profile selector. Preset import now lives in
                     its own "Import" tab, so the top bar carries just the
                     active-profile dropdown here. -->
                <StackPanel Grid.Column="4" Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <profilescommon:ProfileList x:Name="ProfileListControl"
                                                VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Status hint banners: port-locked-by-other-app, restart notice,
             profile-not-added-in-SimHub. Items bound by code-behind every
             ~500ms; the list diff suppresses unchanged-tick rebuilds. -->
        <ItemsControl x:Name="HintBanners" DockPanel.Dock="Top"
                      Margin="22,0,22,0" KeyboardNavigation.TabNavigation="None">
            <ItemsControl.Style>
                <Style TargetType="ItemsControl">
                    <Style.Triggers>
                        <Trigger Property="HasItems" Value="False">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ItemsControl.Style>
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type ui:StatusHint}">
                    <Border Style="{StaticResource BannerBorder}" Margin="0,8,0,0">
                        <StackPanel>
                            <TextBlock Text="{Binding Title}" FontWeight="Bold"
                                       Foreground="#FFD7A0"/>
                            <TextBlock Text="{Binding Body}" Foreground="#FFD7A0"
                                       TextWrapping="Wrap" Margin="0,2,0,0"/>
                            <!-- Restart button: only the device-definition-deployed
                                 banner shows it (ShowRestartButton). Wired to
                                 MozaPlugin.RestartSimHub() via HintRestart_Click. -->
                            <Button Content="{x:Static res:Strings.Button_RestartSimHub}"
                                    Click="HintRestart_Click"
                                    HorizontalAlignment="Left" Margin="0,8,0,0">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource MozaButton}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ShowRestartButton}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Update notification banner: shows on every tab when a newer release
             is available (or an install is pending a restart). Dismissable for
             the session; the full controls (channel, skip, check-now, release
             notes) live in About > Updates. Driven by
             SettingsControl.UpdateBanner.cs via RefreshUpdateNotifications(). -->
        <Border x:Name="HeaderUpdateBanner" DockPanel.Dock="Top"
                Visibility="Collapsed"
                Margin="22,8,22,0"
                BorderBrush="{StaticResource CyanBrush}"
                BorderThickness="1"
                Background="{StaticResource BgDeepBrush}"
                CornerRadius="4"
                Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock x:Name="HeaderUpdateBannerText"
                               FontFamily="{StaticResource FontUi}"
                               FontSize="12.5" FontWeight="SemiBold"
                               Foreground="{StaticResource CyanBrush}"
                               TextWrapping="Wrap"/>
                    <TextBlock x:Name="HeaderUpdateBannerProgressText"
                               Style="{StaticResource MutedHintText}"
                               TextWrapping="Wrap"
                               Visibility="Collapsed"
                               Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="12,0,0,0">
                    <Button x:Name="HeaderUpdateInstallButton"
                            Content="{x:Static res:Strings.Button_InstallUpdate}"
                            Click="HeaderUpdateInstall_Click"
                            Margin="0,0,8,0"/>
                    <Button x:Name="HeaderUpdateRestartButton"
                            Content="{x:Static res:Strings.Button_RestartSimHub}"
                            Click="HeaderUpdateRestart_Click"
                            Visibility="Collapsed"
                            Margin="0,0,8,0"/>
                    <Button x:Name="HeaderUpdateNotesButton"
                            Content="{x:Static res:Strings.Button_OpenReleaseNotes}"
                            Click="HeaderUpdateNotes_Click"
                            Margin="0,0,8,0"/>
                    <Button x:Name="HeaderUpdateDismissButton"
                            Content="{x:Static res:Strings.Button_DismissUpdate}"
                            Click="HeaderUpdateDismiss_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- One-time nudge for users without SDK support enabled: enabling it
             lets the plugin stand in for MOZA Pit House so SDK apps don't
             launch it. Cross-tab like the update banner above; dismissal is
             persisted (SdkPromptDismissed) so it never reappears once acted on.
             Driven by SettingsControl.Sdk.cs via RefreshSdkPromptBanner(). -->
        <Border x:Name="SdkPromptBanner" DockPanel.Dock="Top"
                Visibility="Collapsed" Margin="22,8,22,0"
                BorderBrush="{StaticResource CyanBrush}" BorderThickness="1"
                Background="{StaticResource BgDeepBrush}" CornerRadius="4" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{x:Static res:Strings.Banner_SdkSuggestionText}"
                           FontFamily="{StaticResource FontUi}" FontSize="12.5" FontWeight="SemiBold"
                           Foreground="{StaticResource CyanBrush}"
                           TextWrapping="Wrap" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="12,0,0,0">
                    <Button x:Name="SdkPromptConfigureButton"
                            Content="{x:Static res:Strings.Button_ConfigureSdk}"
                            Click="SdkPromptConfigure_Click" Margin="0,0,8,0"/>
                    <Button x:Name="SdkPromptDismissButton"
                            Content="{x:Static res:Strings.Button_Dismiss}"
                            Click="SdkPromptDismiss_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Tabs -->
        <TabControl x:Name="MainTabs" Style="{StaticResource MozaTabControl}">

            <!-- ==================== BASE TAB ==================== -->
            <TabItem Header="{x:Static res:Strings.TabHeader_Base}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="22,18,22,8">
                    <StackPanel>
                        <!-- Live telemetry header -->
                        <Border Background="{StaticResource BgCardBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1" CornerRadius="8"
                                Padding="18" Margin="0,0,0,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="240"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ctrl:SteeringArc Grid.Column="0" x:Name="SteeringArcViz"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Margin="18,0,0,0">
                                    <DockPanel Margin="0,0,0,12" LastChildFill="False">
                                        <Button DockPanel.Dock="Left" x:Name="BaseCalibrateButton"
                                                Content="{x:Static res:Strings.Button_CalibrateCenter}"
                                                Click="BaseCalibrateButton_Click"
                                                VerticalAlignment="Center"/>
                                        <TextBlock DockPanel.Dock="Left" x:Name="BaseCalibrateStatus"
                                                   Style="{StaticResource MutedHintText}"
                                                   VerticalAlignment="Center"
                                                   Margin="10,0,0,0"/>
                                        <ctrl:SegmentedControl DockPanel.Dock="Right"
                                                               x:Name="PerformanceOutputCombo"
                                                               SelectionChanged="PerformanceOutputCombo_Changed"
                                                               VerticalAlignment="Center">
                                            <ListBoxItem Content="{x:Static res:Strings.Option_Reserved}"/>
                                            <ListBoxItem Content="{x:Static res:Strings.Option_Full}"/>
                                        </ctrl:SegmentedControl>
                                        <TextBlock DockPanel.Dock="Right"
                                                   Text="{x:Static res:Strings.Label_PerformanceOutput}"
                                                   Style="{StaticResource LabelText}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,10,0"/>
                                    </DockPanel>
                                    <!-- Live telemetry side-by-side:
                                         Left  = MCU/MOSFET/Motor rolling temp graph (legend sorts hot→cool).
                                         Right = dual-line bandwidth sparkline (cyan=in, amber=out)
                                         relocated from the About tab so traffic + thermals are visible
                                         on the same screen. Both halves are inner cards with their own
                                         legend underneath. -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Style="{StaticResource InnerCardBorder}"
                                                Padding="10,8" Margin="0,0,7,0">
                                            <StackPanel>
                                                <ctrl:TemperatureGraph x:Name="TemperatureGraphViz" Height="80"
                                                                       McuBrush="{StaticResource RedBrush}"
                                                                       MosfetBrush="{StaticResource CyanBrush}"
                                                                       MotorBrush="{StaticResource GreenBrush}"
                                                                       McuFillBrush="{StaticResource McuFillBrush}"
                                                                       MosfetFillBrush="{StaticResource MosfetFillBrush}"
                                                                       MotorFillBrush="{StaticResource MotorFillBrush}"/>
                                                <!-- Three legend rows sorted top→bottom by current temp each tick
                                                     (UpdateRedesignLiveDisplays populates dot fill, name, current,
                                                     and "max NN" since launch). Component colors are stable: MCU=red,
                                                     MOSFET=cyan, Motor=green — match their graph line. -->
                                                <StackPanel Margin="0,6,0,0">
                                                    <StackPanel x:Name="TempLegendRow1" Orientation="Horizontal" Margin="0,0,0,2">
                                                        <Ellipse x:Name="TempLegendDot1" Width="6" Height="6" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                        <TextBlock x:Name="TempLegendName1" Style="{StaticResource KvKeyText}"/>
                                                        <TextBlock x:Name="TempLegendValue1" Style="{StaticResource KvValueText}"/>
                                                        <TextBlock x:Name="TempLegendMax1" Style="{StaticResource KvKeyText}" Margin="8,0,0,0" Opacity="0.7"/>
                                                    </StackPanel>
                                                    <StackPanel x:Name="TempLegendRow2" Orientation="Horizontal" Margin="0,0,0,2">
                                                        <Ellipse x:Name="TempLegendDot2" Width="6" Height="6" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                        <TextBlock x:Name="TempLegendName2" Style="{StaticResource KvKeyText}"/>
                                                        <TextBlock x:Name="TempLegendValue2" Style="{StaticResource KvValueText}"/>
                                                        <TextBlock x:Name="TempLegendMax2" Style="{StaticResource KvKeyText}" Margin="8,0,0,0" Opacity="0.7"/>
                                                    </StackPanel>
                                                    <StackPanel x:Name="TempLegendRow3" Orientation="Horizontal">
                                                        <Ellipse x:Name="TempLegendDot3" Width="6" Height="6" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                        <TextBlock x:Name="TempLegendName3" Style="{StaticResource KvKeyText}"/>
                                                        <TextBlock x:Name="TempLegendValue3" Style="{StaticResource KvValueText}"/>
                                                        <TextBlock x:Name="TempLegendMax3" Style="{StaticResource KvKeyText}" Margin="8,0,0,0" Opacity="0.7"/>
                                                    </StackPanel>
                                                </StackPanel>
                                                <!-- Legacy named legend labels — kept hidden so any code that
                                                     references McuTempLegend / MosfetTempLegend / MotorTempLegend
                                                     by name still compiles. The ranked legend above is the
                                                     visible source of truth. -->
                                                <StackPanel Visibility="Collapsed">
                                                    <TextBlock x:Name="McuTempLegend"/>
                                                    <TextBlock x:Name="MosfetTempLegend"/>
                                                    <TextBlock x:Name="MotorTempLegend"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="1" Style="{StaticResource InnerCardBorder}"
                                                Padding="10,8" Margin="7,0,0,0">
                                            <StackPanel>
                                                <!-- MaxValue = serial-port byte cap (115200 baud / 10 bits-per-byte). -->
                                                <ctrl:BandwidthSparkline x:Name="BandwidthGraphViz" Height="80"
                                                                         InBrush="{StaticResource CyanBrush}"
                                                                         OutBrush="{StaticResource AmberBrush}"
                                                                         InFillBrush="{StaticResource BwInFillBrush}"
                                                                         OutFillBrush="{StaticResource BwOutFillBrush}"
                                                                         MaxValue="11520"/>
                                                <StackPanel Margin="0,6,0,0">
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                        <Ellipse Width="6" Height="6" VerticalAlignment="Center"
                                                                 Fill="{StaticResource CyanBrush}" Margin="0,0,6,0"/>
                                                        <TextBlock Text="{x:Static res:Strings.Label_Inbound}" Style="{StaticResource KvKeyText}"/>
                                                        <TextBlock x:Name="BandwidthInValueText" Text="0 B/s"
                                                                   Style="{StaticResource KvValueText}"
