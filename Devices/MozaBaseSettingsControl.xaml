<UserControl x:Class="MozaPlugin.Devices.MozaBaseSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:MozaControls"
             xmlns:res="clr-namespace:MozaPlugin.Resources"
             Padding="14"
             TextElement.Foreground="{DynamicResource TextBrush}"
             TextElement.FontFamily="{DynamicResource FontUi}"
             TextElement.FontSize="13">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MozaPlugin;component/Themes/MozaTheme.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/MozaPlugin;component/Themes/MozaIcons.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="SectionHeader" TargetType="TextBlock" BasedOn="{StaticResource SectionTitleText}">
                <Setter Property="Margin" Value="0,20,0,8"/>
                <Setter Property="FontSize" Value="14"/>
            </Style>
            <Style x:Key="FieldLabel" TargetType="TextBlock" BasedOn="{StaticResource LabelText}">
                <Setter Property="Width" Value="180"/>
            </Style>
            <Style x:Key="SliderValue" TargetType="TextBlock">
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Width" Value="60"/>
                <Setter Property="TextAlignment" Value="Right"/>
                <Setter Property="Margin" Value="8,0,0,0"/>
                <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
                <Setter Property="Foreground" Value="{StaticResource CyanBrush}"/>
            </Style>
            <Style x:Key="SettingSlider" TargetType="Slider" BasedOn="{StaticResource MozaSlider}">
                <Setter Property="Width" Value="300"/>
                <Setter Property="IsSnapToTickEnabled" Value="True"/>
            </Style>

            <Style TargetType="Button" BasedOn="{StaticResource MozaButton}"/>
            <Style TargetType="CheckBox" BasedOn="{StaticResource MozaCheckBox}"/>
            <Style TargetType="ComboBox" BasedOn="{StaticResource MozaCombo}"/>
            <Style TargetType="Slider" BasedOn="{StaticResource MozaSlider}"/>
            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            </Style>
            <Style TargetType="Separator">
                <Setter Property="Background" Value="{StaticResource BorderBrush}"/>
                <Setter Property="Height" Value="1"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <!-- ScrollViewer removed: SimHub host already provides scrolling -->
        <StackPanel>

            <!-- Device header -->
            <Border Background="{StaticResource BgCardBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="8"
                    Padding="18,14" Margin="0,0,0,14">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Ellipse x:Name="StatusDot" Width="10" Height="10" Fill="Gray"
                                 VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBlock Text="{x:Static res:Strings.Section_BaseAmbientLeds}"
                                   FontWeight="SemiBold" FontSize="14"
                                   VerticalAlignment="Center" Margin="0,0,18,0"/>
                        <TextBlock x:Name="StatusText" Style="{StaticResource MutedHintText}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{x:Static res:Strings.Label_BaseModel}" Style="{StaticResource KvKeyText}"/>
                        <TextBlock x:Name="BaseModelText" Style="{StaticResource KvValueText}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Detection status -->
            <StackPanel x:Name="BaseAmbientNotDetectedPanel">
                <TextBlock Text="{x:Static res:Strings.Hint_NoBaseAmbientDetected}"
                           Style="{StaticResource MutedHintText}" FontStyle="Italic" Margin="0,10" TextWrapping="Wrap"/>
            </StackPanel>

            <StackPanel x:Name="BasePanel" Visibility="Collapsed">

                <ctrl:SectionCard Title="{x:Static res:Strings.Section_Mode}" Icon="{StaticResource IconBolt}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <TextBlock Text="{x:Static res:Strings.SliderLabel_IndicatorState}" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="IndicatorStateCombo" Width="140" SelectionChanged="IndicatorStateCombo_Changed">
                                <ComboBoxItem Content="{x:Static res:Strings.Option_Off}"/>
                                <ComboBoxItem Content="{x:Static res:Strings.Option_On}"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <TextBlock Text="{x:Static res:Strings.SliderLabel_StandbyAnimation}" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="StandbyModeCombo" Width="140" SelectionChanged="StandbyModeCombo_Changed">
                                <ComboBoxItem Content="{x:Static res:Strings.Option_Constant}"/>
                                <ComboBoxItem Content="{x:Static res:Strings.Option_Breath}"/>
                                <ComboBoxItem Content="{x:Static res:Strings.Option_Cycle}"/>
                                <ComboBoxItem Content="{x:Static res:Strings.Option_Rainbow}"/>
                                <ComboBoxItem Content="{x:Static res:Strings.Option_Flow}"/>
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>
                </ctrl:SectionCard>

                <ctrl:SectionCard Title="{x:Static res:Strings.Section_Brightness}" Icon="{StaticResource IconLed}">
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="{x:Static res:Strings.SliderLabel_Brightness}" Style="{StaticResource FieldLabel}"/>
                        <Slider x:Name="BrightnessSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="255" TickFrequency="1" ValueChanged="BrightnessSlider_ValueChanged"/>
                        <TextBlock x:Name="BrightnessValue" Style="{StaticResource SliderValue}" Text="100"/>
                    </StackPanel>
                </ctrl:SectionCard>

                <ctrl:SectionCard Title="{x:Static res:Strings.Section_Sleep}" Icon="{StaticResource IconMisc}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <TextBlock Text="{x:Static res:Strings.SliderLabel_SleepMode}" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="SleepModeCombo" Width="140" SelectionChanged="SleepModeCombo_Changed">
                                <ComboBoxItem Content="{x:Static res:Strings.Option_Disabled}"/>
                                <ComboBoxItem Content="{x:Static res:Strings.Option_Enabled}"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <TextBlock Text="{x:Static res:Strings.SliderLabel_SleepTimeout}" Style="{StaticResource FieldLabel}"/>
                            <Slider x:Name="SleepTimeoutSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="120" TickFrequency="1" ValueChanged="SleepTimeoutSlider_ValueChanged"/>
                            <TextBlock x:Name="SleepTimeoutValue" Style="{StaticResource SliderValue}" Text="15"/>
                        </StackPanel>
                    </StackPanel>
                </ctrl:SectionCard>

                <ctrl:SectionCard Title="{x:Static res:Strings.Section_PowerOnOffColor}" Icon="{StaticResource IconPower}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <TextBlock Text="{x:Static res:Strings.SliderLabel_StartupColor}" Style="{StaticResource FieldLabel}"/>
                            <Border x:Name="StartupColorSwatch" Width="36" Height="36"
                                    BorderBrush="{StaticResource BorderBrightBrush}" BorderThickness="1"
                                    CornerRadius="4" Cursor="Hand" Background="Black"
                                    MouseLeftButtonUp="StartupColorSwatch_Click"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <TextBlock Text="{x:Static res:Strings.SliderLabel_ShutdownColor}" Style="{StaticResource FieldLabel}"/>
                            <Border x:Name="ShutdownColorSwatch" Width="36" Height="36"
                                    BorderBrush="{StaticResource BorderBrightBrush}" BorderThickness="1"
                                    CornerRadius="4" Cursor="Hand" Background="Black"
                                    MouseLeftButtonUp="ShutdownColorSwatch_Click"/>
                        </StackPanel>
                    </StackPanel>
                </ctrl:SectionCard>
            </StackPanel>
        </StackPanel>
    <!-- /ScrollViewer -->
</UserControl>
