<UserControl x:Class="MozaPlugin.Devices.WheelUi.DashboardManagementControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:MozaControls"
             xmlns:res="clr-namespace:MozaPlugin.Resources"
             xmlns:ui="clr-namespace:MozaPlugin.UI"
             Padding="0"
             TextElement.Foreground="{DynamicResource TextBrush}"
             TextElement.FontFamily="{DynamicResource FontUi}"
             TextElement.FontSize="13">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MozaPlugin;component/Themes/MozaTheme.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/MozaPlugin;component/Themes/MozaIcons.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- WPF built-in bool → Visibility converter; used by the inline
                 channel-mapping editor to show/hide its panel based on row.IsEditing. -->
            <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

            <Style x:Key="SliderLabel" TargetType="TextBlock" BasedOn="{StaticResource LabelText}">
                <Setter Property="Width" Value="180"/>
            </Style>
            <Style x:Key="SliderValue" TargetType="TextBlock">
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Width" Value="60"/>
                <Setter Property="TextAlignment" Value="Right"/>
                <Setter Property="Margin" Value="8,0,0,0"/>
                <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
                <Setter Property="Foreground" Value="{StaticResource CyanBrush}"/>
            </Style>
            <Style x:Key="SettingSlider" TargetType="Slider" BasedOn="{StaticResource MozaSlider}">
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="MinWidth" Value="80"/>
                <Setter Property="IsSnapToTickEnabled" Value="True"/>
            </Style>

            <!-- Default styles for native WPF controls — picks up the new aesthetic -->
            <Style TargetType="Button" BasedOn="{StaticResource MozaButton}"/>
            <Style TargetType="CheckBox" BasedOn="{StaticResource MozaCheckBox}"/>
            <Style TargetType="ComboBox" BasedOn="{StaticResource MozaCombo}"/>
            <Style TargetType="Slider" BasedOn="{StaticResource MozaSlider}"/>
            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            </Style>
            <Style TargetType="Separator">
                <Setter Property="Background" Value="{StaticResource BorderBrush}"/>
                <Setter Property="Height" Value="1"/>
            </Style>
            <Style TargetType="DataGrid">
                <Setter Property="Background" Value="{StaticResource BgCardBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderBrush}"/>
                <Setter Property="VerticalGridLinesBrush" Value="{StaticResource BorderBrush}"/>
                <Setter Property="RowBackground" Value="{StaticResource BgCardBrush}"/>
                <Setter Property="AlternatingRowBackground" Value="{StaticResource BgCard2Brush}"/>
            </Style>
            <Style TargetType="DataGridColumnHeader">
                <Setter Property="Background" Value="{StaticResource BgCard2Brush}"/>
                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                <Setter Property="Padding" Value="8,6"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
            </Style>
            <Style TargetType="DataGridRow">
                <Setter Property="Background" Value="{StaticResource BgCardBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            </Style>
            <Style TargetType="DataGridCell">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="10,4"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="DataGridCell">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Padding="{TemplateBinding Padding}"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <StackPanel>

        <!-- ==================== DASHBOARD ==================== -->
        <!-- Dashboard Telemetry (left) + Display (right) sit side-by-side in a
             two-column grid, matching the plugin panel's paired-card pattern. -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <ctrl:SectionCard Grid.Column="0" x:Name="DashboardTelemetryCard"
                              Title="{x:Static res:Strings.Section_DashboardTelemetry}"
                              Icon="{StaticResource IconBolt}" Margin="0,0,7,14">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <ctrl:OffOnToggle x:Name="TelemetryEnabledCheck" Content="{x:Static res:Strings.Label_EnableDashboardTelemetry}"
                                  VerticalAlignment="Center" Click="TelemetryEnabledCheck_Click"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="{x:Static res:Strings.Label_Dashboard}" Width="120" VerticalAlignment="Center"/>
                        <ComboBox x:Name="TelemetryProfileCombo" Width="200" Margin="0,0,8,0"
                                  SelectionChanged="TelemetryProfileCombo_SelectionChanged"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                        <Button x:Name="TelemetryTestBtn" Content="{x:Static res:Strings.Button_SendTestPattern}"
                                Margin="0,0,8,0" Click="TelemetryTestToggle_Click"/>
                        <Button x:Name="Fsr1ProbeBtn" Content="Probe bytes" Visibility="Collapsed"
                                Margin="0,0,8,0" Click="Fsr1ProbeToggle_Click"/>
                        <Button x:Name="Fsr1ProbePrevBtn" Content="◀" Visibility="Collapsed" Width="30"
                                Margin="0,0,4,0" Click="Fsr1ProbePrev_Click"/>
                        <Button x:Name="Fsr1ProbeNextBtn" Content="▶" Visibility="Collapsed" Width="30"
                                Margin="0,0,8,0" Click="Fsr1ProbeNext_Click"/>
                        <TextBlock x:Name="Fsr1ProbeLabel" Visibility="Collapsed" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </ctrl:SectionCard>

            <ctrl:SectionCard Grid.Column="1" Title="{x:Static res:Strings.Section_Display}"
                              Icon="{StaticResource IconLed}" Margin="7,0,0,14">
                <StackPanel>
                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{x:Static res:Strings.SliderLabel_DisplayBrightness}" Style="{StaticResource SliderLabel}"/>
                        <Slider Grid.Column="1" x:Name="WheelDisplayBrightnessSlider" Style="{StaticResource SettingSlider}"
                                Minimum="0" Maximum="100" TickFrequency="1"
                                ValueChanged="WheelDisplayBrightnessSlider_ValueChanged"/>
                        <TextBox Grid.Column="2" x:Name="WheelDisplayBrightnessValue" Style="{StaticResource SliderValueEditBox}" ui:SliderValueBox.Slider="{Binding ElementName=WheelDisplayBrightnessSlider}" Text="100"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="{x:Static res:Strings.SliderLabel_StandbyTime}" Style="{StaticResource SliderLabel}"/>
                        <ComboBox x:Name="WheelDisplayStandbyCombo" Width="140"
                                  SelectionChanged="WheelDisplayStandbyCombo_Changed">
                            <ComboBoxItem Tag="1" Content="{x:Static res:Strings.Option_Time1Min}"/>
                            <ComboBoxItem Tag="2" Content="{x:Static res:Strings.Option_Time2Min}"/>
                            <ComboBoxItem Tag="3" Content="{x:Static res:Strings.Option_Time3Min}"/>
                            <ComboBoxItem Tag="4" Content="{x:Static res:Strings.Option_Time4Min}"/>
                            <ComboBoxItem Tag="5" Content="{x:Static res:Strings.Option_Time5Min}"/>
                            <ComboBoxItem Tag="10" Content="{x:Static res:Strings.Option_Time10Min}"/>
                            <ComboBoxItem Tag="15" Content="{x:Static res:Strings.Option_Time15Min}"/>
                            <ComboBoxItem Tag="20" Content="{x:Static res:Strings.Option_Time20Min}"/>
                            <ComboBoxItem Tag="25" Content="{x:Static res:Strings.Option_Time25Min}"/>
                            <ComboBoxItem Tag="30" Content="{x:Static res:Strings.Option_Time30Min}"/>
                            <ComboBoxItem Tag="35" Content="{x:Static res:Strings.Option_Time35Min}"/>
                            <ComboBoxItem Tag="40" Content="{x:Static res:Strings.Option_Time40Min}"/>
                            <ComboBoxItem Tag="45" Content="{x:Static res:Strings.Option_Time45Min}"/>
                            <ComboBoxItem Tag="60" Content="{x:Static res:Strings.Option_Time1Hour}"/>
                            <ComboBoxItem Tag="120" Content="{x:Static res:Strings.Option_Time2Hour}"/>
                            <ComboBoxItem Tag="180" Content="{x:Static res:Strings.Option_Time3Hour}"/>
                            <ComboBoxItem Tag="240" Content="{x:Static res:Strings.Option_Time4Hour}"/>
                            <ComboBoxItem Tag="300" Content="{x:Static res:Strings.Option_Time5Hour}"/>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </ctrl:SectionCard>
        </Grid>

        <ctrl:SectionCard Title="{x:Static res:Strings.Section_ChannelMappings}"
                          Icon="{StaticResource IconDiag}">
            <StackPanel>
                <TextBlock Text="{x:Static res:Strings.Hint_ClickPencilForProperty}"
                           Style="{StaticResource MutedHintText}" TextWrapping="Wrap" Margin="0,0,0,10"/>

                <!-- Loading state: shown while ChannelMappingRowFactory.Build returns
                     null (no profile + no wheel catalog yet). Code-behind toggles
                     Visibility from PopulateChannelMappingList. -->
                <TextBlock x:Name="TelemetryChannelListLoading"
                           Text="{x:Static res:Strings.Status_LoadingChannelMappings}"
                           Style="{StaticResource MutedHintText}"
                           FontStyle="Italic"
                           Margin="0,4,0,10"
                           Visibility="Visible"/>

                <!-- Static three-column header (30 / 40 / 30). Mirrors the row
                     template's column proportions so values line up. -->
                <Grid x:Name="TelemetryChannelListHeader" Margin="0,0,0,4" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="4*"/>
                        <ColumnDefinition Width="3*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{x:Static res:Strings.DataGridHeader_Channel}"
                               Style="{StaticResource MutedHintText}"
                               FontWeight="SemiBold" Padding="10,4"/>
                    <TextBlock Grid.Column="1" Text="{x:Static res:Strings.DataGridHeader_SimHubProperty}"
                               Style="{StaticResource MutedHintText}"
                               FontWeight="SemiBold" Padding="10,4"/>
                    <TextBlock Grid.Column="2" Text="{x:Static res:Strings.DataGridHeader_CurrentValue}"
                               Style="{StaticResource MutedHintText}"
                               FontWeight="SemiBold" TextAlignment="Right" Padding="10,4"/>
                </Grid>

                <!-- Static list (no DataGrid) — one row per channel mapping. Each
                     row's middle column shows the bound SimHub property as plain
                     text + a pencil icon that toggles the row's inline editor. -->
                <ItemsControl x:Name="TelemetryChannelList" Margin="0,0,0,10">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <!-- Row -->
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3*"/>
                                        <ColumnDefinition Width="4*"/>
                                        <ColumnDefinition Width="3*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Name}"
                                               VerticalAlignment="Center"
                                               Padding="10,4"
                                               Foreground="{DynamicResource TextBrush}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <!-- SimHub property/formula cell: the current mapping
                                         text + a pencil (simple: pick a property) + a ƒₓ
                                         button (advanced: SimHub's [property] NCalc / js:
                                         formula editor). -->
                                    <Grid Grid.Column="1" Margin="10,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding SimHubProperty}"
                                                   VerticalAlignment="Center"
                                                   FontFamily="{DynamicResource FontMono}"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <Button Grid.Column="1"
                                                Click="EditMapping_Click"
                                                Tag="{Binding}"
                                                ToolTip="{x:Static res:Strings.Tooltip_EditMapping}"
                                                Width="26" Height="22"
                                                Padding="2"
                                                Margin="6,0,0,0"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Cursor="Hand">
                                            <Path Data="{StaticResource IconEdit}"
                                                  Stretch="Uniform"
                                                  Width="14" Height="14"
                                                  Stroke="{DynamicResource TextDimBrush}"
                                                  StrokeThickness="1.5"
                                                  Fill="{x:Null}"
                                                  StrokeLineJoin="Round"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"/>
                                        </Button>
                                        <Button Grid.Column="2"
                                                Click="AdvancedEditMapping_Click"
                                                Tag="{Binding}"
                                                ToolTip="{x:Static res:Strings.Tooltip_EditFormula}"
                                                Width="34" Height="22"
                                                Padding="2"
                                                Margin="4,0,0,0"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Cursor="Hand">
                                            <TextBlock Text="𝑓(𝑥)"
                                                       FontFamily="Cambria Math, Segoe UI"
                                                       FontSize="14"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextDimBrush}"/>
                                        </Button>
                                    </Grid>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding CurrentValueText}"
                                               VerticalAlignment="Center"
                                               TextAlignment="Right"
                                               Padding="10,4"
                                               Foreground="{DynamicResource TextBrush}"
                                               FontFamily="{DynamicResource FontMono}"/>
                                </Grid>

                                <!-- Inline simple editor — visible when row.IsEditing.
                                     Filter TextBox + virtualized property ListBox + Cancel/OK,
                                     plus the FSR1/CM1 per-field steppers below. -->
                                <Border Margin="20,4,20,8"
                                        Background="{DynamicResource BgCard2Brush}"
                                        BorderBrush="{DynamicResource BorderBrightBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="10"
                                        Visibility="{Binding IsEditing,
                                                    Converter={StaticResource BoolToVisibility}}">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0"
                                                     x:Name="EditFilterBox"
                                                     Text="{Binding EditFilter,
                                                           UpdateSourceTrigger=PropertyChanged,
                                                           Mode=TwoWay}"
                                                     FontFamily="{DynamicResource FontMono}"
                                                     Padding="8,4"
                                                     Foreground="{DynamicResource TextBrush}"
                                                     Background="{DynamicResource BgDeepBrush}"
                                                     BorderBrush="{DynamicResource BorderBrush}"
                                                     BorderThickness="1"/>
                                            <Button Grid.Column="1"
                                                    Content="{x:Static res:Strings.Button_Cancel}"
                                                    Margin="6,0,0,0"
                                                    Click="CancelMapping_Click"
                                                    Tag="{Binding}"/>
                                            <Button Grid.Column="2"
                                                    Content="{x:Static res:Strings.Button_Ok}"
                                                    MinWidth="60"
                                                    Margin="6,0,0,0"
                                                    Click="CommitMapping_Click"
                                                    Tag="{Binding}"/>
                                        </Grid>
                                        <ListBox ItemsSource="{Binding FilteredProperties}"
                                                 SelectedItem="{Binding PendingProperty, Mode=TwoWay}"
                                                 MaxHeight="240"
                                                 Background="{DynamicResource BgDeepBrush}"
                                                 Foreground="{DynamicResource TextBrush}"
                                                 BorderBrush="{DynamicResource BorderBrush}"
                                                 BorderThickness="1"
                                                 VirtualizingStackPanel.IsVirtualizing="True"
                                                 VirtualizingStackPanel.VirtualizationMode="Recycling"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}"
                                                               FontFamily="{DynamicResource FontMono}"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource TextBrush}"
                                                               Padding="6,3"/>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>

                                        <!-- FSR V1 only: per-field input scaling. The
                                             source value between Min and Max maps onto the
                                             field's full-scale output (CapabilityText). -->
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0"
                                                    Visibility="{Binding IsFsr1,
                                                                Converter={StaticResource BoolToVisibility}}">
                                            <TextBlock Text="Input min" VerticalAlignment="Center"
                                                       Style="{StaticResource MutedHintText}"/>
                                            <TextBox Text="{Binding InMin, Mode=TwoWay,
                                                           UpdateSourceTrigger=LostFocus}"
                                                     Width="70" Margin="6,0,0,0" Padding="6,3"
                                                     Foreground="{DynamicResource TextBrush}"
                                                     Background="{DynamicResource BgDeepBrush}"
                                                     BorderBrush="{DynamicResource BorderBrush}"
                                                     BorderThickness="1"/>
                                            <TextBlock Text="Input max" VerticalAlignment="Center"
                                                       Margin="12,0,0,0"
                                                       Style="{StaticResource MutedHintText}"/>
                                            <TextBox Text="{Binding InMax, Mode=TwoWay,
                                                           UpdateSourceTrigger=LostFocus}"
                                                     Width="70" Margin="6,0,0,0" Padding="6,3"
                                                     Foreground="{DynamicResource TextBrush}"
                                                     Background="{DynamicResource BgDeepBrush}"
                                                     BorderBrush="{DynamicResource BorderBrush}"
                                                     BorderThickness="1"/>
                                            <TextBlock Text="{Binding CapabilityText, StringFormat='→ {0}'}"
                                                       VerticalAlignment="Center" Margin="12,0,0,0"
                                                       FontFamily="{DynamicResource FontMono}"
                                                       Foreground="{DynamicResource TextDimBrush}"/>
                                        </StackPanel>

                                        <!-- FSR V1 only: wire-boundary editor. Step the field's
                                             left/right data byte; the on-screen box the span feeds
                                             lights live (field-probe armed while this editor is open).
                                             Width is held to 1..3 bytes; BE/LE toggle shows at width 2;
                                             Scale/Bias apply raw·Scale+Bias before packing. -->
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0"
                                                    Visibility="{Binding ShowByteSteppers,
                                                                Converter={StaticResource BoolToVisibility}}">
                                            <TextBlock Text="{x:Static res:Strings.Edit_StartByte}"
                                                       VerticalAlignment="Center"
                                                       Style="{StaticResource MutedHintText}"/>
                                            <Button Content="◀" Width="30" Margin="6,0,0,0"
                                                    Click="FieldStartMinus_Click" Tag="{Binding}"
                                                    IsEnabled="{Binding CanStartMinus}"/>
                                            <TextBlock Text="{Binding Start}" MinWidth="20"
                                                       VerticalAlignment="Center" TextAlignment="Center"
                                                       FontFamily="{DynamicResource FontMono}"
                                                       Foreground="{DynamicResource TextBrush}"/>
                                            <Button Content="▶" Width="30"
                                                    Click="FieldStartPlus_Click" Tag="{Binding}"
                                                    IsEnabled="{Binding CanStartPlus}"/>

                                            <TextBlock Text="{x:Static res:Strings.Edit_EndByte}"
                                                       VerticalAlignment="Center" Margin="14,0,0,0"
                                                       Style="{StaticResource MutedHintText}"/>
                                            <Button Content="◀" Width="30" Margin="6,0,0,0"
                                                    Click="FieldEndMinus_Click" Tag="{Binding}"
                                                    IsEnabled="{Binding CanEndMinus}"/>
                                            <TextBlock Text="{Binding End}" MinWidth="20"
                                                       VerticalAlignment="Center" TextAlignment="Center"
                                                       FontFamily="{DynamicResource FontMono}"
                                                       Foreground="{DynamicResource TextBrush}"/>
                                            <Button Content="▶" Width="30"
                                                    Click="FieldEndPlus_Click" Tag="{Binding}"
                                                    IsEnabled="{Binding CanEndPlus}"/>

                                            <TextBlock Text="{Binding EncodingText}"
                                                       VerticalAlignment="Center" Margin="14,0,0,0"
                                                       FontFamily="{DynamicResource FontMono}"
                                                       Foreground="{DynamicResource TextDimBrush}"/>
                                            <CheckBox Content="{x:Static res:Strings.Edit_Endian_LE}"
                                                      VerticalAlignment="Center" Margin="14,0,0,0"
                                                      Foreground="{DynamicResource TextBrush}"
                                                      IsChecked="{Binding LittleEndian, Mode=TwoWay}"
                                                      Visibility="{Binding EndianApplies,
                                                                  Converter={StaticResource BoolToVisibility}}"/>
                                        </StackPanel>

                                        <!-- FSR1 sub-byte / bit-packed steppers: shown only when this field
                                             shares a byte (two values packed with a shared middle byte, e.g.
                                             tyre/brake temps). Start-bit shifts the run; bit-width grows/shrinks
                                             it. Independent of neighbours; spare bits between fields are allowed.
                                             Probe overlays only these bits on live data, so exactly this box moves. -->
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0"
                                                    Visibility="{Binding IsBitPacked,
                                                                Converter={StaticResource BoolToVisibility}}">
                                            <TextBlock Text="{x:Static res:Strings.Edit_StartBit}"
                                                       VerticalAlignment="Center"
                                                       Style="{StaticResource MutedHintText}"/>
                                            <Button Content="◀" Width="30" Margin="6,0,0,0"
                                                    Click="FieldBitOffsetMinus_Click" Tag="{Binding}"
                                                    IsEnabled="{Binding CanBitOffsetMinus}"/>
                                            <Button Content="▶" Width="30"
                                                    Click="FieldBitOffsetPlus_Click" Tag="{Binding}"
                                                    IsEnabled="{Binding CanBitOffsetPlus}"/>

                                            <TextBlock Text="{x:Static res:Strings.Edit_BitWidth}"
                                                       VerticalAlignment="Center" Margin="14,0,0,0"
                                                       Style="{StaticResource MutedHintText}"/>
                                            <Button Content="◀" Width="30" Margin="6,0,0,0"
                                                    Click="FieldBitWidthMinus_Click" Tag="{Binding}"
                                                    IsEnabled="{Binding CanBitWidthMinus}"/>
                                            <TextBlock Text="{Binding BitRangeText}" MinWidth="86"
                                                       VerticalAlignment="Center" TextAlignment="Center"
                                                       FontFamily="{DynamicResource FontMono}"
                                                       Foreground="{DynamicResource TextBrush}"/>
                                            <Button Content="▶" Width="30"
                                                    Click="FieldBitWidthPlus_Click" Tag="{Binding}"
                                                    IsEnabled="{Binding CanBitWidthPlus}"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0"
                                                    Visibility="{Binding IsFsr1,
                                                                Converter={StaticResource BoolToVisibility}}">
                                            <TextBlock Text="{x:Static res:Strings.Edit_Scale}"
                                                       VerticalAlignment="Center"
                                                       Style="{StaticResource MutedHintText}"/>
                                            <TextBox Text="{Binding Scale, Mode=TwoWay,
                                                           UpdateSourceTrigger=LostFocus}"
                                                     Width="70" Margin="6,0,0,0" Padding="6,3"
                                                     Foreground="{DynamicResource TextBrush}"
                                                     Background="{DynamicResource BgDeepBrush}"
                                                     BorderBrush="{DynamicResource BorderBrush}"
                                                     BorderThickness="1"/>
                                            <TextBlock Text="{x:Static res:Strings.Edit_Bias}"
                                                       VerticalAlignment="Center" Margin="12,0,0,0"
                                                       Style="{StaticResource MutedHintText}"/>
                                            <TextBox Text="{Binding Bias, Mode=TwoWay,
                                                           UpdateSourceTrigger=LostFocus}"
                                                     Width="70" Margin="6,0,0,0" Padding="6,3"
                                                     Foreground="{DynamicResource TextBrush}"
                                                     Background="{DynamicResource BgDeepBrush}"
                                                     BorderBrush="{DynamicResource BorderBrush}"
                                                     BorderThickness="1"/>
                                            <Button Content="{x:Static res:Strings.Button_MergePrev}"
                                                    Margin="14,0,0,0"
                                                    Click="FieldMergePrev_Click" Tag="{Binding}"
                                                    Visibility="{Binding CanMergePrev,
                                                                Converter={StaticResource BoolToVisibility}}"/>
                                            <Button Content="{x:Static res:Strings.Button_MergeNext}"
                                                    Margin="8,0,0,0"
                                                    Click="FieldMergeNext_Click" Tag="{Binding}"
                                                    Visibility="{Binding CanMergeNext,
                                                                Converter={StaticResource BoolToVisibility}}"/>
                                            <Button Content="{x:Static res:Strings.Button_SplitField}"
                                                    Margin="8,0,0,0"
                                                    Click="FieldSplit_Click" Tag="{Binding}"
                                                    Visibility="{Binding CanSplit,
                                                                Converter={StaticResource BoolToVisibility}}"/>
                                            <Button Content="{x:Static res:Strings.Button_BitSplit}"
                                                    Margin="8,0,0,0"
                                                    Click="FieldBitSplit_Click" Tag="{Binding}"
                                                    Visibility="{Binding CanBitSplit,
                                                                Converter={StaticResource BoolToVisibility}}"/>
                                            <Button Content="{x:Static res:Strings.Button_RemoveSplit}"
                                                    Margin="8,0,0,0"
                                                    Click="FieldRemoveSplit_Click" Tag="{Binding}"
                                                    Visibility="{Binding IsSynthetic,
                                                                Converter={StaticResource BoolToVisibility}}"/>
                                            <Button Content="{x:Static res:Strings.Button_ResetField}"
                                                    Margin="8,0,0,0"
                                                    Click="FieldReset_Click" Tag="{Binding}"
                                                    Visibility="{Binding IsCatalogFsr1,
                                                                Converter={StaticResource BoolToVisibility}}"/>
                                        </StackPanel>

                                        <!-- CM1 only: per-field gain. CM1 is always BE float32,
                                             so only Scale applies (no boundary/endianness). -->
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0"
                                                    Visibility="{Binding IsCm1,
                                                                Converter={StaticResource BoolToVisibility}}">
                                            <TextBlock Text="{x:Static res:Strings.Edit_Scale}"
                                                       VerticalAlignment="Center"
                                                       Style="{StaticResource MutedHintText}"/>
                                            <TextBox Text="{Binding Scale, Mode=TwoWay,
                                                           UpdateSourceTrigger=LostFocus}"
                                                     Width="70" Margin="6,0,0,0" Padding="6,3"
                                                     Foreground="{DynamicResource TextBrush}"
                                                     Background="{DynamicResource BgDeepBrush}"
                                                     BorderBrush="{DynamicResource BorderBrush}"
                                                     BorderThickness="1"/>
                                            <Button Content="{x:Static res:Strings.Button_ResetField}"
                                                    Margin="14,0,0,0"
                                                    Click="FieldReset_Click" Tag="{Binding}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- FSR V1 only: live numeric byte-strip visualization. One record per
                     active dashboard; each field's data-byte span is boxed and labelled
                     with the raw bytes (hex) AND the post-scale/transform value. Refreshed
                     ~2 Hz from the live driver output via GetFsr1VizSnapshot(). The whole
                     block is hidden when the snapshot is empty (non-FSR1 wheels). -->
                <StackPanel x:Name="Fsr1VizPanel" Margin="0,0,0,10" Visibility="Collapsed">
                <TextBlock Text="{x:Static res:Strings.Viz_Title}"
                           Style="{StaticResource MutedHintText}"
                           FontWeight="SemiBold" Margin="0,4,0,6"/>
                <ItemsControl x:Name="Fsr1VizList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,8"
                                    Background="{DynamicResource BgCard2Brush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="8,6">
                                <StackPanel>
                                    <TextBlock Text="{Binding Label}"
                                               Foreground="{DynamicResource TextBrush}"
                                               FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <!-- Field boxes laid out left→right in Start order. Each box
                                         shows the field label, the raw bytes (hex) and the scaled
                                         value. A synthetic split box is tinted to stand out. -->
                                    <ItemsControl ItemsSource="{Binding Fields}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,6,6"
                                                        MinWidth="74"
                                                        Background="{Binding BoxBrush}"
                                                        BorderBrush="{DynamicResource BorderBrightBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="3"
                                                        Padding="6,4">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Label}"
                                                                   Foreground="{DynamicResource TextDimBrush}"
                                                                   FontSize="11"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   MaxWidth="140"/>
                                                        <TextBlock Text="{Binding RangeText}"
                                                                   Foreground="{DynamicResource TextDimBrush}"
                                                                   FontFamily="{DynamicResource FontMono}"
                                                                   FontSize="10"/>
                                                        <TextBlock Text="{Binding HexText}"
                                                                   Foreground="{DynamicResource AmberBrush}"
                                                                   FontFamily="{DynamicResource FontMono}"
                                                                   FontSize="12"/>
                                                        <TextBlock Text="{Binding ValueText}"
                                                                   Foreground="{DynamicResource CyanBrush}"
                                                                   FontFamily="{DynamicResource FontMono}"
                                                                   FontSize="13"
                                                                   FontWeight="SemiBold"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <Button Content="{x:Static res:Strings.Button_ResetToDefaults}" Click="TelemetryResetMappings_Click"/>
                    <TextBlock x:Name="TelemetryMappingStatus"
                               Style="{StaticResource MutedHintText}"
                               VerticalAlignment="Center" Margin="14,0,0,0"/>
                </StackPanel>
            </StackPanel>
        </ctrl:SectionCard>

        <!-- ==================== FILES ==================== -->

        <!-- Work-in-progress banner -->
        <Border Style="{StaticResource BannerBorder}">
            <StackPanel>
                <TextBlock FontSize="14" FontWeight="Bold" Foreground="{StaticResource AmberBrush}"
                           Text="{x:Static res:Strings.Banner_DashboardUploadNotWorkingYet}"/>
                <TextBlock TextWrapping="Wrap" Foreground="#FFE082" FontSize="11" Margin="0,4,0,0"
                           Text="{x:Static res:Strings.Hint_DashboardUploadNotWorking}"/>
            </StackPanel>
        </Border>

        <ctrl:SectionCard Title="{x:Static res:Strings.Section_DashboardUpload}"
                          Subtitle="{x:Static res:Strings.Subtitle_DashboardUpload}"
                          Icon="{StaticResource IconDiag}">
            <StackPanel>
                <TextBlock TextWrapping="Wrap" Style="{StaticResource MutedHintText}" Margin="0,0,0,12"
                           Text="{x:Static res:Strings.Hint_UploadStatusFormat}"/>
                <TextBlock Text="{x:Static res:Strings.Label_Source}" Style="{StaticResource MutedHintText}" Margin="0,0,0,6"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <RadioButton x:Name="UploadSourceFileRadio" Content="{x:Static res:Strings.Option_LocalMzdashFile}"
                                 GroupName="WiUploadSource" IsChecked="True"
                                 Margin="0,0,16,0" VerticalAlignment="Center"
                                 Foreground="{StaticResource TextBrush}"
                                 Click="UploadSourceRadio_Click"/>
                    <RadioButton x:Name="UploadSourceLibraryRadio" Content="{x:Static res:Strings.Option_DashboardLibrary}"
                                 GroupName="WiUploadSource"
                                 VerticalAlignment="Center"
                                 Foreground="{StaticResource TextBrush}"
                                 Click="UploadSourceRadio_Click"/>
                </StackPanel>
                <StackPanel x:Name="UploadFilePanel" Orientation="Horizontal" Margin="0,0,0,8">
                    <Button Content="{x:Static res:Strings.Button_PickMzdash}" Margin="0,0,8,0" Click="UploadPickFile_Click"/>
                    <TextBlock x:Name="UploadPickedFileText" VerticalAlignment="Center"
                               Style="{StaticResource MutedHintText}"
                               Text="{x:Static res:Strings.Status_NoFileSelected}" TextTrimming="CharacterEllipsis"
                               MaxWidth="500"/>
                </StackPanel>
                <StackPanel x:Name="UploadLibraryPanel" Margin="0,0,0,8"
                            Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Button Content="{x:Static res:Strings.Button_SetFolder}" Click="UploadSetFolder_Click" Margin="0,0,4,0"
                                ToolTip="{x:Static res:Strings.Tooltip_SetFolder}"/>
                        <Button Content="{x:Static res:Strings.Button_AutoDetect}" Click="UploadAutoDetect_Click" Margin="0,0,4,0"
                                ToolTip="{x:Static res:Strings.Tooltip_AutoDetect}"/>
                        <TextBlock x:Name="UploadFolderInfo" Style="{StaticResource MutedHintText}"
                                   VerticalAlignment="Center" Margin="8,0,0,0"
                                   TextTrimming="CharacterEllipsis" MaxWidth="400"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{x:Static res:Strings.Label_Dashboard}" VerticalAlignment="Center" Width="100"/>
                        <ComboBox x:Name="UploadLibraryCombo" Width="280" Margin="0,0,8,0"
                                  SelectionChanged="UploadLibraryCombo_SelectionChanged"/>
                        <Button Content="{x:Static res:Strings.Button_Refresh}" Click="UploadLibraryRefresh_Click"/>
                    </StackPanel>
                </StackPanel>
                <Separator Margin="0,8,0,12"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <Button x:Name="UploadNowButton" Content="{x:Static res:Strings.Button_UploadNow}" MinWidth="120"
                            Style="{StaticResource MozaButtonPrimary}"
                            Click="UploadNow_Click"/>
                    <TextBlock x:Name="UploadStatusText" VerticalAlignment="Center"
                               Style="{StaticResource MutedHintText}" Margin="14,0,0,0"
                               Text="{x:Static res:Strings.Status_Idle}"/>
                </StackPanel>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{x:Static res:Strings.Label_DashboardName}" Style="{StaticResource KvKeyText}" Margin="0,3"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="UploadInfoNameText" Style="{StaticResource KvValueText}" Margin="0,3" Text="—"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{x:Static res:Strings.Label_RawSize}" Style="{StaticResource KvKeyText}" Margin="0,3"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="UploadInfoRawSizeText" Style="{StaticResource KvValueText}" Margin="0,3" Text="—"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{x:Static res:Strings.Label_Md5}" Style="{StaticResource KvKeyText}" Margin="0,3"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="UploadInfoMd5Text" Style="{StaticResource KvValueText}" Margin="0,3" Text="—"/>
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="{x:Static res:Strings.Label_InFlight}" Style="{StaticResource KvKeyText}" Margin="0,3"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="UploadInfoInFlightText" Style="{StaticResource KvValueText}" Margin="0,3" Text="—"/>
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="{x:Static res:Strings.Label_LastAckBytes}" Style="{StaticResource KvKeyText}" Margin="0,3"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" x:Name="UploadInfoProgressText" Style="{StaticResource KvValueText}" Margin="0,3" Text="—"/>
                    <TextBlock Grid.Row="5" Grid.Column="0" Text="{x:Static res:Strings.Label_LastAckStatus}" Style="{StaticResource KvKeyText}" Margin="0,3"/>
                    <TextBlock Grid.Row="5" Grid.Column="1" x:Name="UploadInfoStatusByteText" Style="{StaticResource KvValueText}" Margin="0,3" Text="—"/>
                </Grid>
                <TextBlock TextWrapping="Wrap" Style="{StaticResource MutedHintText}" Margin="0,14,0,0"
                           Text="{x:Static res:Strings.Hint_UploadRequiresConnection}"/>
            </StackPanel>
        </ctrl:SectionCard>

        <ctrl:SectionCard Title="{x:Static res:Strings.Section_WheelFiles}"
                          Subtitle="{x:Static res:Strings.Subtitle_WheelFiles}"
                          Icon="{StaticResource IconDiag}">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <Button x:Name="WheelFilesRefreshButton" Content="{x:Static res:Strings.Button_Refresh}"
                            Click="WheelFilesRefresh_Click" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <TextBlock x:Name="WheelFilesStatusBox" VerticalAlignment="Center"
                               Style="{StaticResource MutedHintText}" Text="—"/>
                </StackPanel>
                <TextBlock TextWrapping="Wrap" Style="{StaticResource MutedHintText}" Margin="0,0,0,10"
                           Text="{x:Static res:Strings.Hint_DeleteDisabled}"/>
                <DataGrid x:Name="WheelFilesGrid" AutoGenerateColumns="False" IsReadOnly="True"
                          CanUserAddRows="False" CanUserDeleteRows="False" CanUserResizeRows="False"
                          SelectionMode="Single" HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                          BorderThickness="1" RowHeight="24">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{x:Static res:Strings.DataGridHeader_State}" Binding="{Binding State}" Width="80"/>
                        <DataGridTextColumn Header="{x:Static res:Strings.DataGridHeader_Title}" Binding="{Binding Title}" Width="*"/>
                        <DataGridTextColumn Header="{x:Static res:Strings.DataGridHeader_DirName}" Binding="{Binding DirName}" Width="200"/>
                        <DataGridTextColumn Header="{x:Static res:Strings.DataGridHeader_Hash}" Binding="{Binding HashShort}" Width="120"/>
                        <DataGridTextColumn Header="{x:Static res:Strings.DataGridHeader_LastModified}" Binding="{Binding LastModified}" Width="170"/>
                        <DataGridTemplateColumn Header="" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="{x:Static res:Strings.Button_Delete}" Padding="8,2"
                                            Click="WheelFilesDelete_Click"
                                            Tag="{Binding}"
                                            IsEnabled="False"
                                            ToolTip="{x:Static res:Strings.Tooltip_DeleteDisabled}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </ctrl:SectionCard>

    </StackPanel>
</UserControl>
