<UserControl x:Class="MozaPlugin.Devices.MozaWheelSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:MozaControls"
             xmlns:res="clr-namespace:MozaPlugin.Resources"
             Padding="0"
             TextElement.Foreground="{DynamicResource TextBrush}"
             TextElement.FontFamily="{DynamicResource FontUi}"
             TextElement.FontSize="13">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MozaPlugin;component/Themes/MozaTheme.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/MozaPlugin;component/Themes/MozaIcons.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- WPF built-in bool → Visibility converter; used by the inline
                 channel-mapping editor to show/hide its panel based on row.IsEditing. -->
            <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

            <!-- Legacy keys for existing markup — BasedOn the redesign equivalents -->
            <Style x:Key="SectionHeader" TargetType="TextBlock" BasedOn="{StaticResource SectionTitleText}">
                <Setter Property="Margin" Value="0,20,0,8"/>
                <Setter Property="FontSize" Value="14"/>
            </Style>
            <Style x:Key="SliderLabel" TargetType="TextBlock" BasedOn="{StaticResource LabelText}">
                <Setter Property="Width" Value="180"/>
            </Style>
            <Style x:Key="SliderValue" TargetType="TextBlock">
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Width" Value="60"/>
                <Setter Property="TextAlignment" Value="Right"/>
                <Setter Property="Margin" Value="8,0,0,0"/>
                <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
                <Setter Property="Foreground" Value="{StaticResource CyanBrush}"/>
            </Style>
            <Style x:Key="SettingSlider" TargetType="Slider" BasedOn="{StaticResource MozaSlider}">
                <Setter Property="Width" Value="300"/>
                <Setter Property="IsSnapToTickEnabled" Value="True"/>
            </Style>
            <Style x:Key="LedIndex" TargetType="TextBlock">
                <Setter Property="Width" Value="28"/>
                <Setter Property="TextAlignment" Value="Center"/>
                <Setter Property="Foreground" Value="{StaticResource TextFaintBrush}"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="Margin" Value="2,0"/>
            </Style>

            <!-- Default styles for native WPF controls — picks up the new aesthetic -->
            <Style TargetType="Button" BasedOn="{StaticResource MozaButton}"/>
            <Style TargetType="CheckBox" BasedOn="{StaticResource MozaCheckBox}"/>
            <Style TargetType="ComboBox" BasedOn="{StaticResource MozaCombo}"/>
            <Style TargetType="Slider" BasedOn="{StaticResource MozaSlider}"/>
            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            </Style>
            <Style TargetType="Separator">
                <Setter Property="Background" Value="{StaticResource BorderBrush}"/>
                <Setter Property="Height" Value="1"/>
            </Style>
            <Style TargetType="Expander">
                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            </Style>
            <Style TargetType="ProgressBar">
                <Setter Property="Background" Value="{StaticResource BgTrackBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource CyanBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            </Style>
            <Style TargetType="DataGrid">
                <Setter Property="Background" Value="{StaticResource BgCardBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderBrush}"/>
                <Setter Property="VerticalGridLinesBrush" Value="{StaticResource BorderBrush}"/>
                <Setter Property="RowBackground" Value="{StaticResource BgCardBrush}"/>
                <Setter Property="AlternatingRowBackground" Value="{StaticResource BgCard2Brush}"/>
            </Style>
            <!-- DataGridColumnHeader defaults to system-white background; the implicit
                 DataGrid Foreground (near-white TextBrush) then renders as white-on-white.
                 Force the dark theme on headers explicitly. -->
            <Style TargetType="DataGridColumnHeader">
                <Setter Property="Background" Value="{StaticResource BgCard2Brush}"/>
                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                <Setter Property="Padding" Value="8,6"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
            </Style>
            <Style TargetType="DataGridRow">
                <Setter Property="Background" Value="{StaticResource BgCardBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            </Style>
            <Style TargetType="DataGridCell">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="10,4"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="DataGridCell">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Padding="{TemplateBinding Padding}"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <DockPanel>
        <!-- Header (always visible) -->
        <StackPanel DockPanel.Dock="Top" Margin="5">

            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Ellipse x:Name="StatusDot" Width="12" Height="12" Margin="0,0,8,0"/>
                <TextBlock x:Name="StatusText" VerticalAlignment="Center" FontSize="14"/>
            </StackPanel>

            <!-- Detection status -->
            <StackPanel x:Name="WheelNotDetectedPanel">
                <TextBlock Text="{x:Static res:Strings.Status_SearchingForWheel}" Foreground="Gray" FontStyle="Italic" Margin="0,10"/>
            </StackPanel>
        </StackPanel>

        <!-- Capability-driven tabs (matches the new plugin-pane tab styling:
             cyan underline on active, transparent header strip). -->
        <TabControl x:Name="WheelTabs" Style="{StaticResource MozaTabControl}"
                    Margin="0,4,0,0">

            <!-- ==================== INPUTS TAB ==================== -->
            <!-- Migrated from plugin-pane WheelTab in Phase 6. Handlers forward to
                 SettingsControl.Instance.{matching control} so the plugin pane's
                 existing event handlers + persistence logic continue to drive the
                 device. The plugin-pane WheelTab is hidden (Visibility=Collapsed)
                 but its controls remain in the visual tree for this forwarding. -->
            <TabItem x:Name="InputsTab" Header="{x:Static res:Strings.TabHeader_Inputs}">
                <!-- ScrollViewer removed: SimHub host already provides scrolling -->
                    <StackPanel>

                        <!-- Live paddles + buttons (two cards side by side) -->
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource InnerCardBorder}" Margin="0,0,7,0">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <Ellipse Width="7" Height="7" Fill="{StaticResource GreenBrush}"
                                                 VerticalAlignment="Center" Margin="0,0,8,0"
                                                 Effect="{StaticResource GreenGlowEffect}"/>
                                        <TextBlock Text="{x:Static res:Strings.Section_LivePaddles}" Style="{StaticResource SectionTitleText}"/>
                                    </StackPanel>
                                    <StackPanel x:Name="WiSplitPaddlePanel">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <TextBlock Text="{x:Static res:Strings.Label_PaddleLeft}" Style="{StaticResource MutedHintText}" Width="60"/>
                                            <ProgressBar x:Name="WiLeftPaddleBar" Height="12" Width="180"
                                                         Foreground="{StaticResource CyanBrush}"
                                                         Minimum="0" Maximum="100" Value="0"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{x:Static res:Strings.Label_PaddleRight}" Style="{StaticResource MutedHintText}" Width="60"/>
                                            <ProgressBar x:Name="WiRightPaddleBar" Height="12" Width="180"
                                                         Foreground="{StaticResource GreenBrush}"
                                                         Minimum="0" Maximum="100" Value="0"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel x:Name="WiCombinedPaddlePanel" Visibility="Collapsed">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{x:Static res:Strings.Label_PaddleCombined}" Style="{StaticResource MutedHintText}" Width="80"/>
                                            <ProgressBar x:Name="WiCombinedPaddleBar" Height="12" Width="180"
                                                         Foreground="{StaticResource CyanBrush}"
                                                         Minimum="0" Maximum="100" Value="0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Style="{StaticResource InnerCardBorder}" Margin="7,0,0,0">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <Ellipse Width="7" Height="7" Fill="{StaticResource GreenBrush}"
                                                 VerticalAlignment="Center" Margin="0,0,8,0"
                                                 Effect="{StaticResource GreenGlowEffect}"/>
                                        <TextBlock Text="{x:Static res:Strings.Section_ActiveButtons}" Style="{StaticResource SectionTitleText}"/>
                                    </StackPanel>
                                    <TextBlock x:Name="WiActiveButtonsText"
                                               FontFamily="{StaticResource FontMono}" FontSize="12"
                                               Foreground="{StaticResource TextDimBrush}"
                                               TextWrapping="Wrap" Text="{x:Static res:Strings.Option_None}"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <ctrl:SectionCard Title="{x:Static res:Strings.Section_PaddleSettings}" Icon="{StaticResource IconPaddle}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="{x:Static res:Strings.SliderLabel_PaddlesMode}" Style="{StaticResource SliderLabel}"/>
                                    <ctrl:SegmentedControl x:Name="WiPaddlesModeCombo"
                                                           SelectionChanged="WiPaddlesModeCombo_Changed">
                                        <ListBoxItem Content="{x:Static res:Strings.Option_Buttons}"/>
                                        <ListBoxItem Content="{x:Static res:Strings.Option_Combined}"/>
                                        <ListBoxItem Content="{x:Static res:Strings.Option_Split}"/>
                                    </ctrl:SegmentedControl>
                                </StackPanel>
                                <StackPanel x:Name="WiClutchPointPanel" Orientation="Horizontal" Margin="0,4" Visibility="Collapsed">
                                    <TextBlock Text="{x:Static res:Strings.SliderLabel_ClutchSplitPoint}" Style="{StaticResource SliderLabel}"/>
                                    <Slider x:Name="WiClutchPointSlider" Style="{StaticResource SettingSlider}"
                                            Minimum="0" Maximum="100" TickFrequency="1"
                                            ValueChanged="WiClutchPointSlider_ValueChanged"/>
                                    <TextBlock x:Name="WiClutchPointValue" Style="{StaticResource SliderValue}" Text="50%"/>
                                </StackPanel>
                            </StackPanel>
                        </ctrl:SectionCard>

                        <ctrl:SectionCard Title="{x:Static res:Strings.Section_Joystick}"
                                          Subtitle="{x:Static res:Strings.Subtitle_JoystickAssignment}"
                                          Icon="{StaticResource IconKnob}">
                            <StackPanel>
                                <!-- Old protocol: single 'stick as D-Pad' checkbox -->
                                <StackPanel x:Name="WiStickModeOldPanel" Orientation="Horizontal" Margin="0,4" Visibility="Collapsed">
                                    <TextBlock Text="{x:Static res:Strings.SliderLabel_StickAsDpad}" Style="{StaticResource SliderLabel}"/>
                                    <ctrl:OffOnToggle x:Name="WiStickModeCheck" VerticalAlignment="Center" Click="WiStickModeCheck_Click"/>
                                </StackPanel>
                                <!-- New protocol: assignment combo (None/Left/Right) -->
                                <StackPanel x:Name="WiStickModeNewPanel" Orientation="Horizontal" Margin="0,4" Visibility="Collapsed">
                                    <TextBlock Text="{x:Static res:Strings.SliderLabel_JoystickAssignment}" Style="{StaticResource SliderLabel}"/>
                                    <ctrl:SegmentedControl x:Name="WiStickModeCombo"
                                                           SelectionChanged="WiStickModeCombo_Changed">
                                        <ListBoxItem Content="{x:Static res:Strings.Option_None}"/>
                                        <ListBoxItem Content="{x:Static res:Strings.Option_Left}"/>
                                        <ListBoxItem Content="{x:Static res:Strings.Option_Right}"/>
                                    </ctrl:SegmentedControl>
                                </StackPanel>
                                <!-- Visible only while plugin disconnected from wheel (so user sees something) -->
                                <TextBlock x:Name="WiStickModeNotDetected"
                                           Text="{x:Static res:Strings.Hint_NoJoystickConfig}"
                                           Style="{StaticResource MutedHintText}" TextWrapping="Wrap"
                                           Visibility="Collapsed"/>
                            </StackPanel>
                        </ctrl:SectionCard>

                    </StackPanel>
                <!-- /ScrollViewer -->
            </TabItem>

            <!-- ==================== DASHBOARD TAB ==================== -->
            <TabItem x:Name="DashboardTab" Header="{x:Static res:Strings.TabHeader_Dashboard}" Visibility="Collapsed">
                <!-- ScrollViewer removed: SimHub host already provides scrolling -->
                    <StackPanel>

                    <ctrl:SectionCard Title="{x:Static res:Strings.Section_DashboardTelemetry}"
                                      Icon="{StaticResource IconBolt}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <ctrl:OffOnToggle x:Name="TelemetryEnabledCheck" Content="{x:Static res:Strings.Label_EnableDashboardTelemetry}"
                                          VerticalAlignment="Center" Click="TelemetryEnabledCheck_Click"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="{x:Static res:Strings.Label_Dashboard}" Width="180" VerticalAlignment="Center"/>
                                <ComboBox x:Name="TelemetryProfileCombo" Width="200" Margin="0,0,8,0"
                                          SelectionChanged="TelemetryProfileCombo_SelectionChanged"/>
                                <Button Content="{x:Static res:Strings.Button_LoadMzdash}" Click="TelemetryLoadMzdash_Click" Margin="0,0,4,0"
                                        ToolTip="{x:Static res:Strings.Tooltip_LoadMzdash}"/>
                                <Button Content="{x:Static res:Strings.Button_SetFolder}" Click="TelemetrySetFolder_Click" Margin="0,0,4,0"
                                        ToolTip="{x:Static res:Strings.Tooltip_SetFolder}"/>
                                <Button Content="{x:Static res:Strings.Button_AutoDetect}" Click="TelemetryAutoDetect_Click" Margin="0,0,4,0"
                                        ToolTip="{x:Static res:Strings.Tooltip_AutoDetect}"/>
                            </StackPanel>
                            <TextBlock x:Name="TelemetryFolderInfo" Style="{StaticResource MutedHintText}"
                                       Margin="180,0,0,8"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                                <Button x:Name="TelemetryTestStartBtn" Content="{x:Static res:Strings.Button_SendTestPattern}"
                                        Margin="0,0,8,0" Click="TelemetryTestStart_Click"/>
                                <Button x:Name="TelemetryTestStopBtn" Content="{x:Static res:Strings.Button_StopTest}"
                                        Click="TelemetryTestStop_Click" IsEnabled="False"/>
                                <TextBlock x:Name="TelemetryStatusLabel" Style="{StaticResource MutedHintText}"
                                           VerticalAlignment="Center" Margin="14,0,0,0" Text="{x:Static res:Strings.Option_Disabled}"/>
                            </StackPanel>
                        </StackPanel>
                    </ctrl:SectionCard>

                    <ctrl:SectionCard Title="{x:Static res:Strings.Section_ChannelMappings}"
                                      Icon="{StaticResource IconDiag}">
                        <StackPanel>
                            <TextBlock Text="{x:Static res:Strings.Hint_ClickPencilForProperty}"
                                       Style="{StaticResource MutedHintText}" TextWrapping="Wrap" Margin="0,0,0,10"/>

                            <!-- Loading state: shown while ChannelMappingRowFactory.Build returns
                                 null (no profile + no wheel catalog yet). Code-behind toggles
                                 Visibility from PopulateChannelMappingList. -->
                            <TextBlock x:Name="TelemetryChannelListLoading"
                                       Text="{x:Static res:Strings.Status_LoadingChannelMappings}"
                                       Style="{StaticResource MutedHintText}"
                                       FontStyle="Italic"
                                       Margin="0,4,0,10"
                                       Visibility="Visible"/>

                            <!-- Static three-column header (30 / 40 / 30). Mirrors the row
                                 template's column proportions so values line up. -->
                            <Grid x:Name="TelemetryChannelListHeader" Margin="0,0,0,4" Visibility="Collapsed">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3*"/>
                                    <ColumnDefinition Width="4*"/>
                                    <ColumnDefinition Width="3*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{x:Static res:Strings.DataGridHeader_Channel}"
                                           Style="{StaticResource MutedHintText}"
                                           FontWeight="SemiBold" Padding="10,4"/>
                                <TextBlock Grid.Column="1" Text="{x:Static res:Strings.DataGridHeader_SimHubProperty}"
                                           Style="{StaticResource MutedHintText}"
                                           FontWeight="SemiBold" Padding="10,4"/>
                                <TextBlock Grid.Column="2" Text="{x:Static res:Strings.DataGridHeader_CurrentValue}"
                                           Style="{StaticResource MutedHintText}"
                                           FontWeight="SemiBold" TextAlignment="Right" Padding="10,4"/>
                            </Grid>

                            <!-- Static list (no DataGrid) — one row per channel mapping. Each
                                 row's middle column shows the bound SimHub property as plain
                                 text + a pencil icon that toggles the row's inline editor. -->
                            <ItemsControl x:Name="TelemetryChannelList" Margin="0,0,0,10">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <!-- Row -->
                                            <Grid Margin="0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="3*"/>
                                                    <ColumnDefinition Width="4*"/>
                                                    <ColumnDefinition Width="3*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Name}"
                                                           VerticalAlignment="Center"
                                                           Padding="10,4"
                                                           Foreground="{DynamicResource TextBrush}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <!-- SimHub property cell: text + pencil button. -->
                                                <Grid Grid.Column="1" Margin="10,4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding SimHubProperty}"
                                                               VerticalAlignment="Center"
                                                               FontFamily="{DynamicResource FontMono}"
                                                               Foreground="{DynamicResource TextBrush}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <Button Grid.Column="1"
                                                            Click="EditMapping_Click"
                                                            Tag="{Binding}"
                                                            ToolTip="{x:Static res:Strings.Tooltip_EditMapping}"
                                                            Width="26" Height="22"
                                                            Padding="2"
                                                            Margin="6,0,0,0"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Cursor="Hand">
                                                        <Path Data="{StaticResource IconEdit}"
                                                              Stretch="Uniform"
                                                              Width="14" Height="14"
                                                              Stroke="{DynamicResource TextDimBrush}"
                                                              StrokeThickness="1.5"
                                                              Fill="{x:Null}"
                                                              StrokeLineJoin="Round"
                                                              StrokeStartLineCap="Round"
                                                              StrokeEndLineCap="Round"/>
                                                    </Button>
                                                </Grid>
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding CurrentValueText}"
                                                           VerticalAlignment="Center"
                                                           TextAlignment="Right"
                                                           Padding="10,4"
                                                           Foreground="{DynamicResource TextBrush}"
                                                           FontFamily="{DynamicResource FontMono}"/>
                                            </Grid>

                                            <!-- Inline editor — visible only when row.IsEditing == true.
                                                 Filter TextBox + virtualized ListBox + Cancel/OK. -->
                                            <Border Margin="20,4,20,8"
                                                    Background="{DynamicResource BgCard2Brush}"
                                                    BorderBrush="{DynamicResource BorderBrightBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="4"
                                                    Padding="10"
                                                    Visibility="{Binding IsEditing,
                                                                Converter={StaticResource BoolToVisibility}}">
                                                <StackPanel>
                                                    <Grid Margin="0,0,0,8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBox Grid.Column="0"
                                                                 x:Name="EditFilterBox"
                                                                 Text="{Binding EditFilter,
                                                                       UpdateSourceTrigger=PropertyChanged,
                                                                       Mode=TwoWay}"
                                                                 FontFamily="{DynamicResource FontMono}"
                                                                 Padding="8,4"
                                                                 Foreground="{DynamicResource TextBrush}"
                                                                 Background="{DynamicResource BgDeepBrush}"
                                                                 BorderBrush="{DynamicResource BorderBrush}"
                                                                 BorderThickness="1"/>
                                                        <Button Grid.Column="1"
                                                                Content="{x:Static res:Strings.Button_Cancel}"
                                                                Margin="6,0,0,0"
                                                                Click="CancelMapping_Click"
                                                                Tag="{Binding}"/>
                                                        <Button Grid.Column="2"
                                                                Content="{x:Static res:Strings.Button_Ok}"
                                                                MinWidth="60"
                                                                Margin="6,0,0,0"
                                                                Click="CommitMapping_Click"
                                                                Tag="{Binding}"/>
                                                    </Grid>
                                                    <ListBox ItemsSource="{Binding FilteredProperties}"
                                                             SelectedItem="{Binding PendingProperty, Mode=TwoWay}"
                                                             MaxHeight="240"
                                                             Background="{DynamicResource BgDeepBrush}"
                                                             Foreground="{DynamicResource TextBrush}"
                                                             BorderBrush="{DynamicResource BorderBrush}"
                                                             BorderThickness="1"
                                                             VirtualizingStackPanel.IsVirtualizing="True"
                                                             VirtualizingStackPanel.VirtualizationMode="Recycling"
                                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                                                        <ListBox.ItemTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding}"
                                                                           FontFamily="{DynamicResource FontMono}"
                                                                           FontSize="12"
                                                                           Foreground="{DynamicResource TextBrush}"
                                                                           Padding="6,3"/>
                                                            </DataTemplate>
                                                        </ListBox.ItemTemplate>
                                                    </ListBox>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="{x:Static res:Strings.Button_ResetToDefaults}" Click="TelemetryResetMappings_Click"/>
                                <TextBlock x:Name="TelemetryMappingStatus"
                                           Style="{StaticResource MutedHintText}"
                                           VerticalAlignment="Center" Margin="14,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </ctrl:SectionCard>

                    <ctrl:SectionCard Title="{x:Static res:Strings.Section_Display}" Icon="{StaticResource IconLed}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <TextBlock Text="{x:Static res:Strings.SliderLabel_DisplayBrightness}" Style="{StaticResource SliderLabel}"/>
                                <Slider x:Name="WheelDisplayBrightnessSlider" Style="{StaticResource SettingSlider}"
                                        Minimum="0" Maximum="100" TickFrequency="1"
                                        ValueChanged="WheelDisplayBrightnessSlider_ValueChanged"/>
                                <TextBlock x:Name="WheelDisplayBrightnessValue" Style="{StaticResource SliderValue}" Text="100"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <TextBlock Text="{x:Static res:Strings.SliderLabel_StandbyTime}" Style="{StaticResource SliderLabel}"/>
                                <ComboBox x:Name="WheelDisplayStandbyCombo" Width="140"
                                          SelectionChanged="WheelDisplayStandbyCombo_Changed">
                                    <ComboBoxItem Tag="1" Content="{x:Static res:Strings.Option_Time1Min}"/>
                                    <ComboBoxItem Tag="2" Content="{x:Static res:Strings.Option_Time2Min}"/>
                                    <ComboBoxItem Tag="3" Content="{x:Static res:Strings.Option_Time3Min}"/>
                                    <ComboBoxItem Tag="4" Content="{x:Static res:Strings.Option_Time4Min}"/>
                                    <ComboBoxItem Tag="5" Content="{x:Static res:Strings.Option_Time5Min}"/>
                                    <ComboBoxItem Tag="10" Content="{x:Static res:Strings.Option_Time10Min}"/>
                                    <ComboBoxItem Tag="15" Content="{x:Static res:Strings.Option_Time15Min}"/>
                                    <ComboBoxItem Tag="20" Content="{x:Static res:Strings.Option_Time20Min}"/>
                                    <ComboBoxItem Tag="25" Content="{x:Static res:Strings.Option_Time25Min}"/>
                                    <ComboBoxItem Tag="30" Content="{x:Static res:Strings.Option_Time30Min}"/>
                                    <ComboBoxItem Tag="35" Content="{x:Static res:Strings.Option_Time35Min}"/>
                                    <ComboBoxItem Tag="40" Content="{x:Static res:Strings.Option_Time40Min}"/>
                                    <ComboBoxItem Tag="45" Content="{x:Static res:Strings.Option_Time45Min}"/>
                                    <ComboBoxItem Tag="60" Content="{x:Static res:Strings.Option_Time1Hour}"/>
                                    <ComboBoxItem Tag="120" Content="{x:Static res:Strings.Option_Time2Hour}"/>
                                    <ComboBoxItem Tag="180" Content="{x:Static res:Strings.Option_Time3Hour}"/>
                                    <ComboBoxItem Tag="240" Content="{x:Static res:Strings.Option_Time4Hour}"/>
                                    <ComboBoxItem Tag="300" Content="{x:Static res:Strings.Option_Time5Hour}"/>
                                </ComboBox>
                            </StackPanel>
                        </StackPanel>
                    </ctrl:SectionCard>

                    </StackPanel>
                <!-- /ScrollViewer -->
            </TabItem>

            <!-- ==================== RPM TAB ==================== -->
            <TabItem x:Name="RpmTab" Header="{x:Static res:Strings.TabHeader_Rpm}" Visibility="Collapsed">
                <!-- ScrollViewer removed: SimHub host already provides scrolling -->
                    <StackPanel>

                    <!-- New-protocol wheel content -->
                    <StackPanel x:Name="RpmNewContent" Visibility="Collapsed">
                        <ctrl:SectionCard Title="{x:Static res:Strings.Section_RpmLedMode}" Icon="{StaticResource IconBolt}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="{x:Static res:Strings.SliderLabel_RpmLedMode}" Style="{StaticResource SliderLabel}"/>
                                    <ctrl:SegmentedControl x:Name="WheelTelemetryModeCombo" SelectionChanged="WheelTelemetryModeCombo_Changed">
                                        <ListBoxItem Content="{x:Static res:Strings.Option_Off}"/>
                                        <ListBoxItem Content="{x:Static res:Strings.Option_SimHubMode}"/>
                                        <ListBoxItem Content="{x:Static res:Strings.Option_Static}"/>
                                    </ctrl:SegmentedControl>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="{x:Static res:Strings.SliderLabel_RpmIdleEffect}" Style="{StaticResource SliderLabel}"/>
                                    <ctrl:SegmentedControl x:Name="WheelIdleEffectCombo" SelectionChanged="WheelIdleEffectCombo_Changed">
                                        <ListBoxItem Content="{x:Static res:Strings.Option_Off}"/>
                                        <ListBoxItem Content="{x:Static res:Strings.Option_Constant}"/>
                                        <ListBoxItem Content="{x:Static res:Strings.Option_Breathing}"/>
                                        <ListBoxItem Content="{x:Static res:Strings.Option_ColorCycle}"/>
                                        <ListBoxItem Content="{x:Static res:Strings.Option_Rainbow}"/>
                                        <ListBoxItem Content="{x:Static res:Strings.Option_SandFlow}"/>
                                        <ListBoxItem Content="{x:Static res:Strings.Option_RgbPulse}"/>
                                    </ctrl:SegmentedControl>
                                </StackPanel>
                                <StackPanel x:Name="WheelIdleSpeedRow" Orientation="Horizontal" Margin="0,4" Visibility="Collapsed">
                                    <TextBlock Text="{x:Static res:Strings.SliderLabel_RpmIdleSpeed}" Style="{StaticResource SliderLabel}"/>
                                    <Slider x:Name="WheelIdleSpeedSlider" Width="160" Minimum="200" Maximum="5000" TickFrequency="100" SmallChange="50" LargeChange="500" IsSnapToTickEnabled="True" ValueChanged="WheelIdleSpeedSlider_ValueChanged"/>
                                    <TextBlock x:Name="WheelIdleSpeedValue" Width="60" Margin="4,0,0,0" VerticalAlignment="Center" Text="1000 ms"/>
                                </StackPanel>
                            </StackPanel>
                        </ctrl:SectionCard>

                        <StackPanel x:Name="WheelRpmColorSection">
                            <ctrl:SectionCard Title="{x:Static res:Strings.Section_RpmLedColorsStatic}"
                                              Subtitle="{x:Static res:Strings.Subtitle_RpmLedColorsStatic}"
                                              Icon="{StaticResource IconLed}">
                                <StackPanel>
                                    <StackPanel x:Name="WheelRpmIndexPanel" Orientation="Horizontal" Margin="0,0,0,2"/>
                                    <StackPanel x:Name="WheelRpmColorPanel" Orientation="Horizontal" Margin="0,0,0,10"/>
                                    <Border x:Name="WiRpmEditorPanel" Style="{StaticResource InnerCardBorder}"
                                            Visibility="Collapsed" Margin="0,4,0,0">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock x:Name="WiRpmEditorLabel"
                                                       Text="{x:Static res:Strings.Label_LedPlaceholder}"
                                                       Style="{StaticResource SectionTitleText}"
                                                       MinWidth="90" VerticalAlignment="Center"
                                                       Margin="0,0,12,0"/>
                                            <ctrl:PaletteStrip x:Name="WiRpmPalette" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ctrl:SectionCard>
                        </StackPanel>

                        <StackPanel x:Name="WheelFlagSection">
                            <ctrl:SectionCard Title="{x:Static res:Strings.Section_FlagLedColors}"
                                              Subtitle="{x:Static res:Strings.Subtitle_ClickFlagToRecolor}"
                                              Icon="{StaticResource IconAlert}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                        <TextBlock Style="{StaticResource LedIndex}" Text="1"/><TextBlock Style="{StaticResource LedIndex}" Text="2"/>
                                        <TextBlock Style="{StaticResource LedIndex}" Text="3"/><TextBlock Style="{StaticResource LedIndex}" Text="4"/>
                                        <TextBlock Style="{StaticResource LedIndex}" Text="5"/><TextBlock Style="{StaticResource LedIndex}" Text="6"/>
                                    </StackPanel>
                                    <StackPanel x:Name="WheelFlagColorPanel" Orientation="Horizontal" Margin="0,0,0,10"/>
                                    <Border x:Name="WiFlagEditorPanel" Style="{StaticResource InnerCardBorder}"
                                            Visibility="Collapsed" Margin="0,4,0,0">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock x:Name="WiFlagEditorLabel"
                                                       Text="{x:Static res:Strings.Label_FlagPlaceholder}"
                                                       Style="{StaticResource SectionTitleText}"
                                                       MinWidth="90" VerticalAlignment="Center"
                                                       Margin="0,0,12,0"/>
                                            <ctrl:PaletteStrip x:Name="WiFlagPalette" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ctrl:SectionCard>
                        </StackPanel>
                    </StackPanel>

                    <!-- ES (old-protocol) wheel content -->
                    <StackPanel x:Name="RpmEsContent" Visibility="Collapsed">
                        <ctrl:SectionCard Title="{x:Static res:Strings.Section_EsWheelRpmIndicator}"
                                          Subtitle="{x:Static res:Strings.Subtitle_EsLegacy}"
                                          Icon="{StaticResource IconBolt}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="{x:Static res:Strings.SliderLabel_IndicatorMode}" Style="{StaticResource SliderLabel}"/>
                                    <ComboBox x:Name="EsRpmIndicatorCombo" Width="140" SelectionChanged="EsRpmIndicatorCombo_Changed">
                                        <ComboBoxItem Content="{x:Static res:Strings.Option_SimHubMode}"/>
                                        <ComboBoxItem Content="{x:Static res:Strings.Option_AlwaysOn}"/>
                                        <ComboBoxItem Content="{x:Static res:Strings.Option_Off}"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="{x:Static res:Strings.SliderLabel_DisplayMode}" Style="{StaticResource SliderLabel}"/>
                                    <ComboBox x:Name="EsRpmDisplayCombo" Width="140" SelectionChanged="EsRpmDisplayCombo_Changed">
                                        <ComboBoxItem Content="{x:Static res:Strings.Option_Mode1}"/>
                                        <ComboBoxItem Content="{x:Static res:Strings.Option_Mode2}"/>
                                    </ComboBox>
                                </StackPanel>
                            </StackPanel>
                        </ctrl:SectionCard>
                    </StackPanel>

                    </StackPanel>
                <!-- /ScrollViewer -->
            </TabItem>

            <!-- ==================== BUTTONS TAB ==================== -->
            <TabItem x:Name="ButtonsTab" Header="{x:Static res:Strings.TabHeader_Buttons}" Visibility="Collapsed">
                <!-- ScrollViewer removed: SimHub host already provides scrolling -->
                    <StackPanel>

                    <ctrl:SectionCard Title="{x:Static res:Strings.Section_ButtonLedMode}" Icon="{StaticResource IconBolt}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <TextBlock Text="{x:Static res:Strings.SliderLabel_ButtonLedMode}" Style="{StaticResource SliderLabel}"/>
                                <ctrl:SegmentedControl x:Name="WheelButtonLedModeCombo" SelectionChanged="WheelButtonLedModeCombo_Changed">
                                    <ListBoxItem Content="{x:Static res:Strings.Option_Off}"/>
                                    <ListBoxItem Content="{x:Static res:Strings.Option_SimHubMode}"/>
                                    <ListBoxItem Content="{x:Static res:Strings.Option_Static}"/>
                                </ctrl:SegmentedControl>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <TextBlock Text="{x:Static res:Strings.SliderLabel_ButtonIdleEffect}" Style="{StaticResource SliderLabel}"/>
                                <ctrl:SegmentedControl x:Name="WheelButtonIdleEffectCombo" SelectionChanged="WheelButtonIdleEffectCombo_Changed">
                                    <ListBoxItem Content="{x:Static res:Strings.Option_Off}"/><ListBoxItem Content="{x:Static res:Strings.Option_Constant}"/>
                                    <ListBoxItem Content="{x:Static res:Strings.Option_Breathing}"/><ListBoxItem Content="{x:Static res:Strings.Option_ColorCycle}"/>
                                    <ListBoxItem Content="{x:Static res:Strings.Option_Rainbow}"/><ListBoxItem Content="{x:Static res:Strings.Option_SandFlow}"/>
                                    <ListBoxItem Content="{x:Static res:Strings.Option_RgbPulse}"/>
                                </ctrl:SegmentedControl>
                            </StackPanel>
                            <StackPanel x:Name="WheelButtonIdleSpeedRow" Orientation="Horizontal" Margin="0,4" Visibility="Collapsed">
                                <TextBlock Text="{x:Static res:Strings.SliderLabel_ButtonIdleSpeed}" Style="{StaticResource SliderLabel}"/>
                                <Slider x:Name="WheelButtonIdleSpeedSlider" Width="160" Minimum="200" Maximum="5000" TickFrequency="100" SmallChange="50" LargeChange="500" IsSnapToTickEnabled="True" ValueChanged="WheelButtonIdleSpeedSlider_ValueChanged"/>
                                <TextBlock x:Name="WheelButtonIdleSpeedValue" Width="60" Margin="4,0,0,0" VerticalAlignment="Center" Text="1000 ms"/>
                            </StackPanel>
                        </StackPanel>
                    </ctrl:SectionCard>

                    <ctrl:SectionCard Title="{x:Static res:Strings.Section_ButtonLedColors}"
                                      Subtitle="{x:Static res:Strings.Subtitle_ButtonLedColors}"
                                      Icon="{StaticResource IconButtons}">
                        <StackPanel>
                            <StackPanel x:Name="WheelButtonColorPanel" Orientation="Horizontal" Margin="0,0,0,10"/>
                            <Border x:Name="WiButtonEditorPanel" Style="{StaticResource InnerCardBorder}"
                                    Visibility="Collapsed" Margin="0,4,0,0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock x:Name="WiButtonEditorLabel"
                                               Text="{x:Static res:Strings.Label_ButtonPlaceholder}"
                                               Style="{StaticResource SectionTitleText}"
                                               MinWidth="100" VerticalAlignment="Center"
                                               Margin="0,0,12,0"/>
                                    <ctrl:PaletteStrip x:Name="WiButtonPalette" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ctrl:SectionCard>

                    </StackPanel>
                <!-- /ScrollViewer -->
            </TabItem>

            <!-- ==================== KNOBS TAB ==================== -->
            <TabItem x:Name="KnobsTab" Header="{x:Static res:Strings.TabHeader_Knobs}" Visibility="Collapsed">
                <!-- ScrollViewer removed: SimHub host already provides scrolling -->
                    <StackPanel>

                    <StackPanel x:Name="WheelKnobSection" Visibility="Collapsed">
                        <ctrl:SectionCard Title="{x:Static res:Strings.Section_KnobLedMode}" Icon="{StaticResource IconBolt}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="{x:Static res:Strings.SliderLabel_KnobLedMode}" Style="{StaticResource SliderLabel}"/>
                                    <ctrl:SegmentedControl x:Name="WheelKnobLedModeCombo" SelectionChanged="WheelKnobLedModeCombo_Changed">
                                        <ListBoxItem Content="{x:Static res:Strings.Option_Off}"/>
                                        <ListBoxItem Content="{x:Static res:Strings.Option_SimHubMode}"/>
                                        <ListBoxItem Content="{x:Static res:Strings.Option_Static}"/>
                                    </ctrl:SegmentedControl>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="{x:Static res:Strings.SliderLabel_KnobIdleEffect}" Style="{StaticResource SliderLabel}"/>
                                    <ctrl:SegmentedControl x:Name="WheelKnobIdleEffectCombo" SelectionChanged="WheelKnobIdleEffectCombo_Changed">
                                        <ListBoxItem Content="{x:Static res:Strings.Option_Off}"/>
                                        <ListBoxItem Content="{x:Static res:Strings.Option_Constant}"/>
                                        <ListBoxItem Content="{x:Static res:Strings.Option_Breathing}"/>
                                        <ListBoxItem Content="{x:Static res:Strings.Option_ColorCycle}"/>
                                        <ListBoxItem Content="{x:Static res:Strings.Option_Rainbow}"/>
                                        <ListBoxItem Content="{x:Static res:Strings.Option_SandFlow}"/>
                                        <ListBoxItem Content="{x:Static res:Strings.Option_RgbPulse}"/>
                                    </ctrl:SegmentedControl>
                                </StackPanel>
                                <StackPanel x:Name="WheelKnobIdleSpeedRow" Orientation="Horizontal" Margin="0,4" Visibility="Collapsed">
                                    <TextBlock Text="{x:Static res:Strings.SliderLabel_KnobIdleSpeed}" Style="{StaticResource SliderLabel}"/>
                                    <Slider x:Name="WheelKnobIdleSpeedSlider" Width="160" Minimum="200" Maximum="5000" TickFrequency="100" SmallChange="50" LargeChange="500" IsSnapToTickEnabled="True" ValueChanged="WheelKnobIdleSpeedSlider_ValueChanged"/>
                                    <TextBlock x:Name="WheelKnobIdleSpeedValue" Width="60" Margin="4,0,0,0" VerticalAlignment="Center" Text="1000 ms"/>
                                </StackPanel>
                            </StackPanel>
                        </ctrl:SectionCard>

                        <ctrl:SectionCard Title="{x:Static res:Strings.Section_KnobSettings}" Icon="{StaticResource IconKnob}">
                            <StackPanel>
                                <!-- Signal mode subsection -->
                                <TextBlock Style="{StaticResource SectionTitleText}" Margin="0,0,0,8">
                                    <Run Text="{x:Static res:Strings.Label_SignalMode}"/>
                                    <Run Text="{x:Static res:Strings.Subtitle_SignalMode}"
                                         Foreground="{DynamicResource TextFaintBrush}"
                                         FontFamily="{DynamicResource FontMono}"
                                         FontWeight="Normal"/>
                                </TextBlock>
                                <!-- Per-knob Btn/Knob chips (built dynamically when firmware supports
                                     per-knob signal mode). Each cell is a KNOB N card + 2-segment chip. -->
                                <UniformGrid x:Name="WiSignalModeGrid" Columns="5" Rows="1" Margin="0,0,0,18"/>
                                <!-- Legacy combined "All Rotaries" mode — fallback for firmware that
                                     doesn't support per-knob signal mode. Shown only when per-knob isn't
                                     reported; the WiSignalModeGrid above is collapsed in that case. -->
                                <StackPanel x:Name="WiKnobModeLegacyPanel" Orientation="Horizontal"
                                            Margin="0,0,0,18" Visibility="Collapsed">
                                    <TextBlock Text="{x:Static res:Strings.SliderLabel_AllRotaries}" Style="{StaticResource SliderLabel}"/>
                                    <ctrl:SegmentedControl x:Name="WiKnobModeCombo"
                                                           SelectionChanged="WiKnobModeCombo_Changed">
                                        <ListBoxItem Content="{x:Static res:Strings.Option_Buttons}"/>
                                        <ListBoxItem Content="{x:Static res:Strings.Option_Knob}"/>
                                    </ctrl:SegmentedControl>
                                </StackPanel>

                                <!-- Colours subsection -->
                                <TextBlock Style="{StaticResource SectionTitleText}" Margin="0,0,0,8">
                                    <Run Text="{x:Static res:Strings.Label_Colours}"/>
                                    <Run Text="{x:Static res:Strings.Subtitle_KnobColours}"
                                         Foreground="{DynamicResource TextFaintBrush}"
                                         FontFamily="{DynamicResource FontMono}"
                                         FontWeight="Normal"/>
                                </TextBlock>
                                <!-- One KnobRingViz per knob (built dynamically — invisible knobs collapsed) -->
                                <UniformGrid x:Name="WiKnobsGrid" Columns="5" Rows="1" Margin="0,0,0,14"/>

                                <!-- Editor: shown once the user picks a slot/centre -->
                                <Border x:Name="WiKnobEditorPanel" Style="{StaticResource InnerCardBorder}"
                                        Visibility="Collapsed">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock x:Name="WiKnobEditorLabel" Grid.Column="0"
                                                       Text="{x:Static res:Strings.Label_KnobEditing}"
                                                       Style="{StaticResource SectionTitleText}"
                                                       VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <Button Content="{x:Static res:Strings.Button_FillRingWithSelected}" Margin="0,0,8,0"
                                                        Click="WiKnobFillRing_Click"/>
                                                <Button Content="{x:Static res:Strings.Button_CopyKnobToAll}"
                                                        Click="WiKnobCopyToAll_Click"/>
                                            </StackPanel>
                                        </Grid>
                                        <ctrl:PaletteStrip x:Name="WiKnobPalette"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ctrl:SectionCard>
                    </StackPanel>

                    <!-- Legacy panels kept as collapsed stubs so code-behind that
                         populates WheelKnobPanel + WheelKnobRingPanel still resolves. -->
                    <StackPanel x:Name="WheelKnobRingSection" Visibility="Collapsed">
                        <StackPanel x:Name="WheelKnobPanel"/>
                        <StackPanel x:Name="WheelKnobRingPanel"/>
                        <!-- Per-knob signal mode stubs (now driven by inline chips above each
                             KnobRingViz). Plain ComboBox + StackPanel keeps the x:Names + handler
                             contract intact for the existing code-behind without dragging extra
                             SegmentedControl templates into the layout pass. -->
                        <StackPanel x:Name="WiKnobSignalModePanel">
                            <StackPanel x:Name="WiKnobSignalMode0Row">
                                <ComboBox x:Name="WiKnobSignalMode0Combo" SelectionChanged="WiKnobSignalMode0Combo_Changed">
                                    <ComboBoxItem Content="Buttons"/><ComboBoxItem Content="Knob"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel x:Name="WiKnobSignalMode1Row">
                                <ComboBox x:Name="WiKnobSignalMode1Combo" SelectionChanged="WiKnobSignalMode1Combo_Changed">
                                    <ComboBoxItem Content="Buttons"/><ComboBoxItem Content="Knob"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel x:Name="WiKnobSignalMode2Row">
                                <ComboBox x:Name="WiKnobSignalMode2Combo" SelectionChanged="WiKnobSignalMode2Combo_Changed">
                                    <ComboBoxItem Content="Buttons"/><ComboBoxItem Content="Knob"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel x:Name="WiKnobSignalMode3Row">
                                <ComboBox x:Name="WiKnobSignalMode3Combo" SelectionChanged="WiKnobSignalMode3Combo_Changed">
                                    <ComboBoxItem Content="Buttons"/><ComboBoxItem Content="Knob"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel x:Name="WiKnobSignalMode4Row">
                                <ComboBox x:Name="WiKnobSignalMode4Combo" SelectionChanged="WiKnobSignalMode4Combo_Changed">
                                    <ComboBoxItem Content="Buttons"/><ComboBoxItem Content="Knob"/>
                                </ComboBox>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    </StackPanel>
                <!-- /ScrollViewer -->
            </TabItem>

            <!-- ==================== FILES TAB ==================== -->
            <!-- Combines the legacy plugin-pane Upload + Wheel Files tabs.
                 Visible only when the wheel has reported a dashboard (same
                 gate as DashboardTab). Handlers live in MozaWheelSettingsControl.Files.cs. -->
            <TabItem x:Name="FilesTab" Header="{x:Static res:Strings.TabHeader_Files}" Visibility="Collapsed">
                <StackPanel>

                    <!-- Work-in-progress banner -->
                    <Border Style="{StaticResource BannerBorder}">
                        <StackPanel>
                            <TextBlock FontSize="14" FontWeight="Bold" Foreground="{StaticResource AmberBrush}"
                                       Text="{x:Static res:Strings.Banner_DashboardUploadNotWorkingYet}"/>
                            <TextBlock TextWrapping="Wrap" Foreground="#FFE082" FontSize="11" Margin="0,4,0,0"
                                       Text="{x:Static res:Strings.Hint_DashboardUploadNotWorking}"/>
                        </StackPanel>
                    </Border>

                    <ctrl:SectionCard Title="{x:Static res:Strings.Section_DashboardUpload}"
                                      Subtitle="{x:Static res:Strings.Subtitle_DashboardUpload}"
                                      Icon="{StaticResource IconDiag}">
                        <StackPanel>
                            <TextBlock TextWrapping="Wrap" Style="{StaticResource MutedHintText}" Margin="0,0,0,12"
                                       Text="{x:Static res:Strings.Hint_UploadStatusFormat}"/>
                            <TextBlock Text="{x:Static res:Strings.Label_Source}" Style="{StaticResource MutedHintText}" Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <RadioButton x:Name="UploadSourceFileRadio" Content="{x:Static res:Strings.Option_LocalMzdashFile}"
                                             GroupName="WiUploadSource" IsChecked="True"
                                             Margin="0,0,16,0" VerticalAlignment="Center"
                                             Foreground="{StaticResource TextBrush}"
                                             Click="UploadSourceRadio_Click"/>
                                <RadioButton x:Name="UploadSourceLibraryRadio" Content="{x:Static res:Strings.Option_DashboardLibrary}"
                                             GroupName="WiUploadSource"
                                             VerticalAlignment="Center"
                                             Foreground="{StaticResource TextBrush}"
                                             Click="UploadSourceRadio_Click"/>
                            </StackPanel>
                            <StackPanel x:Name="UploadFilePanel" Orientation="Horizontal" Margin="0,0,0,8">
                                <Button Content="{x:Static res:Strings.Button_PickMzdash}" Margin="0,0,8,0" Click="UploadPickFile_Click"/>
                                <TextBlock x:Name="UploadPickedFileText" VerticalAlignment="Center"
                                           Style="{StaticResource MutedHintText}"
                                           Text="{x:Static res:Strings.Status_NoFileSelected}" TextTrimming="CharacterEllipsis"
                                           MaxWidth="500"/>
                            </StackPanel>
                            <StackPanel x:Name="UploadLibraryPanel" Orientation="Horizontal" Margin="0,0,0,8"
                                        Visibility="Collapsed">
                                <TextBlock Text="{x:Static res:Strings.Label_Dashboard}" VerticalAlignment="Center" Width="100"/>
                                <ComboBox x:Name="UploadLibraryCombo" Width="280" Margin="0,0,8,0"
                                          SelectionChanged="UploadLibraryCombo_SelectionChanged"/>
                                <Button Content="{x:Static res:Strings.Button_Refresh}" Click="UploadLibraryRefresh_Click"/>
                            </StackPanel>
                            <Separator Margin="0,8,0,12"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Button x:Name="UploadNowButton" Content="{x:Static res:Strings.Button_UploadNow}" MinWidth="120"
                                        Style="{StaticResource MozaButtonPrimary}"
                                        Click="UploadNow_Click"/>
                                <TextBlock x:Name="UploadStatusText" VerticalAlignment="Center"
                                           Style="{StaticResource MutedHintText}" Margin="14,0,0,0"
                                           Text="{x:Static res:Strings.Status_Idle}"/>
                            </StackPanel>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="{x:Static res:Strings.Label_DashboardName}" Style="{StaticResource KvKeyText}" Margin="0,3"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="UploadInfoNameText" Style="{StaticResource KvValueText}" Margin="0,3" Text="—"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="{x:Static res:Strings.Label_RawSize}" Style="{StaticResource KvKeyText}" Margin="0,3"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="UploadInfoRawSizeText" Style="{StaticResource KvValueText}" Margin="0,3" Text="—"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="{x:Static res:Strings.Label_Md5}" Style="{StaticResource KvKeyText}" Margin="0,3"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="UploadInfoMd5Text" Style="{StaticResource KvValueText}" Margin="0,3" Text="—"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="{x:Static res:Strings.Label_InFlight}" Style="{StaticResource KvKeyText}" Margin="0,3"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="UploadInfoInFlightText" Style="{StaticResource KvValueText}" Margin="0,3" Text="—"/>
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="{x:Static res:Strings.Label_LastAckBytes}" Style="{StaticResource KvKeyText}" Margin="0,3"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" x:Name="UploadInfoProgressText" Style="{StaticResource KvValueText}" Margin="0,3" Text="—"/>
                                <TextBlock Grid.Row="5" Grid.Column="0" Text="{x:Static res:Strings.Label_LastAckStatus}" Style="{StaticResource KvKeyText}" Margin="0,3"/>
                                <TextBlock Grid.Row="5" Grid.Column="1" x:Name="UploadInfoStatusByteText" Style="{StaticResource KvValueText}" Margin="0,3" Text="—"/>
                            </Grid>
                            <TextBlock TextWrapping="Wrap" Style="{StaticResource MutedHintText}" Margin="0,14,0,0"
                                       Text="{x:Static res:Strings.Hint_UploadRequiresConnection}"/>
                        </StackPanel>
                    </ctrl:SectionCard>

                    <ctrl:SectionCard Title="{x:Static res:Strings.Section_WheelFiles}"
                                      Subtitle="{x:Static res:Strings.Subtitle_WheelFiles}"
                                      Icon="{StaticResource IconDiag}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Button x:Name="WheelFilesRefreshButton" Content="{x:Static res:Strings.Button_Refresh}"
                                        Click="WheelFilesRefresh_Click" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock x:Name="WheelFilesStatusBox" VerticalAlignment="Center"
                                           Style="{StaticResource MutedHintText}" Text="—"/>
                            </StackPanel>
                            <TextBlock TextWrapping="Wrap" Style="{StaticResource MutedHintText}" Margin="0,0,0,10"
                                       Text="{x:Static res:Strings.Hint_DeleteDisabled}"/>
                            <DataGrid x:Name="WheelFilesGrid" AutoGenerateColumns="False" IsReadOnly="True"
                                      CanUserAddRows="False" CanUserDeleteRows="False" CanUserResizeRows="False"
                                      SelectionMode="Single" HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                      BorderThickness="1" RowHeight="24">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="{x:Static res:Strings.DataGridHeader_State}" Binding="{Binding State}" Width="80"/>
                                    <DataGridTextColumn Header="{x:Static res:Strings.DataGridHeader_Title}" Binding="{Binding Title}" Width="*"/>
                                    <DataGridTextColumn Header="{x:Static res:Strings.DataGridHeader_DirName}" Binding="{Binding DirName}" Width="200"/>
                                    <DataGridTextColumn Header="{x:Static res:Strings.DataGridHeader_Hash}" Binding="{Binding HashShort}" Width="120"/>
                                    <DataGridTextColumn Header="{x:Static res:Strings.DataGridHeader_LastModified}" Binding="{Binding LastModified}" Width="170"/>
                                    <DataGridTemplateColumn Header="" Width="80">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="{x:Static res:Strings.Button_Delete}" Padding="8,2"
                                                        Click="WheelFilesDelete_Click"
                                                        Tag="{Binding}"
                                                        IsEnabled="False"
                                                        ToolTip="{x:Static res:Strings.Tooltip_DeleteDisabled}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </ctrl:SectionCard>

                </StackPanel>
            </TabItem>

            <!-- ==================== SLEEP TAB ==================== -->
            <TabItem x:Name="SleepTab" Header="{x:Static res:Strings.TabHeader_Sleep}" Visibility="Collapsed">
                <!-- ScrollViewer removed: SimHub host already provides scrolling.
                     StackPanel wraps the card so the SectionCard sizes to its
                     content instead of stretching to the full TabItem height
                     (TabItem's ContentPresenter stretches its direct child by default). -->
                <StackPanel>
                    <ctrl:SectionCard Title="{x:Static res:Strings.Section_SleepLight}"
                                      Subtitle="{x:Static res:Strings.Subtitle_SleepLight}"
                                      Icon="{StaticResource IconMisc}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <TextBlock Text="{x:Static res:Strings.SliderLabel_Mode}" Style="{StaticResource SliderLabel}"/>
                                <ctrl:SegmentedControl x:Name="WheelSleepModeCombo" SelectionChanged="WheelSleepModeCombo_Changed">
                                    <ListBoxItem Content="{x:Static res:Strings.Option_Off}"/>
                                    <ListBoxItem Content="{x:Static res:Strings.Option_Constant}"/>
                                    <ListBoxItem Content="{x:Static res:Strings.Option_Breathing}"/>
                                    <ListBoxItem Content="{x:Static res:Strings.Option_ColorCycle}"/>
                                    <ListBoxItem Content="{x:Static res:Strings.Option_Rainbow}"/>
                                    <ListBoxItem Content="{x:Static res:Strings.Option_SandFlow}"/>
                                    <ListBoxItem Content="{x:Static res:Strings.Option_RgbPulse}"/>
                                </ctrl:SegmentedControl>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <TextBlock Text="{x:Static res:Strings.SliderLabel_StandbyTime}" Style="{StaticResource SliderLabel}"/>
                                <ComboBox x:Name="WheelSleepTimeoutCombo" Width="140" SelectionChanged="WheelSleepTimeoutCombo_Changed">
                                    <ComboBoxItem Tag="1" Content="{x:Static res:Strings.Option_Time1Min}"/>
                                    <ComboBoxItem Tag="2" Content="{x:Static res:Strings.Option_Time2Min}"/>
                                    <ComboBoxItem Tag="3" Content="{x:Static res:Strings.Option_Time3Min}"/>
                                    <ComboBoxItem Tag="4" Content="{x:Static res:Strings.Option_Time4Min}"/>
                                    <ComboBoxItem Tag="5" Content="{x:Static res:Strings.Option_Time5Min}"/>
                                    <ComboBoxItem Tag="10" Content="{x:Static res:Strings.Option_Time10Min}"/>
                                    <ComboBoxItem Tag="15" Content="{x:Static res:Strings.Option_Time15Min}"/>
                                    <ComboBoxItem Tag="20" Content="{x:Static res:Strings.Option_Time20Min}"/>
                                    <ComboBoxItem Tag="25" Content="{x:Static res:Strings.Option_Time25Min}"/>
                                    <ComboBoxItem Tag="30" Content="{x:Static res:Strings.Option_Time30Min}"/>
                                    <ComboBoxItem Tag="35" Content="{x:Static res:Strings.Option_Time35Min}"/>
                                    <ComboBoxItem Tag="40" Content="{x:Static res:Strings.Option_Time40Min}"/>
                                    <ComboBoxItem Tag="45" Content="{x:Static res:Strings.Option_Time45Min}"/>
                                    <ComboBoxItem Tag="60" Content="{x:Static res:Strings.Option_Time1Hour}"/>
                                    <ComboBoxItem Tag="120" Content="{x:Static res:Strings.Option_Time2Hour}"/>
                                    <ComboBoxItem Tag="180" Content="{x:Static res:Strings.Option_Time3Hour}"/>
                                    <ComboBoxItem Tag="240" Content="{x:Static res:Strings.Option_Time4Hour}"/>
                                    <ComboBoxItem Tag="300" Content="{x:Static res:Strings.Option_Time5Hour}"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel x:Name="WheelSleepSpeedRow" Orientation="Horizontal" Margin="0,4" Visibility="Collapsed">
                                <TextBlock Text="{x:Static res:Strings.SliderLabel_Speed}" Style="{StaticResource SliderLabel}"/>
                                <Slider x:Name="WheelSleepSpeedSlider" Width="160" Minimum="200" Maximum="5000" TickFrequency="100" SmallChange="50" LargeChange="500" IsSnapToTickEnabled="True" ValueChanged="WheelSleepSpeedSlider_ValueChanged"/>
                                <TextBlock x:Name="WheelSleepSpeedValue" Width="60" Margin="4,0,0,0" VerticalAlignment="Center" Text="1000 ms"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <TextBlock Text="{x:Static res:Strings.SliderLabel_Color}" Style="{StaticResource SliderLabel}"/>
                                <Border x:Name="WheelSleepColorSwatch" Width="36" Height="36"
                                        BorderBrush="{StaticResource BorderBrightBrush}" BorderThickness="1"
                                        CornerRadius="18" Background="Black" Cursor="Hand"
                                        MouseLeftButtonUp="WheelSleepColorSwatch_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </ctrl:SectionCard>
                </StackPanel>
            </TabItem>

        </TabControl>
    </DockPanel>
</UserControl>
