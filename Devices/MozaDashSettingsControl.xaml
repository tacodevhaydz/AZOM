<UserControl x:Class="MozaPlugin.Devices.MozaDashSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:MozaControls"
             xmlns:res="clr-namespace:MozaPlugin.Resources"
             Padding="14"
             TextElement.Foreground="{DynamicResource TextBrush}"
             TextElement.FontFamily="{DynamicResource FontUi}"
             TextElement.FontSize="13">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MozaPlugin;component/Themes/MozaTheme.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/MozaPlugin;component/Themes/MozaIcons.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="SectionHeader" TargetType="TextBlock" BasedOn="{StaticResource SectionTitleText}">
                <Setter Property="Margin" Value="0,20,0,8"/>
                <Setter Property="FontSize" Value="14"/>
            </Style>
            <Style x:Key="SliderLabel" TargetType="TextBlock" BasedOn="{StaticResource LabelText}">
                <Setter Property="Width" Value="180"/>
            </Style>
            <Style x:Key="SliderValue" TargetType="TextBlock">
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Width" Value="60"/>
                <Setter Property="TextAlignment" Value="Right"/>
                <Setter Property="Margin" Value="8,0,0,0"/>
                <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
                <Setter Property="Foreground" Value="{StaticResource CyanBrush}"/>
            </Style>
            <Style x:Key="SettingSlider" TargetType="Slider" BasedOn="{StaticResource MozaSlider}">
                <Setter Property="Width" Value="300"/>
                <Setter Property="IsSnapToTickEnabled" Value="True"/>
            </Style>
            <Style x:Key="LedIndex" TargetType="TextBlock">
                <Setter Property="Width" Value="28"/>
                <Setter Property="TextAlignment" Value="Center"/>
                <Setter Property="Foreground" Value="{StaticResource TextFaintBrush}"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="Margin" Value="2,0"/>
            </Style>

            <Style TargetType="Button" BasedOn="{StaticResource MozaButton}"/>
            <Style TargetType="CheckBox" BasedOn="{StaticResource MozaCheckBox}"/>
            <Style TargetType="ComboBox" BasedOn="{StaticResource MozaCombo}"/>
            <Style TargetType="Slider" BasedOn="{StaticResource MozaSlider}"/>
            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            </Style>
            <Style TargetType="Separator">
                <Setter Property="Background" Value="{StaticResource BorderBrush}"/>
                <Setter Property="Height" Value="1"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <!-- ScrollViewer removed: SimHub host already provides scrolling -->
        <StackPanel>

            <!-- Device header -->
            <Border Background="{StaticResource BgCardBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="8"
                    Padding="18,14" Margin="0,0,0,14">
                <StackPanel Orientation="Horizontal">
                    <Ellipse x:Name="StatusDot" Width="10" Height="10" Fill="Gray"
                             VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <TextBlock Text="{x:Static res:Strings.Section_MozaDashboard}"
                               FontWeight="SemiBold" FontSize="14"
                               VerticalAlignment="Center" Margin="0,0,18,0"/>
                    <TextBlock x:Name="StatusText" Style="{StaticResource MutedHintText}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <TabControl x:Name="DashTabs" Style="{StaticResource MozaTabControl}" Margin="0,4,0,0">

            <TabItem x:Name="DashLedsTab" Header="{x:Static res:Strings.TabHeader_Leds}">
                <StackPanel>

            <StackPanel x:Name="DashNotDetectedPanel">
                <TextBlock Text="{x:Static res:Strings.Status_SearchingForDashboard}"
                           Style="{StaticResource MutedHintText}" FontStyle="Italic" Margin="0,10"/>
            </StackPanel>

            <StackPanel x:Name="DashPanel" Visibility="Collapsed">

                <ctrl:SectionCard Title="{x:Static res:Strings.Section_IndicatorModes}" Icon="{StaticResource IconBolt}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <TextBlock Text="{x:Static res:Strings.SliderLabel_RpmIndicatorMode}" Style="{StaticResource SliderLabel}"/>
                            <ComboBox x:Name="DashRpmIndicatorCombo" Width="140" SelectionChanged="DashRpmIndicatorCombo_Changed">
                                <ComboBoxItem Content="{x:Static res:Strings.Option_SimHubMode}"/>
                                <ComboBoxItem Content="{x:Static res:Strings.Option_AlwaysOn}"/>
                                <ComboBoxItem Content="{x:Static res:Strings.Option_Off}"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <TextBlock Text="{x:Static res:Strings.SliderLabel_RpmDisplayMode}" Style="{StaticResource SliderLabel}"/>
                            <ComboBox x:Name="DashRpmDisplayCombo" Width="140" SelectionChanged="DashRpmDisplayCombo_Changed">
                                <ComboBoxItem Content="{x:Static res:Strings.Option_Mode1}"/>
                                <ComboBoxItem Content="{x:Static res:Strings.Option_Mode2}"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <TextBlock Text="{x:Static res:Strings.SliderLabel_FlagsIndicatorMode}" Style="{StaticResource SliderLabel}"/>
                            <ComboBox x:Name="DashFlagsIndicatorCombo" Width="140" SelectionChanged="DashFlagsIndicatorCombo_Changed">
                                <ComboBoxItem Content="{x:Static res:Strings.Option_SimHubMode}"/>
                                <ComboBoxItem Content="{x:Static res:Strings.Option_AlwaysOn}"/>
                                <ComboBoxItem Content="{x:Static res:Strings.Option_Off}"/>
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>
                </ctrl:SectionCard>

                <ctrl:SectionCard Title="{x:Static res:Strings.Section_Brightness}" Icon="{StaticResource IconLed}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <TextBlock Text="{x:Static res:Strings.SliderLabel_RpmBrightness}" Style="{StaticResource SliderLabel}"/>
                            <Slider x:Name="DashRpmBrightnessSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="DashRpmBrightnessSlider_ValueChanged"/>
                            <TextBlock x:Name="DashRpmBrightnessValue" Style="{StaticResource SliderValue}" Text="100"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <TextBlock Text="{x:Static res:Strings.SliderLabel_FlagsBrightness}" Style="{StaticResource SliderLabel}"/>
                            <Slider x:Name="DashFlagsBrightnessSlider" Style="{StaticResource SettingSlider}" Minimum="0" Maximum="100" TickFrequency="1" ValueChanged="DashFlagsBrightnessSlider_ValueChanged"/>
                            <TextBlock x:Name="DashFlagsBrightnessValue" Style="{StaticResource SliderValue}" Text="100"/>
                        </StackPanel>
                    </StackPanel>
                </ctrl:SectionCard>

                <ctrl:SectionCard Title="{x:Static res:Strings.Section_RpmLedColors}" Icon="{StaticResource IconLed}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                            <TextBlock Style="{StaticResource LedIndex}" Text="1"/><TextBlock Style="{StaticResource LedIndex}" Text="2"/>
                            <TextBlock Style="{StaticResource LedIndex}" Text="3"/><TextBlock Style="{StaticResource LedIndex}" Text="4"/>
                            <TextBlock Style="{StaticResource LedIndex}" Text="5"/><TextBlock Style="{StaticResource LedIndex}" Text="6"/>
                            <TextBlock Style="{StaticResource LedIndex}" Text="7"/><TextBlock Style="{StaticResource LedIndex}" Text="8"/>
                            <TextBlock Style="{StaticResource LedIndex}" Text="9"/><TextBlock Style="{StaticResource LedIndex}" Text="10"/>
                        </StackPanel>
                        <StackPanel x:Name="DashRpmColorPanel" Orientation="Horizontal" Margin="0,0,0,10"/>
                    </StackPanel>
                </ctrl:SectionCard>

                <ctrl:SectionCard Title="{x:Static res:Strings.Section_RpmBlinkColors}"
                                  Subtitle="{x:Static res:Strings.Subtitle_RpmBlinkColors}"
                                  Icon="{StaticResource IconLed}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                            <TextBlock Style="{StaticResource LedIndex}" Text="1"/><TextBlock Style="{StaticResource LedIndex}" Text="2"/>
                            <TextBlock Style="{StaticResource LedIndex}" Text="3"/><TextBlock Style="{StaticResource LedIndex}" Text="4"/>
                            <TextBlock Style="{StaticResource LedIndex}" Text="5"/><TextBlock Style="{StaticResource LedIndex}" Text="6"/>
                            <TextBlock Style="{StaticResource LedIndex}" Text="7"/><TextBlock Style="{StaticResource LedIndex}" Text="8"/>
                            <TextBlock Style="{StaticResource LedIndex}" Text="9"/><TextBlock Style="{StaticResource LedIndex}" Text="10"/>
                        </StackPanel>
                        <StackPanel x:Name="DashRpmBlinkColorPanel" Orientation="Horizontal" Margin="0,0,0,10"/>
                    </StackPanel>
                </ctrl:SectionCard>

                <ctrl:SectionCard Title="{x:Static res:Strings.Section_FlagLedColors}" Icon="{StaticResource IconAlert}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                            <TextBlock Style="{StaticResource LedIndex}" Text="1"/><TextBlock Style="{StaticResource LedIndex}" Text="2"/>
                            <TextBlock Style="{StaticResource LedIndex}" Text="3"/><TextBlock Style="{StaticResource LedIndex}" Text="4"/>
                            <TextBlock Style="{StaticResource LedIndex}" Text="5"/><TextBlock Style="{StaticResource LedIndex}" Text="6"/>
                        </StackPanel>
                        <StackPanel x:Name="DashFlagColorPanel" Orientation="Horizontal" Margin="0,0,0,10"/>
                    </StackPanel>
                </ctrl:SectionCard>

            </StackPanel>
                </StackPanel>
            </TabItem>

            <TabItem x:Name="DashMgmtTab" Header="{x:Static res:Strings.TabHeader_Dashboard}" Visibility="Collapsed">
                <ContentControl x:Name="DashMgmtHostCm2"/>
            </TabItem>

            </TabControl>
        </StackPanel>
</UserControl>
