<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:MozaControls"
                    xmlns:res="clr-namespace:MozaPlugin.Resources">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/MozaPlugin;component/Themes/MozaTheme.xaml"/>
        <ResourceDictionary Source="pack://application:,,,/MozaPlugin;component/Themes/MozaIcons.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- Converters -->
    <controls:EmptyStringToVisibilityConverter x:Key="EmptyStringToVisibility"/>

    <!-- ============================================================ -->
    <!-- OffOnToggle                                                   -->
    <!-- ============================================================ -->

    <Style TargetType="{x:Type controls:OffOnToggle}">
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource FontUi}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="MinHeight" Value="34"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:OffOnToggle}">
                    <StackPanel Orientation="Horizontal">
                        <!-- Content label (only visible when the toggle was given Content="..."),
                             rendered to the left of the pill so it acts as a drop-in for any
                             CheckBox with a Content text. EmptyStringToVisibility hides the
                             column when Content is empty. -->
                        <ContentPresenter x:Name="Lbl"
                                          VerticalAlignment="Center"
                                          Margin="0,0,12,0"
                                          TextBlock.Foreground="{TemplateBinding Foreground}"
                                          TextBlock.FontFamily="{TemplateBinding FontFamily}"
                                          TextBlock.FontSize="{TemplateBinding FontSize}"
                                          Visibility="{Binding Content, RelativeSource={RelativeSource TemplatedParent},
                                                       Converter={StaticResource EmptyStringToVisibility}}"/>
                        <Border x:Name="Bd"
                                Background="{StaticResource BgDeepBrush}"
                                BorderBrush="{StaticResource BorderBrightBrush}"
                                BorderThickness="1"
                                CornerRadius="5"
                                Padding="3"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" MinWidth="42"/>
                                    <ColumnDefinition Width="*" MinWidth="42"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="OffPill" Grid.Column="0"
                                        Background="Transparent"
                                        CornerRadius="3"
                                        Padding="14,6">
                                    <TextBlock Text="{x:Static res:Strings.Toggle_Off}"
                                               x:Name="OffText"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextDimBrush}"/>
                                </Border>
                                <Border x:Name="OnPill" Grid.Column="1"
                                        Background="Transparent"
                                        CornerRadius="3"
                                        Padding="14,6">
                                    <TextBlock Text="{x:Static res:Strings.Toggle_On}"
                                               x:Name="OnText"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextDimBrush}"/>
                                </Border>
                            </Grid>
                        </Border>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <!-- DynamicResource lookup picks up per-section overrides
                                 (Throttle = green, Brake / Handbrake = red, etc.). -->
                            <Setter TargetName="OnPill" Property="Background" Value="{DynamicResource ToggleOnBrush}"/>
                            <Setter TargetName="OnPill" Property="BorderBrush" Value="{StaticResource BorderGlowBrush}"/>
                            <Setter TargetName="OnText" Property="Foreground" Value="{DynamicResource ToggleOnTextBrush}"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="False">
                            <Setter TargetName="OffPill" Property="Background" Value="{StaticResource BgCardBrush}"/>
                            <Setter TargetName="OffText" Property="Foreground" Value="{StaticResource TextBrush}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BorderGlowBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================ -->
    <!-- SegmentedControl — horizontal radio-group list                -->
    <!-- ============================================================ -->

    <Style x:Key="SegmentedItemStyle" TargetType="ListBoxItem">
        <Setter Property="Foreground" Value="{StaticResource TextDimBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource FontUi}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="14,6"/>
        <Setter Property="Margin" Value="2,0,0,0"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="Bd"
                            Background="Transparent"
                            CornerRadius="3"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          TextBlock.Foreground="{TemplateBinding Foreground}"
                                          TextBlock.FontFamily="{TemplateBinding FontFamily}"
                                          TextBlock.FontSize="{TemplateBinding FontSize}"
                                          TextBlock.FontWeight="{TemplateBinding FontWeight}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <!-- DynamicResource so a parent container can swap the
                                 active-button tint (e.g. red on the Handbrake card)
                                 by overriding ToggleOnBrush / ToggleOnTextBrush in
                                 its local Resources. -->
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ToggleOnBrush}"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BorderGlowBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource ToggleOnTextBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type controls:SegmentedControl}">
        <Setter Property="Background" Value="{StaticResource BgDeepBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrightBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Padding" Value="3"/>
        <Setter Property="ItemContainerStyle" Value="{StaticResource SegmentedItemStyle}"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Hidden"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:SegmentedControl}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="5"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ItemsPresenter/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================ -->
    <!-- MozaCurveEditor                                               -->
    <!-- ============================================================ -->
    <!-- The shared template (MozaCurveEditorTemplate) and the 6-band   -->
    <!-- MozaEqualizerLineStyle live in MozaTheme.xaml so SettingsControl-->
    <!-- can see them via its merged-dictionary lookup. This file just  -->
    <!-- supplies the unkeyed default style that WPF auto-applies to    -->
    <!-- every MozaCurveEditor instance.                                -->

    <Style TargetType="{x:Type controls:MozaCurveEditor}">
        <Setter Property="MinHeight" Value="280"/>
        <Setter Property="AccentBrush" Value="{StaticResource CyanBrush}"/>
        <Setter Property="Template" Value="{StaticResource MozaCurveEditorTemplate}"/>
    </Style>

    <!-- ============================================================ -->
    <!-- MozaRangeSlider                                               -->
    <!-- ============================================================ -->
    <!-- Shared template lives in MozaTheme.xaml (same split as
         MozaCurveEditor above) — this is just the unkeyed default style
         WPF auto-applies to every MozaRangeSlider instance. -->

    <Style TargetType="{x:Type controls:MozaRangeSlider}">
        <Setter Property="MinHeight" Value="90"/>
        <Setter Property="AccentBrush" Value="{StaticResource AmberBrush}"/>
        <Setter Property="Template" Value="{StaticResource MozaRangeSliderTemplate}"/>
    </Style>

    <!-- ============================================================ -->
    <!-- SteeringArc                                                   -->
    <!-- ============================================================ -->

    <Style TargetType="{x:Type controls:SteeringArc}">
        <Setter Property="Width" Value="220"/>
        <Setter Property="Height" Value="220"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:SteeringArc}">
                    <Grid Width="220" Height="220">
                        <!-- background arc reference (faint full sweep) -->
                        <Path Stroke="{StaticResource BorderBrush}" StrokeThickness="3"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="{x:Null}">
                            <Path.Data>
                                <PathGeometry>
                                    <PathFigure StartPoint="44.97,175.03" IsClosed="False">
                                        <ArcSegment Point="175.03,175.03" Size="92,92"
                                                    SweepDirection="Clockwise" IsLargeArc="True"/>
                                    </PathFigure>
                                </PathGeometry>
                            </Path.Data>
                        </Path>
                        <!-- active arc -->
                        <Path Data="{Binding ArcGeometry, RelativeSource={RelativeSource TemplatedParent}}"
                              StrokeThickness="3"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Fill="{x:Null}"
                              Effect="{StaticResource CyanGlowEffect}">
                            <Path.Stroke>
                                <LinearGradientBrush StartPoint="0,1" EndPoint="1,0">
                                    <GradientStop Color="{StaticResource CyanColor}" Offset="0"/>
                                    <GradientStop Color="{StaticResource GreenColor}" Offset="1"/>
                                </LinearGradientBrush>
                            </Path.Stroke>
                        </Path>
                        <!-- 0° reference notch (green) -->
                        <Path Stroke="{StaticResource GreenBrush}" StrokeThickness="2"
                              Effect="{StaticResource GreenGlowEffect}"
                              Data="M 110 14 L 110 22"/>
                        <!-- centre readout -->
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="{Binding AngleText, RelativeSource={RelativeSource TemplatedParent}}"
                                       FontFamily="{StaticResource FontMono}"
                                       FontSize="42"
                                       Foreground="{StaticResource CyanBrush}"
                                       FontWeight="Medium"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{x:Static res:Strings.Label_SteeringAngle}"
                                       FontFamily="{StaticResource FontUi}"
                                       FontSize="10"
                                       Foreground="{StaticResource TextFaintBrush}"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                        <!-- Position dot at end of active arc. Recompute() emits
                             DotX/DotY as the dot's CENTER on the arc; Canvas.Left/Top
                             anchor by top-left, so the negative margin (= -half the
                             ellipse size) shifts the dot up-left so its center
                             lands on the anchor. -->
                        <Canvas IsHitTestVisible="False">
                            <Ellipse Width="8" Height="8"
                                     Margin="-4,-4,0,0"
                                     Fill="{StaticResource CyanBrush}"
                                     Effect="{StaticResource CyanGlowEffect}"
                                     Canvas.Left="{Binding DotX, RelativeSource={RelativeSource TemplatedParent}}"
                                     Canvas.Top="{Binding DotY, RelativeSource={RelativeSource TemplatedParent}}"/>
                        </Canvas>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================ -->
    <!-- BandwidthSparkline                                            -->
    <!-- ============================================================ -->

    <!-- ============================================================ -->
    <!-- TemperatureGraph (MCU + MOSFET + MOTOR overlay)               -->
    <!-- ============================================================ -->
    <Style TargetType="{x:Type controls:TemperatureGraph}">
        <Setter Property="MinHeight" Value="80"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:TemperatureGraph}">
                    <Grid>
                        <!-- Dotted horizontal gridlines at 25/50/75 % of the plot.
                             Stays at the back. -->
                        <Path Data="{Binding GridGeometry, RelativeSource={RelativeSource TemplatedParent}}"
                              Stroke="{StaticResource BorderBrush}" StrokeThickness="1"
                              StrokeDashArray="2 3" Opacity="0.6"/>

                        <!-- Series layer. Each series has an under-glow fill +
                             a stroked line + a trailing tip dot, grouped under
                             a single Panel.ZIndex so the hottest current trace
                             can be lifted in front of the cooler ones. The
                             control recomputes per-series ZIndex every tick. -->
                        <Canvas IsHitTestVisible="False" ClipToBounds="True">
                            <!-- MCU -->
                            <Path Data="{Binding McuFillGeometry, RelativeSource={RelativeSource TemplatedParent}}"
                                  Fill="{TemplateBinding McuFillBrush}" Opacity="0.55"
                                  Panel.ZIndex="{Binding McuZIndex, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <Path Data="{Binding McuLineGeometry, RelativeSource={RelativeSource TemplatedParent}}"
                                  Stroke="{TemplateBinding McuBrush}" StrokeThickness="1.5"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Fill="{x:Null}"
                                  Panel.ZIndex="{Binding McuZIndex, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <Ellipse Width="6" Height="6"
                                     Fill="{TemplateBinding McuBrush}"
                                     Canvas.Left="{Binding McuTipX, RelativeSource={RelativeSource TemplatedParent}}"
                                     Canvas.Top="{Binding McuTipY, RelativeSource={RelativeSource TemplatedParent}}"
                                     Panel.ZIndex="{Binding McuZIndex, RelativeSource={RelativeSource TemplatedParent}}"/>

                            <!-- MOSFET -->
                            <Path Data="{Binding MosfetFillGeometry, RelativeSource={RelativeSource TemplatedParent}}"
                                  Fill="{TemplateBinding MosfetFillBrush}" Opacity="0.55"
                                  Panel.ZIndex="{Binding MosfetZIndex, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <Path Data="{Binding MosfetLineGeometry, RelativeSource={RelativeSource TemplatedParent}}"
                                  Stroke="{TemplateBinding MosfetBrush}" StrokeThickness="1.5"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Fill="{x:Null}"
                                  Panel.ZIndex="{Binding MosfetZIndex, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <Ellipse Width="6" Height="6"
                                     Fill="{TemplateBinding MosfetBrush}"
                                     Canvas.Left="{Binding MosfetTipX, RelativeSource={RelativeSource TemplatedParent}}"
                                     Canvas.Top="{Binding MosfetTipY, RelativeSource={RelativeSource TemplatedParent}}"
                                     Panel.ZIndex="{Binding MosfetZIndex, RelativeSource={RelativeSource TemplatedParent}}"/>

                            <!-- MOTOR -->
                            <Path Data="{Binding MotorFillGeometry, RelativeSource={RelativeSource TemplatedParent}}"
                                  Fill="{TemplateBinding MotorFillBrush}" Opacity="0.55"
                                  Panel.ZIndex="{Binding MotorZIndex, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <Path Data="{Binding MotorLineGeometry, RelativeSource={RelativeSource TemplatedParent}}"
                                  Stroke="{TemplateBinding MotorBrush}" StrokeThickness="1.5"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Fill="{x:Null}"
                                  Panel.ZIndex="{Binding MotorZIndex, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <Ellipse Width="6" Height="6"
                                     Fill="{TemplateBinding MotorBrush}"
                                     Canvas.Left="{Binding MotorTipX, RelativeSource={RelativeSource TemplatedParent}}"
                                     Canvas.Top="{Binding MotorTipY, RelativeSource={RelativeSource TemplatedParent}}"
                                     Panel.ZIndex="{Binding MotorZIndex, RelativeSource={RelativeSource TemplatedParent}}"/>
                        </Canvas>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type controls:BandwidthSparkline}">
        <Setter Property="MinHeight" Value="56"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:BandwidthSparkline}">
                    <Grid>
                        <!-- Third drawn furthest back, then outbound, then inbound
                             on top — so for the two-series bandwidth chart the
                             typically-louder inbound line still lays on top, and
                             the mBooster pedal-trace graph's Clutch line (Third)
                             sits behind Throttle (Out) and Brake (In). Fill
                             brushes default null (line-only) but the caller can
                             supply gradient brushes for the under-glow effect. -->
                        <Path Data="{Binding ThirdFillGeometry, RelativeSource={RelativeSource TemplatedParent}}"
                              Fill="{TemplateBinding ThirdFillBrush}"
                              StrokeThickness="0"/>
                        <Path Data="{Binding OutFillGeometry, RelativeSource={RelativeSource TemplatedParent}}"
                              Fill="{TemplateBinding OutFillBrush}"
                              StrokeThickness="0"/>
                        <Path Data="{Binding InFillGeometry, RelativeSource={RelativeSource TemplatedParent}}"
                              Fill="{TemplateBinding InFillBrush}"
                              StrokeThickness="0"/>

                        <!-- Opt-in dashed horizontal gridlines (ShowGridlines) at
                             100/75/50/25 % of the plot. Drawn on top of the fills
                             (so they stay visible through the translucent
                             envelopes instead of being buried under them) but
                             behind the series' own line strokes + tip dots, so
                             the actual data reads as the foreground layer. -->
                        <Path Data="{Binding GridGeometry, RelativeSource={RelativeSource TemplatedParent}}"
                              Stroke="{StaticResource TextDimBrush}" StrokeThickness="1"
                              StrokeDashArray="2 3" Opacity="0.55"/>

                        <Path Data="{Binding ThirdLineGeometry, RelativeSource={RelativeSource TemplatedParent}}"
                              Stroke="{TemplateBinding ThirdBrush}"
                              StrokeThickness="1.5"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Fill="{x:Null}"/>
                        <Path Data="{Binding OutLineGeometry, RelativeSource={RelativeSource TemplatedParent}}"
                              Stroke="{TemplateBinding OutBrush}"
                              StrokeThickness="1.5"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Fill="{x:Null}"/>
                        <Path Data="{Binding InLineGeometry, RelativeSource={RelativeSource TemplatedParent}}"
                              Stroke="{TemplateBinding InBrush}"
                              StrokeThickness="1.5"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Fill="{x:Null}"/>
                        <Canvas IsHitTestVisible="False">
                            <Ellipse Width="6" Height="6"
                                     Fill="{TemplateBinding ThirdBrush}"
                                     Canvas.Left="{Binding ThirdTipX, RelativeSource={RelativeSource TemplatedParent}}"
                                     Canvas.Top="{Binding ThirdTipY, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <Ellipse Width="6" Height="6"
                                     Fill="{TemplateBinding OutBrush}"
                                     Canvas.Left="{Binding OutTipX, RelativeSource={RelativeSource TemplatedParent}}"
                                     Canvas.Top="{Binding OutTipY, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <Ellipse Width="6" Height="6"
                                     Fill="{TemplateBinding InBrush}"
                                     Canvas.Left="{Binding InTipX, RelativeSource={RelativeSource TemplatedParent}}"
                                     Canvas.Top="{Binding InTipY, RelativeSource={RelativeSource TemplatedParent}}"/>
                        </Canvas>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================ -->
    <!-- ConnectionPill                                                -->
    <!-- ============================================================ -->

    <Style TargetType="{x:Type controls:ConnectionPill}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:ConnectionPill}">
                    <Border x:Name="Outer"
                            Background="{StaticResource BgCardBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="999"
                            Padding="12,6">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse x:Name="Dot" Width="8" Height="8"
                                     Fill="#FF555555"
                                     VerticalAlignment="Center"
                                     Margin="0,0,9,0"/>
                            <TextBlock x:Name="PortText"
                                       Text="{TemplateBinding PortName}"
                                       FontFamily="{StaticResource FontMono}"
                                       FontSize="12"
                                       Foreground="{StaticResource TextFaintBrush}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0"/>
                            <TextBlock x:Name="StatusLabel"
                                       Text="{TemplateBinding StatusText}"
                                       FontFamily="{StaticResource FontMono}"
                                       FontSize="12"
                                       Foreground="{StaticResource TextBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsConnected" Value="True">
                            <Setter TargetName="Dot" Property="Fill" Value="{StaticResource GreenBrush}"/>
                            <Setter TargetName="Dot" Property="Effect" Value="{StaticResource GreenGlowEffect}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================ -->
    <!-- PaletteStrip                                                  -->
    <!-- ============================================================ -->

    <Style TargetType="{x:Type controls:PaletteStrip}">
        <Setter Property="MinHeight" Value="32"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:PaletteStrip}">
                    <StackPanel x:Name="PART_Swatches" Orientation="Horizontal"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================ -->
    <!-- KnobRingViz                                                   -->
    <!-- ============================================================ -->

    <Style TargetType="{x:Type controls:KnobRingViz}">
        <Setter Property="Width" Value="100"/>
        <Setter Property="Height" Value="100"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:KnobRingViz}">
                    <Canvas x:Name="PART_Canvas" Width="100" Height="100"
                            Background="Transparent"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================ -->
    <!-- SectionCard                                                   -->
    <!-- ============================================================ -->

    <Style TargetType="{x:Type controls:SectionCard}">
        <Setter Property="Background" Value="{StaticResource BgCardBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Margin" Value="0,0,0,14"/>
        <Setter Property="AccentBrush" Value="{StaticResource CyanBrush}"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:SectionCard}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            SnapsToDevicePixels="True">
                        <DockPanel LastChildFill="True">
                            <!-- Header -->
                            <Border x:Name="PART_Header" DockPanel.Dock="Top"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="0,0,0,1"
                                    Padding="18,12"
                                    Background="Transparent">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Accent bar -->
                                    <Rectangle Grid.Column="0"
                                               Width="2"
                                               Margin="-12,-2,12,-2"
                                               Fill="{TemplateBinding AccentBrush}"
                                               Effect="{StaticResource CyanGlowSoftEffect}"
                                               VerticalAlignment="Stretch"/>
                                    <!-- Icon chip -->
                                    <Border Grid.Column="1"
                                            Width="30" Height="30"
                                            Background="{StaticResource BgCard2Brush}"
                                            BorderBrush="{StaticResource BorderBrightBrush}"
                                            BorderThickness="1"
                                            CornerRadius="5"
                                            Margin="0,0,12,0">
                                        <Path Width="16" Height="16"
                                              Stretch="Uniform"
                                              Stroke="{TemplateBinding AccentBrush}"
                                              StrokeThickness="1.5"
                                              Fill="{x:Null}"
                                              StrokeLineJoin="Round"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Data="{TemplateBinding Icon}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Center"/>
                                    </Border>
                                    <!-- Title + subtitle -->
                                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{TemplateBinding Title}"
                                                   Style="{StaticResource SectionTitleText}"/>
                                        <TextBlock Text="{TemplateBinding Subtitle}"
                                                   Style="{StaticResource SectionSubText}"
                                                   Visibility="{Binding Subtitle, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource EmptyStringToVisibility}}"/>
                                    </StackPanel>
                                    <!-- Right-hand rule gradient -->
                                    <Rectangle Grid.Column="3" Height="1"
                                               VerticalAlignment="Center"
                                               Margin="14,0,0,0">
                                        <Rectangle.Fill>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="{StaticResource BorderBrightColor}" Offset="0"/>
                                                <GradientStop Color="#00000000" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Rectangle.Fill>
                                    </Rectangle>
                                    <!-- Optional header-right content (HeaderedContentControl.Header;
                                         null on most cards → renders nothing) plus the collapse/
                                         expand chevron — hidden unless IsCollapsible is set; clicking
                                         anywhere in the header (PART_Header, see
                                         SectionCard.OnApplyTemplate) toggles IsExpanded. Both share
                                         this one trailing Auto column. -->
                                    <StackPanel Grid.Column="4" Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <ContentPresenter Content="{TemplateBinding Header}"
                                                          VerticalAlignment="Center"
                                                          Margin="12,0,0,0"/>
                                        <Path x:Name="PART_Chevron" Margin="14,0,0,0"
                                              Width="10" Height="6" Stretch="Uniform"
                                              Data="M0,0 L5,6 L10,0"
                                              Stroke="{StaticResource TextDimBrush}" StrokeThickness="1.6"
                                              StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                              Fill="{x:Null}"
                                              VerticalAlignment="Center"
                                              RenderTransformOrigin="0.5,0.5"
                                              Visibility="Collapsed">
                                            <Path.RenderTransform>
                                                <RotateTransform Angle="0"/>
                                            </Path.RenderTransform>
                                        </Path>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <!-- Body -->
                            <ContentPresenter x:Name="PART_Body" Margin="18,14,18,18"/>
                        </DockPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsCollapsible" Value="True">
                            <Setter TargetName="PART_Chevron" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="PART_Header" Property="Cursor" Value="Hand"/>
                        </Trigger>
                        <Trigger Property="IsExpanded" Value="False">
                            <Setter TargetName="PART_Body" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="PART_Chevron" Property="RenderTransform">
                                <Setter.Value>
                                    <RotateTransform Angle="-90"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

