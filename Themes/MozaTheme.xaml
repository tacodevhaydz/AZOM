<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib"
                    xmlns:controls="clr-namespace:MozaControls">

    <!-- ============================================================ -->
    <!-- Color tokens                                                  -->
    <!-- ============================================================ -->

    <!-- Backgrounds -->
    <Color x:Key="BgDeepColor">#20000000</Color>
    <Color x:Key="BgPanelColor">#10000000</Color>
    <Color x:Key="BgCardColor">#08FFFFFF</Color>
    <Color x:Key="BgCard2Color">#10FFFFFF</Color>
    <Color x:Key="BgCardHoverColor">#18FFFFFF</Color>
    <Color x:Key="BgTrackColor">#18000000</Color>

    <!-- Borders -->
    <Color x:Key="BorderColor">#FF20262B</Color>
    <Color x:Key="BorderBrightColor">#FF2E373D</Color>
    <Color x:Key="BorderGlowColor">#3300E5FF</Color>

    <!-- Text -->
    <Color x:Key="TextColor">#FFE8EDF0</Color>
    <Color x:Key="TextDimColor">#FFBBC4CC</Color>
    <Color x:Key="TextFaintColor">#FF8E97A0</Color>
    <Color x:Key="TextMutedColor">#FF6A737C</Color>

    <!-- Accents -->
    <Color x:Key="CyanColor">#FF00E5FF</Color>
    <Color x:Key="CyanGlowColor">#6600E5FF</Color>
    <Color x:Key="CyanSoftColor">#2200E5FF</Color>
    <Color x:Key="GreenColor">#FF39FF88</Color>
    <Color x:Key="GreenGlowColor">#6639FF88</Color>
    <Color x:Key="GreenSoftColor">#2239FF88</Color>
    <Color x:Key="AmberColor">#FFFFB84D</Color>
    <Color x:Key="AmberGlowColor">#66FFB84D</Color>
    <Color x:Key="AmberSoftColor">#22FFB84D</Color>
    <Color x:Key="RedColor">#FFFF5566</Color>
    <Color x:Key="RedGlowColor">#66FF5566</Color>
    <Color x:Key="BlueColor">#FF4D8CFF</Color>
    <Color x:Key="BlueGlowColor">#664D8CFF</Color>

    <!-- ============================================================ -->
    <!-- Brushes                                                       -->
    <!-- ============================================================ -->

    <SolidColorBrush x:Key="BgDeepBrush" Color="{StaticResource BgDeepColor}"/>
    <SolidColorBrush x:Key="BgPanelBrush" Color="{StaticResource BgPanelColor}"/>
    <SolidColorBrush x:Key="BgCardBrush" Color="{StaticResource BgCardColor}"/>
    <SolidColorBrush x:Key="BgCard2Brush" Color="{StaticResource BgCard2Color}"/>
    <SolidColorBrush x:Key="BgCardHoverBrush" Color="{StaticResource BgCardHoverColor}"/>
    <SolidColorBrush x:Key="BgTrackBrush" Color="{StaticResource BgTrackColor}"/>

    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="BorderBrightBrush" Color="{StaticResource BorderBrightColor}"/>
    <SolidColorBrush x:Key="BorderGlowBrush" Color="{StaticResource BorderGlowColor}"/>

    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="TextDimBrush" Color="{StaticResource TextDimColor}"/>
    <SolidColorBrush x:Key="TextFaintBrush" Color="{StaticResource TextFaintColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}"/>

    <SolidColorBrush x:Key="CyanBrush" Color="{StaticResource CyanColor}"/>
    <SolidColorBrush x:Key="CyanGlowBrush" Color="{StaticResource CyanGlowColor}"/>
    <SolidColorBrush x:Key="CyanSoftBrush" Color="{StaticResource CyanSoftColor}"/>
    <SolidColorBrush x:Key="GreenBrush" Color="{StaticResource GreenColor}"/>
    <SolidColorBrush x:Key="GreenGlowBrush" Color="{StaticResource GreenGlowColor}"/>
    <SolidColorBrush x:Key="GreenSoftBrush" Color="{StaticResource GreenSoftColor}"/>
    <SolidColorBrush x:Key="AmberBrush" Color="{StaticResource AmberColor}"/>
    <SolidColorBrush x:Key="AmberSoftBrush" Color="{StaticResource AmberSoftColor}"/>
    <SolidColorBrush x:Key="RedBrush" Color="{StaticResource RedColor}"/>
    <SolidColorBrush x:Key="BlueBrush" Color="{StaticResource BlueColor}"/>

    <!-- Gradient fills used by slider track, EQ bars, temperature meters -->
    <LinearGradientBrush x:Key="CyanFillBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#FF00B8D4" Offset="0"/>
        <GradientStop Color="{StaticResource CyanColor}" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="GreenFillBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#FF1A7044" Offset="0"/>
        <GradientStop Color="{StaticResource GreenColor}" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="RedFillBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#FF8A1E2A" Offset="0"/>
        <GradientStop Color="{StaticResource RedColor}" Offset="1"/>
    </LinearGradientBrush>
    <!-- TemperatureGraph per-series under-glow gradients. Each fades from the
         line's accent color at the top to fully transparent at the bottom, so
         the area under each trace gets a soft halo (mirrors the bandwidth
         sparkline's fill effect). -->
    <!-- Per-series fills follow the typical hot→cool color hierarchy on the
         wheelbase: MCU=red (control board / regulators run hottest), MOSFET=cyan
         (power stage middle), Motor=green (coolest under normal use). Actual
         ranking varies in-game; the legend re-sorts top→bottom by current temp,
         but graph line colors stay anchored per-component for visual continuity. -->
    <LinearGradientBrush x:Key="McuFillBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource RedColor}" Offset="0"/>
        <GradientStop Color="#00FF5566" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="MosfetFillBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource CyanColor}" Offset="0"/>
        <GradientStop Color="#0000E5FF" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="MotorFillBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource GreenColor}" Offset="0"/>
        <GradientStop Color="#0039FF88" Offset="1"/>
    </LinearGradientBrush>

    <!-- BandwidthSparkline dual-line fills: cyan (in) + amber (out), each fading
         to transparent at the bottom. -->
    <LinearGradientBrush x:Key="BwInFillBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource CyanColor}" Offset="0"/>
        <GradientStop Color="#0000E5FF" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="BwOutFillBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource AmberColor}" Offset="0"/>
        <GradientStop Color="#00FFB84D" Offset="1"/>
    </LinearGradientBrush>
    <!-- Third-series fill (blue) — mBooster pedal-trace graph's Clutch line. -->
    <LinearGradientBrush x:Key="BwThirdFillBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource BlueColor}" Offset="0"/>
        <GradientStop Color="#004D8CFF" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="TopBarBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#20000000" Offset="0"/>
        <GradientStop Color="{StaticResource BgPanelColor}" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="ToggleOnBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#3300E5FF" Offset="0"/>
        <GradientStop Color="#1000E5FF" Offset="1"/>
    </LinearGradientBrush>
    <!-- Per-accent variants of the soft "active" background used by the
         SegmentedControl selected item + the OffOnToggle ON pill. The
         template references these via DynamicResource so a parent container
         can override `ToggleOnBrush` (and the matching text color) to recolor
         every active button-selector inside it without touching the template. -->
    <LinearGradientBrush x:Key="GreenToggleOnBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#3339FF88" Offset="0"/>
        <GradientStop Color="#1039FF88" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="RedToggleOnBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#33FF5566" Offset="0"/>
        <GradientStop Color="#10FF5566" Offset="1"/>
    </LinearGradientBrush>
    <!-- Foreground tint for the active button — defaults to cyan; per-section
         resource overrides redirect this to GreenBrush or RedBrush. -->
    <SolidColorBrush x:Key="ToggleOnTextBrush" Color="{StaticResource CyanColor}"/>
    <LinearGradientBrush x:Key="BannerBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#18FFB84D" Offset="0"/>
        <GradientStop Color="#08FFB84D" Offset="1"/>
    </LinearGradientBrush>

    <!-- ============================================================ -->
    <!-- Font keys (no font files packaged — fall back gracefully)     -->
    <!-- ============================================================ -->

    <FontFamily x:Key="FontUi">Segoe UI, Inter, system-ui, sans-serif</FontFamily>
    <FontFamily x:Key="FontMono">Consolas, JetBrains Mono, monospace</FontFamily>

    <!-- ============================================================ -->
    <!-- Reusable drop-shadow / glow effects                           -->
    <!-- Used sparingly per design hint: only on accent elements       -->
    <!-- ============================================================ -->

    <DropShadowEffect x:Key="CyanGlowEffect" Color="{StaticResource CyanColor}"
                      ShadowDepth="0" BlurRadius="10" Opacity="0.6"/>
    <DropShadowEffect x:Key="CyanGlowSoftEffect" Color="{StaticResource CyanColor}"
                      ShadowDepth="0" BlurRadius="6" Opacity="0.35"/>
    <DropShadowEffect x:Key="GreenGlowEffect" Color="{StaticResource GreenColor}"
                      ShadowDepth="0" BlurRadius="8" Opacity="0.6"/>
    <DropShadowEffect x:Key="AmberGlowEffect" Color="{StaticResource AmberColor}"
                      ShadowDepth="0" BlurRadius="6" Opacity="0.4"/>

    <!-- ============================================================ -->
    <!-- Shared TextBlock typography                                   -->
    <!-- ============================================================ -->

    <Style x:Key="SectionTitleText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontUi}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
    </Style>

    <Style x:Key="SectionSubText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{StaticResource TextFaintBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="8,0,0,0"/>
    </Style>

    <Style x:Key="LabelText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontUi}"/>
        <Setter Property="FontSize" Value="14.5"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="ValueText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="Foreground" Value="{StaticResource CyanBrush}"/>
        <Setter Property="TextAlignment" Value="Right"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Padding" Value="9,5"/>
        <Setter Property="MinWidth" Value="72"/>
        <Setter Property="Background" Value="{StaticResource BgDeepBrush}"/>
    </Style>

    <Style x:Key="MutedHintText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontUi}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{StaticResource TextFaintBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="KvKeyText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{StaticResource TextFaintBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,0,6,0"/>
    </Style>

    <Style x:Key="KvValueText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{StaticResource TextDimBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,0,18,0"/>
    </Style>

    <Style x:Key="StatusBarText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{StaticResource TextFaintBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,0,18,0"/>
    </Style>

    <!-- ============================================================ -->
    <!-- Buttons                                                       -->
    <!-- ============================================================ -->

    <Style x:Key="MozaButton" TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource FontUi}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="Background" Value="{StaticResource BgCardBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrightBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="13,7"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4" SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Margin="{TemplateBinding Padding}"
                                          TextBlock.FontFamily="{TemplateBinding FontFamily}"
                                          TextBlock.FontSize="{TemplateBinding FontSize}"
                                          TextBlock.FontWeight="{TemplateBinding FontWeight}"
                                          TextBlock.Foreground="{TemplateBinding Foreground}"
                                          RecognizesAccessKey="True"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgCardHoverBrush}"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BorderGlowBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource CyanBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgDeepBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource TextFaintBrush}"/>
                            <Setter TargetName="Bd" Property="Opacity" Value="0.55"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="MozaButtonPrimary" TargetType="Button" BasedOn="{StaticResource MozaButton}">
        <Setter Property="Background" Value="{StaticResource ToggleOnBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderGlowBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource CyanBrush}"/>
    </Style>

    <Style x:Key="MozaButtonDanger" TargetType="Button" BasedOn="{StaticResource MozaButton}">
        <Setter Property="Foreground" Value="{StaticResource RedBrush}"/>
        <Setter Property="BorderBrush" Value="#44FF5566"/>
    </Style>

    <Style x:Key="MozaButtonGhost" TargetType="Button" BasedOn="{StaticResource MozaButton}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextDimBrush}"/>
    </Style>

    <!-- ============================================================ -->
    <!-- Slider — bar-fill style with cyan thumb + value pill          -->
    <!-- (No value pill in the template — the parent row supplies it.) -->
    <!-- ============================================================ -->

    <Style x:Key="MozaThumbStyle" TargetType="Thumb">
        <Setter Property="Width" Value="14"/>
        <Setter Property="Height" Value="22"/>
        <!-- Default thumb tint. Per-slider overrides set Foreground on the
             enclosing Slider, which the Slider template passes down to the
             thumb so the fill cascades. -->
        <Setter Property="Foreground" Value="{StaticResource CyanBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Rectangle Fill="{TemplateBinding Foreground}" RadiusX="3" RadiusY="3"
                               Width="14" Height="22"
                               Effect="{StaticResource CyanGlowEffect}"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="MozaRepeatButtonStyle" TargetType="RepeatButton">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Background="Transparent"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="MozaSlider" TargetType="Slider">
        <Setter Property="MinHeight" Value="22"/>
        <Setter Property="Background" Value="{StaticResource BgTrackBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource CyanFillBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="IsMoveToPointEnabled" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Grid VerticalAlignment="Center" MinHeight="22">
                        <Border x:Name="TrackBg"
                                Height="6"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="3"
                                VerticalAlignment="Center"
                                SnapsToDevicePixels="True"/>
                        <Track x:Name="PART_Track" Maximum="{TemplateBinding Maximum}"
                               Minimum="{TemplateBinding Minimum}"
                               Value="{TemplateBinding Value}">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Style="{StaticResource MozaRepeatButtonStyle}"
                                              Command="Slider.DecreaseLarge"
                                              Foreground="{TemplateBinding Foreground}">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton">
                                            <Border Background="{TemplateBinding Background}">
                                                <Rectangle Margin="0,8" Height="6"
                                                           Fill="{TemplateBinding Foreground}"
                                                           RadiusX="2" RadiusY="2"
                                                           Effect="{StaticResource CyanGlowSoftEffect}"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Stretch"/>
                                            </Border>
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.DecreaseRepeatButton>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Style="{StaticResource MozaRepeatButtonStyle}"
                                              Command="Slider.IncreaseLarge"/>
                            </Track.IncreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{StaticResource MozaThumbStyle}"
                                       Foreground="{TemplateBinding Foreground}"/>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.45"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Vertical EQ bar variant (used by MozaEqualizer custom control) -->
    <Style x:Key="MozaSliderVertical" TargetType="Slider" BasedOn="{StaticResource MozaSlider}">
        <Setter Property="Orientation" Value="Vertical"/>
    </Style>

    <!-- ============================================================ -->
    <!-- ComboBox restyle                                              -->
    <!-- ============================================================ -->

    <Style x:Key="MozaComboItem" TargetType="ComboBoxItem">
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="Background" Value="#FF1E242A"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgCardHoverBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource CyanBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource CyanBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <ControlTemplate x:Key="MozaComboToggleTemplate" TargetType="ToggleButton">
        <Border x:Name="Bd"
                Background="#FF1E242A"
                BorderBrush="{StaticResource BorderBrightBrush}"
                BorderThickness="1"
                CornerRadius="4"
                SnapsToDevicePixels="True">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ContentPresenter Grid.Column="0"
                                  Margin="11,7,4,7"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Center"
                                  IsHitTestVisible="False"/>
                <Path Grid.Column="1" Margin="0,0,11,0"
                      Width="9" Height="6"
                      Stretch="Fill"
                      Fill="{StaticResource TextDimBrush}"
                      Data="M 0,0 L 9,0 L 4.5,6 Z"
                      VerticalAlignment="Center"/>
            </Grid>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BorderGlowBrush}"/>
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BorderGlowBrush}"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style x:Key="MozaCombo" TargetType="ComboBox">
        <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="Background" Value="{StaticResource BgCard2Brush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrightBrush}"/>
        <Setter Property="MinWidth" Value="160"/>
        <Setter Property="MinHeight" Value="30"/>
        <Setter Property="Padding" Value="11,7"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="ItemContainerStyle" Value="{StaticResource MozaComboItem}"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <ToggleButton x:Name="ToggleButton"
                                      Grid.Column="0"
                                      Template="{StaticResource MozaComboToggleTemplate}"
                                      Focusable="False"
                                      ClickMode="Press"
                                      IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              Margin="0"/>
                        </ToggleButton>
                        <Popup x:Name="Popup"
                               Placement="Bottom"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Slide">
                            <Border Background="#FF1E242A"
                                    BorderBrush="{StaticResource BorderBrightBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    MinWidth="{TemplateBinding ActualWidth}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                <ScrollViewer SnapsToDevicePixels="True">
                                    <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================ -->
    <!-- CheckBox restyle (used where we want a plain checkbox; toggle-style is OffOnToggle) -->
    <!-- ============================================================ -->

    <Style x:Key="MozaCheckBox" TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource FontUi}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal">
                        <Border x:Name="Box" Width="14" Height="14"
                                BorderBrush="{StaticResource BorderBrightBrush}" BorderThickness="1"
                                Background="{StaticResource BgDeepBrush}" CornerRadius="2"
                                VerticalAlignment="Center">
                            <Path x:Name="Check" Stretch="Uniform" Margin="2"
                                  Data="M0,3 L2,5 L6,0"
                                  Stroke="{StaticResource CyanBrush}" StrokeThickness="1.6"
                                  Visibility="Collapsed"/>
                        </Border>
                        <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center"
                                          TextBlock.Foreground="{TemplateBinding Foreground}"/>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Check" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource BorderGlowBrush}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource BorderGlowBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================ -->
    <!-- TabControl + TabItem — cyan underline on active tab            -->
    <!-- (TabControl itself uses a minimal wrapper template — chrome    -->
    <!--  is removed, content area is plain.)                          -->
    <!-- ============================================================ -->

    <Style x:Key="MozaTabItem" TargetType="TabItem">
        <Setter Property="FontFamily" Value="{StaticResource FontUi}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource TextFaintBrush}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Padding" Value="18,0"/>
        <Setter Property="Height" Value="44"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Grid x:Name="Root" Background="Transparent">
                        <ContentPresenter ContentSource="Header"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"
                                          TextBlock.Foreground="{TemplateBinding Foreground}"
                                          TextBlock.FontFamily="{TemplateBinding FontFamily}"
                                          TextBlock.FontSize="{TemplateBinding FontSize}"
                                          TextBlock.FontWeight="{TemplateBinding FontWeight}"
                                          RecognizesAccessKey="True"/>
                        <Border x:Name="Underline"
                                VerticalAlignment="Bottom"
                                Height="2" Margin="12,0"
                                Background="{StaticResource CyanBrush}"
                                Effect="{StaticResource CyanGlowEffect}"
                                Visibility="Collapsed"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource TextDimBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource CyanBrush}"/>
                            <Setter TargetName="Underline" Property="Visibility" Value="Visible"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="MozaTabControl" TargetType="TabControl">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="ItemContainerStyle" Value="{StaticResource MozaTabItem}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabControl">
                    <DockPanel LastChildFill="True">
                        <Border DockPanel.Dock="Top"
                                Background="{StaticResource BgPanelBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="0,0,0,1">
                            <TabPanel x:Name="HeaderPanel"
                                      Panel.ZIndex="1"
                                      IsItemsHost="True"
                                      KeyboardNavigation.TabIndex="1"
                                      Background="Transparent"
                                      Margin="22,0"/>
                        </Border>
                        <Border Background="Transparent"
                                BorderThickness="0">
                            <ContentPresenter x:Name="PART_SelectedContentHost"
                                              ContentSource="SelectedContent"
                                              SnapsToDevicePixels="True"/>
                        </Border>
                    </DockPanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================ -->
    <!-- ScrollViewer / ScrollBar — slim dark scroll                   -->
    <!-- ============================================================ -->

    <Style x:Key="MozaScrollThumb" TargetType="Thumb">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border CornerRadius="5"
                            Background="#1C2228"
                            BorderBrush="{StaticResource BgDeepBrush}"
                            BorderThickness="2"
                            SnapsToDevicePixels="True"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="MozaScrollBar" TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Width" Value="10"/>
        <Setter Property="MinWidth" Value="10"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="Transparent">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb Style="{StaticResource MozaScrollThumb}"/>
                            </Track.Thumb>
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Style="{StaticResource MozaRepeatButtonStyle}"
                                              Command="ScrollBar.PageUpCommand"/>
                            </Track.DecreaseRepeatButton>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Style="{StaticResource MozaRepeatButtonStyle}"
                                              Command="ScrollBar.PageDownCommand"/>
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================ -->
    <!-- Section card — used by UI/Controls/SectionCard.cs              -->
    <!-- Style is keyed by the type itself (default style) via the     -->
    <!-- SectionCard class's static constructor.                       -->
    <!-- ============================================================ -->

    <!-- TeleCard background style for compact telemetry tiles -->
    <Style x:Key="TeleCardBorder" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BgCardBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="14,12"/>
        <Setter Property="Margin" Value="0,0,10,10"/>
    </Style>

    <!-- Generic "card" wrapper (no header — for paddle/button live tiles) -->
    <Style x:Key="InnerCardBorder" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BgCard2Brush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="5"/>
        <Setter Property="Padding" Value="14,12"/>
    </Style>

    <!-- Banner style for the restart notice -->
    <Style x:Key="BannerBorder" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BannerBrush}"/>
        <Setter Property="BorderBrush" Value="#44FFB84D"/>
        <Setter Property="BorderThickness" Value="1,1,1,1"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="14,10"/>
        <Setter Property="Margin" Value="0,0,0,14"/>
    </Style>

    <!-- ============================================================ -->
    <!-- MozaCurveEditor shared template + MozaEqualizerLineStyle      -->
    <!-- ============================================================ -->
    <!-- Lives here (not in Generic.xaml) so SettingsControl.xaml can      -->
    <!-- reach MozaEqualizerLineStyle via its merged-dictionary lookup.    -->
    <!-- Generic.xaml also merges this file, so its default unkeyed       -->
    <!-- MozaCurveEditor style can reference the template by key.         -->

    <ControlTemplate x:Key="MozaCurveEditorTemplate" TargetType="{x:Type controls:MozaCurveEditor}">
        <Border Background="{StaticResource BgDeepBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="0"
                SnapsToDevicePixels="True">
            <Canvas x:Name="PART_Canvas" Background="Transparent" ClipToBounds="True">
                <!-- Grid lines -->
                <Path Stroke="{StaticResource BorderBrush}" StrokeThickness="1"
                      StrokeDashArray="2 3" Opacity="0.6"
                      Data="{Binding GridGeometry, RelativeSource={RelativeSource TemplatedParent}}"/>
                <!-- Optional y=x nominal/linear-response reference (output curves only).
                     Same visual style as the horizontal reference line below. -->
                <Path Stroke="{StaticResource AmberBrush}" StrokeThickness="1.5"
                      StrokeDashArray="4 3" Opacity="0.85"
                      Data="{Binding IdentityLineGeometry, RelativeSource={RelativeSource TemplatedParent}}"/>
                <!-- Optional horizontal reference line (dashed amber, e.g. EQ 100% neutral) -->
                <Path Stroke="{StaticResource AmberBrush}" StrokeThickness="1.5"
                      StrokeDashArray="4 3" Opacity="0.85"
                      Data="{Binding ReferenceLineGeometry, RelativeSource={RelativeSource TemplatedParent}}"/>
                <!-- Curve -->
                <Path Stroke="{TemplateBinding AccentBrush}" StrokeThickness="2.5"
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                      Fill="{x:Null}"
                      Effect="{StaticResource CyanGlowSoftEffect}"
                      Data="{Binding CurveGeometry, RelativeSource={RelativeSource TemplatedParent}}"/>
                <!-- Live position indicator (see MozaCurveEditor.LiveX) — a dashed
                     guide line from the axis up to the spline, and a small dot
                     ON the spline at the current pedal travel, updated at the
                     same cadence as the position bar. White so it stands out
                     against both the amber curve and the dark background;
                     smaller than the draggable nodes so it never competes
                     with them for attention. -->
                <Path Stroke="White" StrokeThickness="1" StrokeDashArray="3 2" Opacity="0.55"
                      Visibility="{Binding LiveMarkerVisible, RelativeSource={RelativeSource TemplatedParent}}"
                      Data="{Binding LiveGuideLineGeometry, RelativeSource={RelativeSource TemplatedParent}}"/>
                <Ellipse Width="10" Height="10" Fill="White" Stroke="#FF1E242A" StrokeThickness="1.5"
                         Visibility="{Binding LiveMarkerVisible, RelativeSource={RelativeSource TemplatedParent}}"
                         Canvas.Left="{Binding LiveMarkerLeft, RelativeSource={RelativeSource TemplatedParent}}"
                         Canvas.Top="{Binding LiveMarkerTop, RelativeSource={RelativeSource TemplatedParent}}"/>
                <!-- Up to 6 draggable nodes. Each Border is a circle (CornerRadius=
                     half of Width/Height) with an opaque background so the spline
                     visually terminates at the circle edge, and a centred TextBlock
                     showing the current Y value. Unused slots are parked off-canvas
                     by Recompute(). Width/Height/CornerRadius must stay in sync with
                     MozaCurveEditor.NodeSize. -->
                <Border Width="28" Height="28" CornerRadius="14"
                        Background="#FF1E242A"
                        BorderBrush="{TemplateBinding AccentBrush}" BorderThickness="2"
                        Effect="{StaticResource CyanGlowSoftEffect}"
                        Canvas.Left="{Binding Node1X, RelativeSource={RelativeSource TemplatedParent}}"
                        Canvas.Top="{Binding Node1Y, RelativeSource={RelativeSource TemplatedParent}}">
                    <TextBlock Text="{Binding Node1Value, RelativeSource={RelativeSource TemplatedParent}}"
                               FontFamily="{StaticResource FontMono}" FontSize="11"
                               Foreground="{TemplateBinding AccentBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               IsHitTestVisible="False"/>
                </Border>
                <Border Width="28" Height="28" CornerRadius="14"
                        Background="#FF1E242A"
                        BorderBrush="{TemplateBinding AccentBrush}" BorderThickness="2"
                        Effect="{StaticResource CyanGlowSoftEffect}"
                        Canvas.Left="{Binding Node2X, RelativeSource={RelativeSource TemplatedParent}}"
                        Canvas.Top="{Binding Node2Y, RelativeSource={RelativeSource TemplatedParent}}">
                    <TextBlock Text="{Binding Node2Value, RelativeSource={RelativeSource TemplatedParent}}"
                               FontFamily="{StaticResource FontMono}" FontSize="11"
                               Foreground="{TemplateBinding AccentBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               IsHitTestVisible="False"/>
                </Border>
                <Border Width="28" Height="28" CornerRadius="14"
                        Background="#FF1E242A"
                        BorderBrush="{TemplateBinding AccentBrush}" BorderThickness="2"
                        Effect="{StaticResource CyanGlowSoftEffect}"
                        Canvas.Left="{Binding Node3X, RelativeSource={RelativeSource TemplatedParent}}"
                        Canvas.Top="{Binding Node3Y, RelativeSource={RelativeSource TemplatedParent}}">
                    <TextBlock Text="{Binding Node3Value, RelativeSource={RelativeSource TemplatedParent}}"
                               FontFamily="{StaticResource FontMono}" FontSize="11"
                               Foreground="{TemplateBinding AccentBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               IsHitTestVisible="False"/>
                </Border>
                <Border Width="28" Height="28" CornerRadius="14"
                        Background="#FF1E242A"
                        BorderBrush="{TemplateBinding AccentBrush}" BorderThickness="2"
                        Effect="{StaticResource CyanGlowSoftEffect}"
                        Canvas.Left="{Binding Node4X, RelativeSource={RelativeSource TemplatedParent}}"
                        Canvas.Top="{Binding Node4Y, RelativeSource={RelativeSource TemplatedParent}}">
                    <TextBlock Text="{Binding Node4Value, RelativeSource={RelativeSource TemplatedParent}}"
                               FontFamily="{StaticResource FontMono}" FontSize="11"
                               Foreground="{TemplateBinding AccentBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               IsHitTestVisible="False"/>
                </Border>
                <Border Width="28" Height="28" CornerRadius="14"
                        Background="#FF1E242A"
                        BorderBrush="{TemplateBinding AccentBrush}" BorderThickness="2"
                        Effect="{StaticResource CyanGlowSoftEffect}"
                        Canvas.Left="{Binding Node5X, RelativeSource={RelativeSource TemplatedParent}}"
                        Canvas.Top="{Binding Node5Y, RelativeSource={RelativeSource TemplatedParent}}">
                    <TextBlock Text="{Binding Node5Value, RelativeSource={RelativeSource TemplatedParent}}"
                               FontFamily="{StaticResource FontMono}" FontSize="11"
                               Foreground="{TemplateBinding AccentBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               IsHitTestVisible="False"/>
                </Border>
                <Border Width="28" Height="28" CornerRadius="14"
                        Background="#FF1E242A"
                        BorderBrush="{TemplateBinding AccentBrush}" BorderThickness="2"
                        Effect="{StaticResource CyanGlowSoftEffect}"
                        Canvas.Left="{Binding Node6X, RelativeSource={RelativeSource TemplatedParent}}"
                        Canvas.Top="{Binding Node6Y, RelativeSource={RelativeSource TemplatedParent}}">
                    <TextBlock Text="{Binding Node6Value, RelativeSource={RelativeSource TemplatedParent}}"
                               FontFamily="{StaticResource FontMono}" FontSize="11"
                               Foreground="{TemplateBinding AccentBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               IsHitTestVisible="False"/>
                </Border>

                <!-- Y-axis labels -->
                <TextBlock Text="{Binding YAxisLabel0, RelativeSource={RelativeSource TemplatedParent}}"
                           Style="{StaticResource KvKeyText}" TextAlignment="Right" Width="26"
                           Canvas.Left="{Binding YLabelCanvasLeft, RelativeSource={RelativeSource TemplatedParent}}"
                           Canvas.Top="{Binding YLabel0Y, RelativeSource={RelativeSource TemplatedParent}}"/>
                <TextBlock Text="{Binding YAxisLabel1, RelativeSource={RelativeSource TemplatedParent}}"
                           Style="{StaticResource KvKeyText}" TextAlignment="Right" Width="26"
                           Canvas.Left="{Binding YLabelCanvasLeft, RelativeSource={RelativeSource TemplatedParent}}"
                           Canvas.Top="{Binding YLabel1Y, RelativeSource={RelativeSource TemplatedParent}}"/>
                <TextBlock Text="{Binding YAxisLabel2, RelativeSource={RelativeSource TemplatedParent}}"
                           Style="{StaticResource KvKeyText}" TextAlignment="Right" Width="26"
                           Canvas.Left="{Binding YLabelCanvasLeft, RelativeSource={RelativeSource TemplatedParent}}"
                           Canvas.Top="{Binding YLabel2Y, RelativeSource={RelativeSource TemplatedParent}}"/>
                <TextBlock Text="{Binding YAxisLabel3, RelativeSource={RelativeSource TemplatedParent}}"
                           Style="{StaticResource KvKeyText}" TextAlignment="Right" Width="26"
                           Canvas.Left="{Binding YLabelCanvasLeft, RelativeSource={RelativeSource TemplatedParent}}"
                           Canvas.Top="{Binding YLabel3Y, RelativeSource={RelativeSource TemplatedParent}}"/>
                <TextBlock Text="{Binding YAxisLabel4, RelativeSource={RelativeSource TemplatedParent}}"
                           Style="{StaticResource KvKeyText}" TextAlignment="Right" Width="26"
                           Canvas.Left="{Binding YLabelCanvasLeft, RelativeSource={RelativeSource TemplatedParent}}"
                           Canvas.Top="{Binding YLabel4Y, RelativeSource={RelativeSource TemplatedParent}}"/>

                <!-- X-axis labels -->
                <TextBlock Text="{Binding XAxisLabel0, RelativeSource={RelativeSource TemplatedParent}}"
                           Style="{StaticResource KvKeyText}" TextAlignment="Center" Width="32"
                           Canvas.Left="{Binding TickLabel0X, RelativeSource={RelativeSource TemplatedParent}}"
                           Canvas.Top="{Binding XLabelCanvasTop, RelativeSource={RelativeSource TemplatedParent}}"/>
                <TextBlock Text="{Binding XAxisLabel1, RelativeSource={RelativeSource TemplatedParent}}"
                           Style="{StaticResource KvKeyText}" TextAlignment="Center" Width="32"
                           Canvas.Left="{Binding TickLabel1X, RelativeSource={RelativeSource TemplatedParent}}"
                           Canvas.Top="{Binding XLabelCanvasTop, RelativeSource={RelativeSource TemplatedParent}}"/>
                <TextBlock Text="{Binding XAxisLabel2, RelativeSource={RelativeSource TemplatedParent}}"
                           Style="{StaticResource KvKeyText}" TextAlignment="Center" Width="32"
                           Canvas.Left="{Binding TickLabel2X, RelativeSource={RelativeSource TemplatedParent}}"
                           Canvas.Top="{Binding XLabelCanvasTop, RelativeSource={RelativeSource TemplatedParent}}"/>
                <TextBlock Text="{Binding XAxisLabel3, RelativeSource={RelativeSource TemplatedParent}}"
                           Style="{StaticResource KvKeyText}" TextAlignment="Center" Width="32"
                           Canvas.Left="{Binding TickLabel3X, RelativeSource={RelativeSource TemplatedParent}}"
                           Canvas.Top="{Binding XLabelCanvasTop, RelativeSource={RelativeSource TemplatedParent}}"/>
                <TextBlock Text="{Binding XAxisLabel4, RelativeSource={RelativeSource TemplatedParent}}"
                           Style="{StaticResource KvKeyText}" TextAlignment="Center" Width="32"
                           Canvas.Left="{Binding TickLabel4X, RelativeSource={RelativeSource TemplatedParent}}"
                           Canvas.Top="{Binding XLabelCanvasTop, RelativeSource={RelativeSource TemplatedParent}}"/>
                <TextBlock Text="{Binding XAxisLabel5, RelativeSource={RelativeSource TemplatedParent}}"
                           Style="{StaticResource KvKeyText}" TextAlignment="Center" Width="32"
                           Canvas.Left="{Binding TickLabel5X, RelativeSource={RelativeSource TemplatedParent}}"
                           Canvas.Top="{Binding XLabelCanvasTop, RelativeSource={RelativeSource TemplatedParent}}"/>
            </Canvas>
        </Border>
    </ControlTemplate>

    <Style x:Key="MozaEqualizerLineStyle" TargetType="{x:Type controls:MozaCurveEditor}">
        <Setter Property="MinHeight" Value="200"/>
        <Setter Property="AccentBrush" Value="{StaticResource CyanBrush}"/>
        <Setter Property="NodeCount" Value="6"/>
        <Setter Property="YMin" Value="0"/>
        <Setter Property="YMax" Value="400"/>
        <Setter Property="ReferenceLineY" Value="100"/>
        <Setter Property="AnchorAtOrigin" Value="False"/>
        <Setter Property="ShowIdentityLine" Value="False"/>
        <!-- 6 bands spread 0.04..0.96 of plot width (gap 0.184). Wider than
             column-centres while keeping a small ~4% margin from each edge
             (enough that the 28-px node circles don't clip the rounded
             Border corners). End fraction matches the output curve's 0.96
             for a balanced look between the two graphs. -->
        <Setter Property="NodeXFractions"  Value="0.04,0.224,0.408,0.592,0.776,0.96"/>
        <Setter Property="XLabelFractions" Value="0.04,0.224,0.408,0.592,0.776,0.96"/>
        <Setter Property="XAxisLabels"     Value="10Hz,15Hz,25Hz,40Hz,60Hz,100Hz"/>
        <Setter Property="YAxisLabels"     Value="400,300,200,100,0"/>
        <Setter Property="Template" Value="{StaticResource MozaCurveEditorTemplate}"/>
    </Style>

    <!-- ============================================================ -->
    <!-- MozaRangeSlider                                               -->
    <!-- ============================================================ -->
    <!-- Two-thumb range slider — see MozaRangeSlider.cs. One track line,
         a highlighted sub-range between the thumbs, and two draggable
         circular thumbs (same visual language as MozaCurveEditor's nodes:
         dark-filled circle, accent border + glow, value shown inside).
         Endpoint (Minimum/Maximum) labels sit below the track ends. -->
    <ControlTemplate x:Key="MozaRangeSliderTemplate" TargetType="{x:Type controls:MozaRangeSlider}">
        <Border Background="{StaticResource BgDeepBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="0"
                SnapsToDevicePixels="True">
            <Canvas x:Name="PART_Canvas" Background="Transparent" ClipToBounds="True">
                <!-- Full track (dim) -->
                <Path Fill="{StaticResource BorderBrightBrush}"
                      Data="{Binding TrackGeometry, RelativeSource={RelativeSource TemplatedParent}}"/>
                <!-- Highlighted sub-range between the two thumbs -->
                <Path Fill="{TemplateBinding AccentBrush}" Opacity="0.85"
                      Data="{Binding RangeGeometry, RelativeSource={RelativeSource TemplatedParent}}"/>
                <!-- Low thumb -->
                <Border Width="34" Height="34" CornerRadius="17"
                        Background="#FF1E242A"
                        BorderBrush="{TemplateBinding AccentBrush}" BorderThickness="2"
                        Effect="{StaticResource CyanGlowSoftEffect}"
                        Canvas.Left="{Binding LowThumbX, RelativeSource={RelativeSource TemplatedParent}}"
                        Canvas.Top="{Binding ThumbTop, RelativeSource={RelativeSource TemplatedParent}}">
                    <TextBlock Text="{Binding LowLabel, RelativeSource={RelativeSource TemplatedParent}}"
                               FontFamily="{StaticResource FontMono}" FontSize="10"
                               Foreground="{TemplateBinding AccentBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               IsHitTestVisible="False"/>
                </Border>
                <!-- High thumb -->
                <Border Width="34" Height="34" CornerRadius="17"
                        Background="#FF1E242A"
                        BorderBrush="{TemplateBinding AccentBrush}" BorderThickness="2"
                        Effect="{StaticResource CyanGlowSoftEffect}"
                        Canvas.Left="{Binding HighThumbX, RelativeSource={RelativeSource TemplatedParent}}"
                        Canvas.Top="{Binding ThumbTop, RelativeSource={RelativeSource TemplatedParent}}">
                    <TextBlock Text="{Binding HighLabel, RelativeSource={RelativeSource TemplatedParent}}"
                               FontFamily="{StaticResource FontMono}" FontSize="10"
                               Foreground="{TemplateBinding AccentBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               IsHitTestVisible="False"/>
                </Border>
                <!-- Endpoint (Minimum/Maximum) labels -->
                <TextBlock Text="{Binding MinLabel, RelativeSource={RelativeSource TemplatedParent}}"
                           Style="{StaticResource KvKeyText}"
                           Canvas.Left="22" Canvas.Top="{Binding EndLabelTop, RelativeSource={RelativeSource TemplatedParent}}"/>
                <TextBlock Text="{Binding MaxLabel, RelativeSource={RelativeSource TemplatedParent}}"
                           Style="{StaticResource KvKeyText}" TextAlignment="Right" Width="60"
                           Canvas.Right="22" Canvas.Top="{Binding EndLabelTop, RelativeSource={RelativeSource TemplatedParent}}"/>
            </Canvas>
        </Border>
    </ControlTemplate>

    <!-- ============================================================ -->
    <!-- Editable slider value box                                     -->
    <!-- ============================================================ -->
    <!-- Read-only-looking value box that reveals editable chrome on
         hover/focus. Wire it to a slider with the SliderValueBox.Slider
         attached behavior (clr-namespace MozaPlugin.UI) — focus strips the
         unit suffix, Enter/blur pushes the typed value back to the slider.
         The main settings page keeps its own copy of this key with a GotFocus
         EventSetter; this shared version relies on the attached behavior. -->
    <Style x:Key="SliderValueEditBox" TargetType="TextBox">
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Width" Value="78"/>
        <Setter Property="Height" Value="26"/>
        <Setter Property="Padding" Value="6,2"/>
        <Setter Property="Margin" Value="8,0,0,0"/>
        <Setter Property="TextAlignment" Value="Right"/>
        <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="{StaticResource CyanBrush}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CaretBrush" Value="{StaticResource CyanBrush}"/>
        <Setter Property="SelectionBrush" Value="{StaticResource CyanBrush}"/>
        <Setter Property="SelectionOpacity" Value="0.35"/>
        <Setter Property="Cursor" Value="IBeam"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3"
                            SnapsToDevicePixels="True">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}"
                                      VerticalAlignment="Center"
                                      Focusable="False"
                                      HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Hidden"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgCard2Brush}"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgCardBrush}"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BorderGlowBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
